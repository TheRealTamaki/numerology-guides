---
import Layout from '../../../layouts/Layout.astro';
import SidebarCTA from '../../../components/SidebarCTA.astro';
import { houseNumbers } from '../../../data/houseNumbers';

export function getStaticPaths() {
  return houseNumbers.map(hn => ({
    params: { n: String(hn.n) },
    props: { hn },
  }));
}

const { hn } = Astro.props;
const allNumbers = houseNumbers.map(h => ({ n: h.n, title: h.title }));


const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": hn.faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://numerologyguides.blog/" },
    { "@type": "ListItem", "position": 2, "name": "Learn", "item": "https://numerologyguides.blog/learn/" },
    { "@type": "ListItem", "position": 3, "name": "House Number Numerology", "item": "https://numerologyguides.blog/learn/house-number-numerology/" },
    { "@type": "ListItem", "position": 4, "name": `House Number ${hn.n}` }
  ]
};

const isMaster = [11, 22, 33].includes(hn.n);
---

<link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" />
<style>
  :root { --font-family-heading: 'Cormorant Garamond', Georgia, serif; }
  .p-label { font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-soft-gold); font-weight:600; }
  .p-divider { width:48px; height:2px; background:var(--color-soft-gold); margin:0 auto; }
  .section-h2 { font-family:var(--font-family-heading); font-size:clamp(1.6rem,3.5vw,2.25rem); font-weight:700; color:var(--color-body-text); margin:0 0 1.25rem; }
  .faq-list details { border-top:1px solid var(--color-border); }
  .faq-list details:last-child { border-bottom:1px solid var(--color-border); }
  .faq-list summary { padding:1.3rem 0; cursor:pointer; display:flex; align-items:center; justify-content:space-between; gap:1rem; font-weight:600; font-size:1rem; color:var(--color-body-text); list-style:none; transition:color 0.2s; }
  .faq-list summary::-webkit-details-marker { display:none; }
  .faq-list details[open] summary { color:var(--color-violet); }
  .faq-chevron { flex-shrink:0; transition:transform 0.25s; }
  .faq-list details[open] .faq-chevron { transform:rotate(180deg); }
  .faq-answer { padding-bottom:1.3rem; font-size:0.9rem; color:var(--color-muted-text); line-height:1.8; }
</style>

<Layout
  schema={[faqSchema, breadcrumbSchema]}
  title={`House Number ${hn.n} in Numerology: ${hn.title} | Numerology Guides`}
  description={hn.shortDesc}
>

  <!-- Breadcrumb -->
  <nav style="background:var(--color-card-bg);border-bottom:1px solid var(--color-border);padding:0.75rem 1.5rem;" aria-label="Breadcrumb">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:0.5rem;font-size:0.75rem;color:var(--color-muted-text);">
      <a href="/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Home</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Learn</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/house-number-numerology/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">House Number Numerology</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <span style="color:var(--color-body-text);font-weight:600;">House Number {hn.n}</span>
    </div>
  </nav>

  <!-- Hero -->
  <section style="position:relative;overflow:hidden;background:var(--color-midnight,#0e0a1a);">
    <div aria-hidden="true" style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(196,162,78,0.07) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>
    <div aria-hidden="true" style="position:absolute;top:-10%;left:-5%;width:55%;height:120%;background:radial-gradient(ellipse at center,rgba(124,92,191,0.18) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>
    <div style="position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:4rem 1.5rem;display:flex;align-items:center;gap:3rem;flex-wrap:wrap;">
      <div style="flex:1;min-width:280px;">
        <p class="p-label" style="margin-bottom:1.1rem;color:var(--color-soft-gold);opacity:0.9;">{isMaster ? 'Master Number House' : 'House Number Numerology'}</p>
        <div class="p-divider" style="margin:0 0 1.6rem;"></div>
        <h1 style="font-family:var(--font-family-heading);font-size:clamp(2.8rem,6vw,5rem);font-weight:700;line-height:1.06;color:#f5f0e8;letter-spacing:-0.02em;margin:0 0 1.25rem;">
          House Number <em style="color:#c8a8f0;font-style:italic;">{hn.n}</em>: {hn.title}
        </h1>
        <p style="font-size:1.05rem;line-height:1.8;color:rgba(240,234,255,0.78);max-width:460px;margin:0 0 2rem;">{hn.heroSubtitle}</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.875rem;">
          <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:1rem;padding:0.875rem 2rem;border-radius:6px;text-decoration:none;transition:background 0.2s,transform 0.15s;box-shadow:0 4px 20px rgba(124,92,191,0.45);" onmouseover="this.style.background='#6a4eab';this.style.transform='translateY(-1px)'" onmouseout="this.style.background='var(--color-violet)';this.style.transform='none'">Get My Free Reading →</a>
          <a href="#meaning" style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.08);backdrop-filter:blur(6px);color:#f5f0e8;font-weight:600;font-size:1rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.2);transition:border-color 0.2s,background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)';this.style.borderColor='rgba(255,255,255,0.4)'" onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.borderColor='rgba(255,255,255,0.2)'">What It Means ↓</a>
        </div>
      </div>
      <div style="flex-shrink:0;width:clamp(200px,28vw,300px);filter:drop-shadow(0 8px 40px rgba(196,162,78,0.25)) drop-shadow(0 2px 12px rgba(0,0,0,0.6));">
        <img
          src={`/images/learn/house-number-numerology/House Number - ${hn.title}.webp`}
          alt={`House Number ${hn.n}, ${hn.title}`}
          fetchpriority="high"
          style="width:100%;border-radius:6px;display:block;"
        />
      </div>
    </div>
  </section>

  <!-- Author byline -->
  <div style="background:var(--color-light-bg);padding:1.25rem 1.5rem;">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:1rem;">
      <img src="/images/author-maddi-green.webp" alt="Maddie Greene" style="width:2.75rem;height:2.75rem;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid rgba(124,92,191,0.2);" />
      <div>
        <p style="color:var(--color-body-text);font-size:0.875rem;font-weight:600;margin:0 0 0.1rem;">Written by <strong>Maddie Greene</strong></p>
        <p style="color:var(--color-muted-text);font-size:0.78rem;margin:0;">Numerology writer &amp; researcher</p>
      </div>
    </div>
  </div>

  <!-- Content + Sticky sidebar wrapper -->
  <div class="xl:flex xl:gap-6 xl:max-w-[1200px] xl:mx-auto xl:px-4">
    <!-- Main content column -->
    <div class="xl:flex-1 xl:min-w-0">

  <!-- Main content -->
  <article style="background:white;padding-top:1.5rem;padding-bottom:2.5rem;" class="px-4">
    <div class="max-w-3xl mx-auto xl:mx-0 xl:max-w-none">

      <!-- What it means -->
      <section id="meaning" class="mb-10">
        <h2 class="section-h2">What house number {hn.n} means</h2>
        <div style="display:flex;flex-direction:column;gap:1rem;">
          {hn.whatItMeans.map(para => <p style="color:var(--color-body-text);line-height:1.8;">{para}</p>)}
        </div>
      </section>

      <!-- Best for -->
      <section id="best-for" class="mb-10">
        <h2 class="section-h2">Who thrives in a {hn.n} house</h2>
        <div class="card-light p-6">
          <ul style="display:flex;flex-direction:column;gap:0.75rem;list-style:none;padding:0;margin:0;">
            {hn.bestFor.map(item => (
              <li style="display:flex;align-items:flex-start;gap:0.75rem;color:var(--color-body-text);">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--color-violet);flex-shrink:0;margin-top:0.2rem;" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span style="font-size:0.875rem;line-height:1.7;">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Watch for -->
      <section id="watch-for" class="mb-10">
        <h2 class="section-h2">What to watch for</h2>
        <div class="card-light p-6" style="border-left:4px solid #fbbf24;">
          <div style="display:flex;flex-direction:column;gap:1rem;">
            {hn.watchFor.map(item => <p style="color:var(--color-body-text);font-size:0.875rem;line-height:1.8;">{item}</p>)}
          </div>
        </div>
      </section>

      <!-- Strengths & challenges -->
      <section id="strengths" class="mb-10">
        <h2 class="section-h2">Strengths &amp; challenges</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h3 style="font-weight:700;font-family:var(--font-family-heading);color:var(--color-body-text);margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" style="color:var(--color-violet);" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              What this house gives you
            </h3>
            <div style="display:flex;flex-direction:column;gap:1rem;">
              {hn.strengths.map(s => (
                <div class="card-light p-5">
                  <div style="font-weight:600;color:var(--color-body-text);margin-bottom:0.25rem;">{s.title}</div>
                  <p style="font-size:0.875rem;color:var(--color-muted-text);line-height:1.7;">{s.desc}</p>
                </div>
              ))}
            </div>
          </div>
          <div>
            <h3 style="font-weight:700;font-family:var(--font-family-heading);color:var(--color-body-text);margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#f87171;" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              What to manage
            </h3>
            <div style="display:flex;flex-direction:column;gap:1rem;">
              {hn.challenges.map(c => (
                <div class="card-light p-5">
                  <div style="font-weight:600;color:var(--color-body-text);margin-bottom:0.25rem;">{c.title}</div>
                  <p style="font-size:0.875rem;color:var(--color-muted-text);line-height:1.7;">{c.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Living tips -->
      <section id="tips" class="mb-10">
        <h2 class="section-h2">Living in a house number {hn.n}</h2>
        <div style="display:flex;flex-direction:column;gap:1rem;">
          {hn.livingTips.map(para => <p style="color:var(--color-body-text);line-height:1.8;">{para}</p>)}
        </div>
      </section>

      <!-- FAQ -->
      <section id="faq" class="mb-10">
        <h2 class="section-h2">Common questions</h2>
        <div class="faq-list">
          {hn.faq.map(item => (
            <details>
              <summary>{item.q}<svg class="faq-chevron" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg></summary>
              <p class="faq-answer">{item.a}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- All house numbers -->
      <section id="all" class="mb-8">
        <h2 class="section-h2">All house numbers</h2>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-3">
          {allNumbers.map(num => (
            <a
              href={`/learn/house-number-numerology/${num.n}/`}
              style={num.n === hn.n
                ? "display:block;padding:1rem;text-align:center;border-radius:0.5rem;border:2px solid var(--color-soft-gold);background:rgba(196,162,78,0.08);color:var(--color-body-text);font-weight:700;text-decoration:none;transition:all 0.2s;"
                : "display:block;padding:1rem;text-align:center;border-radius:0.5rem;border:2px solid var(--color-border);background:var(--color-card-bg);color:var(--color-muted-text);text-decoration:none;transition:all 0.2s;"}
              onmouseover={num.n !== hn.n ? "this.style.borderColor='var(--color-violet)';this.style.color='var(--color-body-text)';" : ""}
              onmouseout={num.n !== hn.n ? "this.style.borderColor='var(--color-border)';this.style.color='var(--color-muted-text)';" : ""}
            >
              <div style={num.n === hn.n
                ? "font-size:1.5rem;font-weight:700;font-family:var(--font-family-heading);color:var(--color-soft-gold);"
                : "font-size:1.5rem;font-weight:700;font-family:var(--font-family-heading);color:var(--color-body-text);"
              }>{num.n}</div>
              <div style="font-size:0.7rem;margin-top:0.25rem;line-height:1.3;">{num.title.replace(/^The /, '')}</div>
            </a>
          ))}
        </div>
      </section>

    </div>
  </article>

  <!-- Related guides -->
  <section style="background:var(--color-card-bg);border-top:1px solid var(--color-border);padding:2.5rem 1.5rem;">
    <div class="max-w-5xl mx-auto xl:mx-0 xl:max-w-none">
      <h2 class="section-h2">Related guides</h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
        <a href="/learn/house-number-numerology/" class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block">
          <img src="/images/learn/House Number Numerology - Tile.webp" alt="House Number Numerology" class="w-full aspect-[2/3] object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          <div class="p-4">
            <h3 class="font-semibold text-body-text group-hover:text-violet transition-colors mb-1">House Number Numerology</h3>
            <p class="text-xs text-muted-text">Overview and how to calculate</p>
          </div>
        </a>
        <a href={`/learn/life-path-number-${hn.n}/`} class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block">
          <img src={`/images/learn/Life Path Number ${hn.n} - Hero.webp`} alt={`Life Path ${hn.n}`} class="w-full aspect-[16/9] object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          <div class="p-4">
            <h3 class="font-semibold text-body-text group-hover:text-violet transition-colors mb-1">Life Path {hn.n}</h3>
            <p class="text-xs text-muted-text">The personal number with similar energy</p>
          </div>
        </a>
        <a href="/learn/master-numbers/" class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block">
          <img src="/images/learn/Master Numbers - Tile.webp" alt="Master Numbers" class="w-full aspect-[2/3] object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          <div class="p-4">
            <h3 class="font-semibold text-body-text group-hover:text-violet transition-colors mb-1">Master Numbers</h3>
            <p class="text-xs text-muted-text">11, 22, 33 explained</p>
          </div>
        </a>
      </div>
    </div>
  </section>

    </div><!-- end main content column -->
    <SidebarCTA />
  </div><!-- end flex wrapper -->

  <!-- Bottom CTA -->
  <section style="background:var(--color-midnight);padding:5rem 1.5rem;text-align:center;">
    <div style="max-width:36rem;margin:0 auto;">
      <p class="p-label" style="color:rgba(196,162,78,0.7);margin-bottom:0.75rem;">Go Deeper</p>
      <h2 style="font-family:var(--font-family-heading);font-size:clamp(1.75rem,4vw,2.5rem);font-weight:700;color:var(--color-starlight);margin:0 0 1rem;">Want to see your complete numerology chart?</h2>
      <p style="color:rgba(255,255,255,0.65);font-size:1rem;line-height:1.75;margin:0 0 2rem;">
        Your house number is one part of the picture. A full reading connects your life path, expression, soul urge, and personality numbers so you can see how all the pieces fit together.
      </p>
      <a
        href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net"
        target="_blank"
        rel="noopener sponsored"
        style="display:inline-block;background:var(--color-soft-gold);color:var(--color-midnight);font-weight:700;font-size:1.05rem;padding:1rem 2.25rem;border-radius:0.5rem;text-decoration:none;letter-spacing:0.02em;transition:opacity 0.2s;"
        onmouseover="this.style.opacity='0.88'"
        onmouseout="this.style.opacity='1'"
      >
        Get Your Free Numerology Reading
      </a>
    </div>
  </section>

</Layout>

---
import Layout from '../../../layouts/Layout.astro';
import SidebarCTA from '../../../components/SidebarCTA.astro';

const compatibility = [
 { lp: "1", label: "The Leader", score: 4, verdict: "Strong pairing. LP1's drive and ambition are energized by LP3's creativity and infectious enthusiasm. LP1 builds; LP3 inspires." },
 { lp: "2", label: "The Peacemaker", score: 3, verdict: "Warm match. LP2's gentle nature soothes LP3's mood swings, while LP3 brings joy and lightness to LP2's world." },
 { lp: "3", label: "The Communicator", score: 3, verdict: "Exciting but chaotic. Two life path 3s share limitless enthusiasm and many ideas, but both struggle with follow-through." },
 { lp: "4", label: "The Builder", score: 2, verdict: "Challenging. LP4's rigid structure clashes with LP3's need for spontaneity. Success requires serious compromise from both." },
 { lp: "5", label: "The Adventurer", score: 5, verdict: "One of the best matches. Both gravitate toward freedom, adventure, and new experiences. This partnership rarely feels stale." },
 { lp: "6", label: "The Nurturer", score: 4, verdict: "Balanced and nurturing. LP6 provides the stability LP3 often lacks, while LP3 adds beauty, laughter, and creative energy to LP6's world." },
 { lp: "7", label: "The Seeker", score: 3, verdict: "Intriguing but requires work. LP7's depth and introversion can frustrate LP3's need to connect with others, but the intellectual spark is real." },
 { lp: "8", label: "The Powerhouse", score: 2, verdict: "Difficult long-term. LP8's focus on material achievement may feel rigid and soulless to LP3. Different values around success and happiness." },
 { lp: "9", label: "The Humanitarian", score: 5, verdict: "Exceptional match. Both share a desire to uplift others and a big-picture idealism. LP9's wisdom steadies LP3's scattered creative energy." },
];

const strengths = [
 { title: "Natural communicator", desc: "Few life path numbers are as naturally gifted with language. LP3s connect with others effortlessly - in person, in writing, on stage, anywhere." },
 { title: "Infectious enthusiasm", desc: "LP3 energy is magnetic. Their optimism and joy pull people in. They're the ones who make a room feel brighter simply by entering it." },
 { title: "Boundless creativity", desc: "Life path 3 carries an almost limitless creative energy. New ideas arrive constantly - in art, music, writing, conversation, or business." },
 { title: "Uplifting presence", desc: "LP3s have a rare gift: the ability to uplift and inspire. Their sense of humor, charisma, and warmth make them deeply memorable to everyone they meet." },
];

const challenges = [
 { title: "Scattered focus", desc: "With so many ideas always arriving, LP3 may find it difficult to finish what they start. Procrastination and burnout are common when energy is spread too thin." },
 { title: "Self-doubt", desc: "Despite the outward charisma, feelings of insecurity run deep in LP3. Many struggle to share their true feelings or reveal their true self for fear of judgment." },
 { title: "Mood swings", desc: "LP3's highs are extraordinary, but so are the lows. They can become moody, sarcastic, or withdrawn when their expressive nature is blocked or unappreciated." },
 { title: "Avoiding depth", desc: "Playing the clown is safer than being vulnerable. LP3 may use humor and sociability as a shield, gravitating toward surface connection rather than emotional truth." },
];

const famousLP3s = [
 { name: "David Bowie", why: "The blueprint for artistic reinvention: musician, performer, and cultural shape-shifter whose creative energy knew no bounds." },
 { name: "John Travolta", why: "Actor and dancer whose natural charisma and infectious on-screen joy define LP3's magnetic quality." },
 { name: "Celine Dion", why: "A communicator through music. Her voice carries emotion with a natural ability to move and connect with millions." },
 { name: "Jackie Chan", why: "The embodiment of LP3's sense of humor fused with extraordinary talent, a performer who found his true self in joyful, high-energy expression." },
 { name: "Christina Aguilera", why: "Powerfully expressive singer whose music is rooted in authentic emotion and the courage to reveal true feelings." },
 { name: "Snoop Dogg", why: "A witty, charismatic communicator who built an empire on self-expression, language, and an unmistakably magnetic personality." },
];

const allLifePaths = [
 { n: "1", name: "The Leader" },
 { n: "2", name: "The Peacemaker" },
 { n: "3", name: "The Communicator" },
 { n: "4", name: "The Builder" },
 { n: "5", name: "The Adventurer" },
 { n: "6", name: "The Nurturer" },
 { n: "7", name: "The Seeker" },
 { n: "8", name: "The Powerhouse" },
 { n: "9", name: "The Humanitarian" },
 { n: "11", name: "The Intuitive" },
 { n: "22", name: "The Architect" },
 { n: "33", name: "The Teacher" },
];

const faqSchema = {
 "@context": "https://schema.org",
 "@type": "FAQPage",
 "mainEntity": [
 { "@type": "Question", "name": "What does the number 3 life path mean?", "acceptedAnswer": { "@type": "Answer", "text": "Life path number 3 is the number of self-expression, creativity, and communication. People with this life path are natural communicators - expressive, optimistic, charismatic, and driven by a deep need to share their inner world with others. In numerology, 3 represents the creative synthesis of the 1 and 2 - the voice that emerges when will and relationship combine. LP3s are here to bring joy, beauty, and inspiration into the world, approaching everything they do with gusto. Their purpose is found not in building systems or accumulating power, but in expressing their true self and uplifting everyone around them. Life path 3s who fully embrace this truth are able to express themselves in ways that attract people instinctively - their imagination and humour make them magnetic." } },
 { "@type": "Question", "name": "Who should a life path 3 marry?", "acceptedAnswer": { "@type": "Answer", "text": "The best matches for life path 3 tend to be LP5, LP9, LP1, and LP6. LP5 shares LP3's enthusiasm for new experiences and freedom, one of the strongest pairings. LP9 (number 9) brings wisdom and idealism that complement LP3's creative energy beautifully - this pairing is optimistic and deeply connected. LP1 brings ambition and direction that LP3 finds inspiring rather than rigid. LP6 provides the nurturing stability LP3 often lacks. Life path 3s learn to listen more deeply when partnered with a 2 or 6 - partners who model emotional attunement. More challenging partnerships are typically with LP4 (whose structured approach may feel stifling) and LP8 (whose definition of success and happiness diverges from LP3's values). That said, compatibility in numerology is always nuanced - other numbers in your full chart add important context." } },
 { "@type": "Question", "name": "How does life path 3 handle money?", "acceptedAnswer": { "@type": "Answer", "text": "Money management is a blind spot for 3s. Enthusiasm, love of experiences, endless ideas - they lead to impulsive spending. Planning and discipline feel restrictive to 3s. But structure actually expands freedom. A stable foundation means more creative risks, not fewer. Build that structure externally with an accountant or grounded partner - that works better than white-knuckling it alone." } },
 { "@type": "Question", "name": "What are the health issues with the life path number 3?", "acceptedAnswer": { "@type": "Answer", "text": "3s burn out easily. Taking on too many ideas and projects depletes them, especially when suppressing feelings instead of expressing them. Anxiety, self-doubt, mood swings affect mental and physical health. Throat and respiratory issues show up in 3s - connected symbolically to their communication gift. The antidote: creative outlets that release emotion. Music, movement, writing, performance, journaling. Regular rest. Emotional honesty. Relationships where they're safe to be real, not just optimistic." } },
 { "@type": "Question", "name": "What is the shadow side of life path 3?", "acceptedAnswer": { "@type": "Answer", "text": "The shadow side of 3 is the gap between the public face and private reality. Many 3s are outwardly joyful but carry deep insecurity underneath. They use humor, movement, charm as a shield - entertaining the room while feeling unseen. Shadow patterns: sarcasm as a weapon when hurt, procrastination that blocks their gifts, harsh criticism of others when they feel stuck. At worst, they get moody and scattered, leaving half-finished projects everywhere. Here's the key: when 3s stop performing for approval and create from genuine expression, everything shifts. Not magic. Just the energy that went into the mask finally free for something real." } },
 { "@type": "Question", "name": "Are there master numbers related to life path 3?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The number 33 is the master number most closely associated with 3 energy, sometimes called the Master Teacher. It amplifies the communicative and expressive qualities of the 3 to a level of service: the LP33 is oriented toward healing, teaching, and uplifting others at a collective scale. Master numbers like 11 and 22 represent their own distinct vibrations, but 33 shares LP3's gift for language, emotional connection, and the ability to inspire. If your numbers reduce to 33 without passing through a non-master double digit, you carry this amplified vibration rather than a standard life path 3." } }
 ]
};

const breadcrumbSchema = {
 "@context": "https://schema.org",
 "@type": "BreadcrumbList",
 "itemListElement": [
 { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://numerologyguides.blog/" },
 { "@type": "ListItem", "position": 2, "name": "Learn", "item": "https://numerologyguides.blog/learn/" },
 { "@type": "ListItem", "position": 3, "name": "Life Path Numbers", "item": "https://numerologyguides.blog/learn/life-path-number/" },
 { "@type": "ListItem", "position": 4, "name": "Life Path 3" }
 ]
};
---

<Layout
 schema={[faqSchema, breadcrumbSchema]}
 title="Life Path Number 3: The Gift That Feels Like a Curse | Numerology Guides"
 description="Life path number 3 is the most expressive and creatively gifted number in numerology. Discover LP3 traits, compatibility with all life path numbers, career paths, and more."
>


 <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" />

 <style>
   :root { --font-family-heading: \'Cormorant Garamond\', Georgia, serif; }
   .p-label { font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-soft-gold); font-weight:600; }
   .p-divider { width:48px; height:2px; background:var(--color-soft-gold); margin:0 auto; }
   .section-h2 { font-family:var(--font-family-heading); font-size:clamp(1.6rem,3.5vw,2.25rem); font-weight:700; color:var(--color-body-text); margin:0 0 1.25rem; }
   .faq-list details { border-top:1px solid var(--color-border); }
   .faq-list details:last-child { border-bottom:1px solid var(--color-border); }
   .faq-list summary { padding:1.3rem 0; cursor:pointer; display:flex; align-items:center; justify-content:space-between; gap:1rem; font-weight:600; font-size:1rem; color:var(--color-body-text); list-style:none; transition:color 0.2s; }
   .faq-list summary::-webkit-details-marker { display:none; }
   .faq-list details[open] summary { color:var(--color-violet); }
   .faq-chevron { flex-shrink:0; transition:transform 0.25s; }
   .faq-list details[open] .faq-chevron { transform:rotate(180deg); }
   .faq-answer { padding-bottom:1.3rem; font-size:0.9rem; color:var(--color-muted-text); line-height:1.8; }
   .lp-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:0.75rem; }
   @media (max-width:640px) { .lp-grid { grid-template-columns:repeat(3,1fr); } }
   .feat-card { display:block; background:white; border:1px solid var(--color-border); border-radius:8px; overflow:hidden; text-decoration:none; transition:box-shadow 0.25s, transform 0.25s; }
   .feat-card:hover { box-shadow:0 12px 40px rgba(26,21,40,0.1); transform:translateY(-3px); }
   .feat-img-wrap { overflow:hidden; }
   .feat-card img { width:100%; aspect-ratio:2/3; object-fit:cover; transition:transform 0.5s; }
   .feat-card:hover img { transform:scale(1.05); }
 </style>

 <!-- Breadcrumb -->
 <nav class="bg-light-bg border-b border-border/40 px-4 py-2.5" aria-label="Breadcrumb">
 <ol class="max-w-5xl mx-auto flex items-center gap-2 text-xs text-muted-text">
 <li><a href="/" class="hover:text-violet transition-colors">Home</a></li>
 <li class="text-border/60">›</li>
 <li><a href="/learn/" style="color:var(--color-muted-text);text-decoration:none;">Learn</a></li>
 <li class="text-border/60">›</li>
 <li><a href="/learn/life-path-number/" style="color:var(--color-muted-text);text-decoration:none;">Life Path Numbers</a></li>
 <li class="text-border/60">›</li>
 <li class="text-body-text font-medium">Life Path 3</li>
 </ol>
 </nav>

 <!-- Hero -->
 <section style="position:relative;overflow:hidden;background:var(--color-midnight,#0e0a1a);">
   <div aria-hidden="true" style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(196,162,78,0.07) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>
   <div aria-hidden="true" style="position:absolute;top:-10%;left:-5%;width:55%;height:120%;background:radial-gradient(ellipse at center,rgba(124,92,191,0.18) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>
   <div style="position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:4rem 1.5rem;display:flex;align-items:center;gap:3rem;flex-wrap:wrap;">
     <div style="flex:1;min-width:280px;">
       <p class="p-label" style="margin-bottom:1.1rem;color:var(--color-soft-gold);opacity:0.9;">Life Path Number 3</p>
       <div class="p-divider" style="margin:0 0 1.6rem;"></div>
       <h1 style="font-family:var(--font-family-heading);font-size:clamp(2rem,3.5vw,3.75rem);font-weight:700;line-height:1.06;color:#f5f0e8;letter-spacing:-0.02em;margin:0 0 1.25rem;">
         The <em style="color:#c8a8f0;font-style:italic;">Communicator</em>
       </h1>
       <p style="font-size:1.05rem;line-height:1.8;color:rgba(240,234,255,0.78);max-width:460px;margin:0 0 2rem;">LP3 lives to create and connect. Their gift is turning ideas into words, words into art, and art into genuine human connection. If that's your number, you already know what it's like to light up a room.</p>
       <div style="display:flex;flex-wrap:wrap;gap:0.875rem;">
         <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:1rem;padding:0.875rem 2rem;border-radius:6px;text-decoration:none;transition:background 0.2s,transform 0.15s;box-shadow:0 4px 20px rgba(124,92,191,0.45);" onmouseover="this.style.background='#6a4eab';this.style.transform='translateY(-1px)'" onmouseout="this.style.background='var(--color-violet)';this.style.transform='none'">Get My Free Reading →</a>
         <a href="#compatibility" style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.08);backdrop-filter:blur(6px);color:#f5f0e8;font-weight:600;font-size:1rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.2);transition:border-color 0.2s,background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)';this.style.borderColor='rgba(255,255,255,0.4)'" onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.borderColor='rgba(255,255,255,0.2)'">Explore LP3 Compatibility ↓</a>
       </div>
     </div>
     <div style="flex-shrink:0;width:clamp(200px,28vw,300px);filter:drop-shadow(0 8px 40px rgba(196,162,78,0.25)) drop-shadow(0 2px 12px rgba(0,0,0,0.6));">
       <img src="/images/learn/Life Path Number 3 - The Communicator.webp" alt="Life Path 3, The Communicator tarot card" fetchpriority="high" style="width:100%;border-radius:6px;display:block;" />
     </div>
   </div>
 </section>

 <!-- Author byline -->
 <div style="background:var(--color-light-bg);padding:1.25rem 1.5rem;">
   <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:1rem;">
     <img src="/images/author-maddi-green.webp" alt="Maddie Greene" style="width:2.75rem;height:2.75rem;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid rgba(124,92,191,0.2);" />
     <div>
       <p style="color:var(--color-body-text);font-size:0.875rem;font-weight:600;margin:0 0 0.1rem;">Written by <strong>Maddie Greene</strong></p>
       <p style="color:var(--color-muted-text);font-size:0.78rem;margin:0;">Numerology writer &amp; researcher</p>
     </div>
   </div>
 </div>

 <!-- Content + Sticky sidebar wrapper -->
 <div class="xl:flex xl:gap-6 xl:max-w-[1200px] xl:mx-auto xl:px-4">
   <!-- Main content column -->
   <div class="xl:flex-1 xl:min-w-0">

 <!-- What does LP3 mean -->
 <section style="padding:3rem 1.5rem;background:var(--color-card-bg);">

 <div class="max-w-3xl mx-auto">
 <h2 class="section-h2">
 What does life path number 3 mean?
 </h2>
 <div class="space-y-4 text-muted-text leading-relaxed">
 <p>
 If 1 is about forging your direction and 2 is about connection, 3 is about something else: bringing color, creativity, joy into the world. The communicator. The person who makes everyone feel more awake. For 3s, that lands immediately.
 </p>
 <p>
 In numerology, 3 is creation: the synthesis of 1 and 2. For 3s, creativity isn't something they do - it's something they are. Expressing isn't optional. It's a need. Block it, and everything else falls apart.
 </p>
 <p>
 The challenge for 3s is directing that creative energy. With ideas constantly arriving, they scatter across too many outlets without finishing. The work isn't finding the gift. They know what it is. It's trusting it fully and following through.
 </p>
 </div>
 </div>
 </section>

 <!-- Traits image + intro -->
 <section class="py-16 px-4">
 <div class="max-w-5xl mx-auto">
 <div class="grid md:grid-cols-2 gap-10 items-center">
 <div>
 <div class="mb-8 rounded-lg overflow-hidden border border-border/60 shadow-lg">
 <img
 src="/images/learn/Life Path Number 3 - Traits.webp"
 alt="Life Path 3 - The Communicator personality traits"
 class="w-full h-64 object-cover"
 />
 </div>
 </div>
 <div>
 <h2 class="section-h2">
 Personality traits of life path 3s
 </h2>
 <p class="text-muted-text leading-relaxed mb-4">
 If you know a 3, they're the most memorable person in the room. Not loudest, but most alive. They bring genuine enthusiasm and make people feel seen.
 </p>
 <p class="text-muted-text leading-relaxed mb-4">
 Life path 3s carry a joyful, magnetic quality. Laughter comes easily. So does connection. They can talk to anyone and usually leave that person feeling better than before.
 </p>
 <p class="text-muted-text leading-relaxed">
 But behind that warmth, 3s feel things intensely. The joy is real. The self-doubt is too. Block their expression or dismiss it, and the mood shifts sharp. They wear two faces: the public warmth and the private vulnerability.
 </p>
 </div>
 </div>
 </div>
 </section>

 <!-- Strengths and challenges -->
 <section style="padding:3rem 1.5rem;background:var(--color-card-bg);">
 <div class="max-w-5xl mx-auto">
 <h2 class="section-h2" style="text-align:center;margin-bottom:2.5rem;">
 Strengths &amp; Challenges
 </h2>
 <div class="grid md:grid-cols-2 gap-6">
 <div>
 <h3 class="text-lg font-bold font-[family-name:var(--font-family-heading)] text-body-text mb-4 flex items-center gap-2">
 <span class="text-rpg-green text-xl">✦</span> Core Strengths
 </h3>
 <div class="space-y-4">
 {strengths.map(s => (
 <div class="card-light p-5">
 <div class="font-semibold text-body-text mb-1">{s.title}</div>
 <p class="text-sm text-muted-text leading-relaxed">{s.desc}</p>
 </div>
 ))}
 </div>
 </div>
 <div>
 <h3 class="text-lg font-bold font-[family-name:var(--font-family-heading)] text-body-text mb-4 flex items-center gap-2">
 <span class="text-rpg-red text-xl">✦</span> Key Challenges
 </h3>
 <div class="space-y-4">
 {challenges.map(c => (
 <div class="card-light p-5">
 <div class="font-semibold text-body-text mb-1">{c.title}</div>
 <p class="text-sm text-muted-text leading-relaxed">{c.desc}</p>
 </div>
 ))}
 </div>
 </div>
 </div>
 </div>
 </section>

 <!-- Love and relationships -->
 <section class="py-16 px-4">
 <div class="max-w-3xl mx-auto">
 <h2 class="section-h2">
 Life path 3 in love &amp; relationships
 </h2>
 <div class="space-y-4 text-muted-text leading-relaxed">
 <p>
 3s are passionate and expressive in relationships. They love through words, gestures, creative acts. A partner who receives and returns warmth brings out the best. Coldness or rigidity shuts them down.
 </p>
 <p>
 The challenge is vulnerability. 3s use humor as a shield, play the entertainer, hide what they feel. Partners connect with the performance, not the person. Real relationships require sharing the hard stuff: uncertainty, self-doubt.
 </p>
 <p>
 3s want partners with their own creative spark and humor. They struggle with rigid, emotionally stifling relationships. Room to express isn't negotiable.
 </p>
 <p>
 Best matches are 1, 5, 6, 9. Harder ones are 4 (structure feels stifling) and 8 (different values around success).
 </p>
 </div>
 </div>
 </section>

 <!-- Compatibility table -->
 <section id="compatibility" style="padding:3rem 1.5rem;background:var(--color-card-bg);">
 <div class="max-w-5xl mx-auto">
 <h2 class="section-h2" style="text-align:center;">
 Life path 3 compatibility
 </h2>
 <p class="text-center text-muted-text mb-10 max-w-xl mx-auto">
 How 3 pairs with each life path - based on shared traits, values, and friction points.
 </p>
 <div class="overflow-x-auto">
 <table style="width:100%;font-size:0.875rem;border-collapse:collapse;border:1px solid var(--color-border);border-radius:8px;overflow:hidden;box-shadow:0 2px 12px rgba(26,21,40,0.07);">
 <thead>
 <tr>
 <th class="text-left px-4 py-3 text-xs uppercase tracking-wider">Life Path</th>
 <th class="text-left px-4 py-3 text-xs uppercase tracking-wider">Archetype</th>
 <th class="text-center px-4 py-3 text-xs uppercase tracking-wider">Match</th>
 <th class="text-left px-4 py-3 text-xs uppercase tracking-wider hidden md:table-cell">Notes</th>
 </tr>
 </thead>
 <tbody>
 {compatibility.map(row => (
 <tr>
 <td class="px-4 py-3 font-bold text-violet text-base">{row.lp}</td>
 <td class="px-4 py-3 text-body-text font-medium whitespace-nowrap">{row.label}</td>
 <td class="px-4 py-3 text-center whitespace-nowrap">
 {Array.from({length: 5}).map((_, i) => (
 <span class={i < row.score ? "text-gold" : "text-border/40"}>★</span>
 ))}
 </td>
 <td class="px-4 py-3 text-muted-text hidden md:table-cell">{row.verdict}</td>
 </tr>
 ))}
 </tbody>
 </table>
 </div>
 <p class="text-xs text-muted-text mt-4 text-center">
 Compatibility ratings reflect general patterns across life path numbers. Individual charts always add nuance.
 </p>
 </div>
 </section>

 <!-- Career -->
 <section class="py-16 px-4">
 <div class="max-w-3xl mx-auto">
 <h2 class="section-h2">
 Career paths for life path 3
 </h2>
 <div class="space-y-4 text-muted-text leading-relaxed">
 <p>
 3s thrive in work that lets them communicate, create, connect. When they do work that uses their natural ability to engage and inspire, the results show.
 </p>
 <p>
 Writing, journalism, acting, music, comedy, art, design - obvious homes. Many 3s build careers around self-expression. But it doesn't have to be "the arts." Teaching, coaching, PR, marketing, therapy - any role centered on language and connection works.
 </p>
 <p>
 Repetitive, data-heavy, isolated work doesn't suit 3s. Without creative outlet or people interaction, they get moody and withdrawn. Find work with variety and room to express. It doesn't have to be "creative" industry - just creative in role.
 </p>
 </div>
 </div>
 </section>

 <!-- Famous LP3s -->
 <section style="padding:3rem 1.5rem;background:var(--color-card-bg);">
 <div class="max-w-5xl mx-auto">
 <h2 class="section-h2" style="text-align:center;margin-bottom:2.5rem;">
 Famous life path 3s
 </h2>
 <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
 {famousLP3s.map(p => (
 <div class="card-light p-5">
 <div class="font-bold font-[family-name:var(--font-family-heading)] text-body-text mb-2">{p.name}</div>
 <p class="text-sm text-muted-text leading-relaxed">{p.why}</p>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- All life paths grid -->
 <section class="py-16 px-4">
 <div class="max-w-5xl mx-auto">
 <h2 class="section-h2" style="text-align:center;">
 Explore all life path numbers
 </h2>
 <p class="text-center text-muted-text mb-10 max-w-xl mx-auto">
 Each life path carries its own strengths and tensions.
 </p>
 <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-3">
 {allLifePaths.map(lp => (
 <a
 href={`/learn/life-path-number-${lp.n}/`}
 class:list={[

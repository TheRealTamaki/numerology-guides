          <h2>Things people ask</h2>
        </div>

        <div>
          {faqs.map(item => (
            <details>
              <summary>
                {item.q}
                <svg class="hp-faq-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </summary>
              <div class="hp-faq-answer">{item.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══ BOTTOM CTA ════════════════════════════════════════ -->
    <section class="hp-cta">
      <div class="hp-cta-inner">
        <div class="hp-eyebrow">
          <span class="hp-dot" style="background:var(--hp-gold-soft);"></span>
          <span>Numerologist.com</span>
          <span class="hp-rule-line" style="background:rgba(241,236,223,0.18);"></span>
          <span class="hp-dot" style="background:var(--hp-gold-soft);"></span>
        </div>
        <h2>Ready to see what your numbers <em>actually say</em>?</h2>
        <p>
          Enter your name and birthdate. Get a free video reading built around you,
          not a generic overview with your name dropped in.
        </p>
        <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net"
           target="_blank" rel="noopener sponsored" class="hp-btn-gold" style="margin:0 auto;">
          Get your free reading at Numerologist.com
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </a>
      </div>
    </section>

  </div><!-- /.hp-page -->


  <script>
  (function () {

    /* ── Today's Universal Day Number ────────────────────── */
    const TITLES: Record<number, string> = {
      1:"The Initiator", 2:"The Diplomat", 3:"The Voice",
      4:"The Builder", 5:"The Traveler", 6:"The Keeper",
      7:"The Mystic", 8:"The Sovereign", 9:"The Humanitarian",
      11:"The Illuminator", 22:"The Master Builder", 33:"The Master Teacher"
    };
    const KEYWORDS: Record<number, string> = {
      1:"independence · leadership · initiative",
      2:"partnership · intuition · balance",
      3:"expression · creativity · joy",
      4:"structure · discipline · loyalty",
      5:"freedom · curiosity · change",
      6:"nurture · responsibility · harmony",
      7:"inquiry · depth · solitude",
      8:"power · ambition · abundance",
      9:"compassion · completion · wisdom",
      11:"intuition · inspiration · sensitivity",
      22:"vision · execution · legacy",
      33:"devotion · compassion · guidance"
    };

    function reduce(n: number): number {
      if (n < 10 || n === 11 || n === 22 || n === 33) return n;
      let s = 0; let m = n;
      while (m > 0) { s += m % 10; m = Math.floor(m / 10); }
      return reduce(s);
    }

    const now = new Date();
    const m = now.getMonth() + 1;
    const d = now.getDate();
    const y = now.getFullYear();
    const digits = [...String(m), ...String(d), ...String(y)].map(Number);
    let sum = digits.reduce((a, b) => a + b, 0);
    while (sum > 9 && sum !== 11 && sum !== 22 && sum !== 33) {
      sum = String(sum).split('').map(Number).reduce((a, b) => a + b, 0);
    }
    const todayNum = sum;

    const dateStr = now.toLocaleDateString('en-US', {
      weekday: 'long', month: 'long', day: 'numeric', year: 'numeric'
    });

    // Populate today card
    const numEl  = document.getElementById('hp-today-num');
    const titleEl = document.getElementById('hp-today-title');
    const kwEl   = document.getElementById('hp-today-kw');
    const dateEl = document.getElementById('hp-today-date');
    const hpDate = document.getElementById('hp-date');
    if (numEl)   numEl.textContent  = String(todayNum);
    if (titleEl) titleEl.textContent = `A ${TITLES[todayNum]}'s day.`;
    if (kwEl)    kwEl.textContent    = KEYWORDS[todayNum] ?? '';
    if (dateEl)  dateEl.textContent  = dateStr.toUpperCase();
    if (hpDate)  hpDate.textContent  = dateStr;

    /* ── Animated SVG ornament ───────────────────────────── */
    const outer = document.querySelector('.hp-orn-outer') as SVGElement | null;
    const inner = document.querySelector('.hp-orn-inner') as SVGElement | null;
    let tick = 0;

    const outerNums  = document.querySelectorAll<SVGElement>('.hp-orn-num');
    const innerGlyphs = document.querySelectorAll<SVGElement>('.hp-orn-glyph');

    function animateOrnament() {
      tick++;
      const r1 =  tick * 0.3;
      const r2 = -tick * 0.2;
      if (outer) outer.setAttribute('transform', `rotate(${r1} 250 250)`);
      if (inner) inner.setAttribute('transform', `rotate(${r2} 250 250)`);
      // Counter-rotate each number so it stays upright
      outerNums.forEach(el => {
        const x = el.getAttribute('data-x')!;
        const y = el.getAttribute('data-y')!;
        el.setAttribute('transform', `rotate(${-r1} ${x} ${y})`);
      });
      // Counter-rotate each glyph so it stays upright
      innerGlyphs.forEach(el => {
        const x = el.getAttribute('data-x')!;
        const y = el.getAttribute('data-y')!;
        el.setAttribute('transform', `rotate(${-r2} ${x} ${y})`);
      });
      requestAnimationFrame(animateOrnament);
    }
    requestAnimationFrame(animateOrnament);

    /* ── Life Path Calculator ────────────────────────────── */
    const MEANINGS: Record<number, {title:string;archetype:string;body:string;light:string;shadow:string;famous:string;master?:boolean}> = {
      1:{title:"The Initiator",archetype:"Pioneer · Sovereign · Spark",body:"The 1 walks alone at the front of the line — first idea, first step, first to fall and first to stand back up. They carry a current of ambition that resists committee. Their lesson is to lead without ruling, to begin without forcing.",light:"Decisive, original, courageous under pressure.",shadow:"Domineering, impatient with collaboration, lonely at the top.",famous:"Lady Gaga · Tom Hanks · Walt Disney"},
      2:{title:"The Diplomat",archetype:"Mediator · Mirror · Companion",body:"Where the 1 declares, the 2 listens. This is the energy of pairs, of unseen harmonies, of the quiet hand that keeps a room from tipping over. Their gift is the ability to feel what hasn't been said.",light:"Empathic, peacemaking, deeply intuitive.",shadow:"Self-erasing, indecisive, wounded by friction.",famous:"Barack Obama · Madonna · Wolfgang Mozart"},
      3:{title:"The Voice",archetype:"Communicator · Performer · Muse",body:"The 3 lives where language meets play. They turn observation into story and grief into a song you can dance to. Beneath the brightness is a serious craft: making other people feel less alone.",light:"Charismatic, expressive, generous with imagination.",shadow:"Scattered, performative, allergic to depth.",famous:"Jackie Chan · David Bowie · J.K. Rowling"},
      4:{title:"The Builder",archetype:"Architect · Steward · Foundation",body:"The 4 is what survives the weather. They believe in the dignity of the small good repeated daily — the swept floor, the kept word, the load-bearing wall. Their life is a slow act of construction.",light:"Reliable, methodical, quietly powerful.",shadow:"Rigid, joyless, suspicious of change.",famous:"Bill Gates · Frida Kahlo · Clint Eastwood"},
      5:{title:"The Traveler",archetype:"Adventurer · Messenger · Wind",body:"The 5 was born mid-sentence and has been moving ever since. They are the friend who knew the city before it was famous. Restlessness is their compass — and their pitfall.",light:"Adaptable, magnetic, irresistible storyteller.",shadow:"Reckless, commitment-shy, easily addicted to novelty.",famous:"Angelina Jolie · Steven Spielberg · Abraham Lincoln"},
      6:{title:"The Keeper",archetype:"Caretaker · Healer · Hearth",body:"The 6 is the home you didn't know you were homesick for. They build the table where others eat, hold the field where others heal. Their gift is care — but they must learn that love is not earned through self-sacrifice.",light:"Devoted, beauty-loving, profoundly responsible.",shadow:"Martyr complex, meddlesome, perfectionistic.",famous:"Meryl Streep · John Lennon · Albert Einstein"},
      7:{title:"The Mystic",archetype:"Seeker · Scholar · Solitary",body:"The 7 needs the room to be quiet. They are the long walk, the unfinished thesis, the question that does not flinch. Their work is to translate the invisible into something the rest of us can read.",light:"Analytical, spiritual, fluent in nuance.",shadow:"Withdrawn, cynical, paralyzed by the unknown.",famous:"Marilyn Monroe · Stephen Hawking · Princess Diana"},
      8:{title:"The Sovereign",archetype:"Executive · Magnate · Karma",body:"The 8 moves where consequence lives. They build empires, restructure systems, count the cost. Their lesson is to hold power without becoming it — to wield without being wielded by it.",light:"Strategic, abundant, fair-handed in authority.",shadow:"Cold, money-obsessed, drunk on control.",famous:"Pablo Picasso · Nelson Mandela · Sandra Bullock"},
      9:{title:"The Humanitarian",archetype:"Sage · Artist · Letting-Go",body:"The 9 has lived all the other numbers and walked back to tell us. They are the closing of a cycle, the artist whose work belongs to the world. Their work is to give without expecting return.",light:"Generous, wise, world-conscious.",shadow:"Resentful, self-pitying, unable to let go.",famous:"Mahatma Gandhi · Jim Carrey · Mother Teresa"},
      11:{title:"The Illuminator",archetype:"Visionary · Channel · Lightning Rod",body:"The 11 is a 2 with a lightning bolt running through it. It receives signals others can't hear and pays for the privilege in nervous-system overhead. Their work is to translate the transmission into something useable.",light:"Inspired, electric, profoundly perceptive.",shadow:"Anxious, ungrounded, burnt by their own current.",famous:"Michelle Obama · Tim Burton · Katy Perry",master:true},
      22:{title:"The Master Builder",archetype:"Manifestor · Engineer · World-Shaper",body:"The 22 is the rarest combination of dreamer and bricklayer. It sees what could exist and possesses the practical patience to build it, brick by brick, over decades.",light:"Visionary, capable, structurally world-changing.",shadow:"Crushed by the weight of their own potential.",famous:"The Dalai Lama · Paul McCartney · Oprah Winfrey",master:true},
      33:{title:"The Master Teacher",archetype:"Bodhisattva · Healer · Selfless Voice",body:"The 33 is the rarest of all — a 6 raised to its highest octave. It exists to teach through love and to elevate everyone in its orbit. The shadow is martyrdom; the gift is grace.",light:"Healing, devotional, lifts entire communities.",shadow:"Self-erasing, savior-coded, easily exhausted.",famous:"Albert Einstein · John Lennon · Francis of Assisi",master:true},
    };

    const MONTHS_SHORT = ["JAN","FEB","MAR","APR","MAY","JUN","JUL","AUG","SEP","OCT","NOV","DEC"];
    const MONTHS_FULL  = ["January","February","March","April","May","June","July","August","September","October","November","December"];

    const GLYPHS: Record<number, string> = {
      1:'<path d="M20 4 L20 36 M14 10 L20 4 L26 10"/>',
      2:'<path d="M8 14 Q8 4 20 4 Q32 4 32 14 Q32 22 8 36 L32 36"/>',
      3:'<path d="M8 8 Q20 -2 28 8 Q22 18 18 20 Q28 22 28 30 Q20 42 8 32"/>',
      4:'<path d="M24 4 L8 24 L30 24 M24 4 L24 36"/>',
      5:'<path d="M30 4 L12 4 L10 18 Q22 14 28 22 Q28 36 14 36 Q8 36 6 30"/>',
      6:'<circle cx="20" cy="26" r="10"/><path d="M30 14 Q20 -2 12 14"/>',
      7:'<path d="M6 6 L34 6 L18 36"/>',
      8:'<circle cx="20" cy="12" r="8"/><circle cx="20" cy="28" r="8"/>',
      9:'<circle cx="20" cy="14" r="10"/><path d="M30 14 Q26 36 14 36"/>',
      11:'<path d="M14 4 L14 36"/><path d="M26 4 L26 36"/><circle cx="20" cy="20" r="2"/>',
      22:'<path d="M6 12 Q6 4 14 4 Q22 4 20 14 L6 36 L22 36"/><path d="M22 12 Q22 4 30 4 Q38 4 36 14 L22 36 L38 36"/>',
      33:'<path d="M6 8 Q14 0 20 8 Q14 16 12 18 Q22 18 22 26 Q14 38 6 30 M20 8 Q28 0 34 8 Q28 16 26 18 Q36 18 36 26 Q28 38 20 30"/>',
    };

    function dSum(n: number): number {
      return String(n).split('').reduce((s,d) => s + Number(d), 0);
    }
    function reducePart(n: number): {value:number; steps:number[]} {
      const steps = [n]; let v = n;
      while (v > 9 && v !== 11 && v !== 22 && v !== 33) { v = dSum(v); steps.push(v); }
      return { value: v, steps };
    }

    let calcMonth = 0, calcDay = 0, calcYear = '';
    let calcStep  = 0;

    const stageMonth  = document.getElementById('hpc-stage-month')!;
    const stageDay    = document.getElementById('hpc-stage-day')!;
    const stageYear   = document.getElementById('hpc-stage-year')!;
    const stageReveal = document.getElementById('hpc-stage-reveal')!;
    const dayGrid     = document.getElementById('hpc-day-grid')!;
    const dayPrompt   = document.getElementById('hpc-day-prompt')!;
    const yearInput   = document.getElementById('hpc-year') as HTMLInputElement;
    const revealBtn   = document.getElementById('hpc-reveal-btn') as HTMLButtonElement;
    const mathLine    = document.getElementById('hpc-math-line')!;
    const revelation  = document.getElementById('hpc-revelation')!;
    const steps       = document.querySelectorAll<HTMLButtonElement>('.hp-step');

    function showStage(n: number) {
      [stageMonth, stageDay, stageYear, stageReveal].forEach((el, i) => {
        el.style.display = i === n ? '' : 'none';
      });
      steps.forEach((btn, i) => {
        btn.classList.toggle('active', i === n);
        btn.classList.toggle('done', i < n);
        btn.disabled = i > n && !(i === 3 && calcMonth && calcDay && isYearValid());
      });
      calcStep = n;
    }

    function isYearValid(): boolean {
      const y = parseInt(calcYear);
      return calcYear.length === 4 && y >= 1900 && y <= 2099;
    }

    function buildDayGrid() {
      const yr  = parseInt(calcYear) || 2000;
      const days = new Date(yr, calcMonth, 0).getDate();
      dayGrid.innerHTML = '';
      for (let d = 1; d <= days; d++) {
        const btn = document.createElement('button');
        btn.className = 'hp-day-cell' + (d === calcDay ? ' selected' : '');
        btn.textContent = String(d);
        btn.addEventListener('click', () => {
          calcDay = d;
          dayGrid.querySelectorAll('.hp-day-cell').forEach(b => b.classList.remove('selected'));
          btn.classList.add('selected');
          setTimeout(() => showStage(2), 280);
        });
        // border rules: last in each row, last rows
        const col = (d - 1) % 8;
        if (col === 7) btn.style.borderRight = 'none';
        dayGrid.appendChild(btn);
      }
      // remove border-bottom from last row
      const lastRowStart = days - (days % 8 || 8);
      dayGrid.querySelectorAll<HTMLButtonElement>('.hp-day-cell').forEach((b, i) => {
        if (i >= lastRowStart) b.style.borderBottom = 'none';
      });
    }

    // Month clicks
    document.querySelectorAll<HTMLButtonElement>('.hp-month-cell').forEach(btn => {
      btn.addEventListener('click', () => {
        calcMonth = Number(btn.dataset.month);
        document.querySelectorAll('.hp-month-cell').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        dayPrompt.textContent = `Which day of ${MONTHS_FULL[calcMonth - 1]}?`;
        buildDayGrid();
        setTimeout(() => showStage(1), 280);
      });
    });

    // Stepper back-nav
    steps.forEach((btn, i) => {
      btn.addEventListener('click', () => {
        if (i < calcStep) showStage(i);
        if (i === 3 && calcMonth && calcDay && isYearValid()) doReveal();
      });
    });

    // Year input
    yearInput.addEventListener('input', () => {
      calcYear = yearInput.value.replace(/\D/g, '');
      yearInput.value = calcYear;
      revealBtn.disabled = !isYearValid();
    });
    yearInput.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' && isYearValid()) doReveal();
    });
    revealBtn.addEventListener('click', doReveal);

    function doReveal() {
      showStage(3);
      buildReveal();
    }

    function buildReveal() {
      const m = reducePart(calcMonth);
      const d = reducePart(calcDay);
      const y = reducePart(parseInt(calcYear));
      const sum = m.value + d.value + y.value;
      const fin = reducePart(sum);

      // Build math line — initially show raw values only
      mathLine.innerHTML = `
        <div class="hp-date-part">
          <div class="hp-dp-label">${MONTHS_SHORT[calcMonth - 1]}</div>
          <div class="hp-dp-stack" id="hpc-m-stack"></div>
        </div>
        <span class="hp-op">+</span>
        <div class="hp-date-part">
          <div class="hp-dp-label">DAY</div>
          <div class="hp-dp-stack" id="hpc-d-stack"></div>
        </div>
        <span class="hp-op">+</span>
        <div class="hp-date-part">
          <div class="hp-dp-label">YEAR</div>
          <div class="hp-dp-stack" id="hpc-y-stack"></div>
        </div>
        <span class="hp-op equals hp-op-sum" id="hpc-op-eq">=</span>
        <div class="hp-sum-block" id="hpc-sum">
          <div class="hp-sum-label">SUM</div>
          <div class="hp-sum-row">
            <div class="hp-sum-value">${sum}</div>
            <div class="hp-sum-inline-trail" id="hpc-trail" style="display:none;"></div>
          </div>
        </div>
      `;

      function buildStack(id: string, part: {steps: number[]}, isGold: boolean) {
        const el = document.getElementById(id)!;
        part.steps.forEach((v, i) => {
          const d = document.createElement('div');
          d.className = 'hp-dp-value' + (i === 0 ? ' raw' : '');
          d.textContent = String(v);
          el.appendChild(d);
        });
      }

      buildStack('hpc-m-stack', m, false);
      buildStack('hpc-d-stack', d, false);
      buildStack('hpc-y-stack', y, false);

      // Animate phases
      setTimeout(() => {
        // Phase 1: show reduced values + highlight finals
        document.querySelectorAll<HTMLElement>('.hp-dp-value:not(.raw)').forEach(el => {
          el.classList.add('shown');
        });
        // Gold the last value in each stack
        ['hpc-m-stack','hpc-d-stack','hpc-y-stack'].forEach(id => {
          const stack = document.getElementById(id);
          const last = stack?.querySelector<HTMLElement>('.hp-dp-value:last-child');
          if (last) last.classList.add('gold');
        });
      }, 600);

      setTimeout(() => {
        // Phase 2: show sum
        const opEl = document.getElementById('hpc-op-eq');
        const sumEl = document.getElementById('hpc-sum');
        if (opEl) opEl.classList.add('shown');
        if (sumEl) sumEl.classList.add('shown');
        if (fin.steps.length > 1) {
          const trail = document.getElementById('hpc-trail');
          if (trail) {
            const finalNum = fin.steps[fin.steps.length - 1];
            trail.innerHTML = `<span class="hp-sum-arrow-inline">→</span><span class="hp-sum-final">${finalNum}</span>`;
            trail.style.display = 'flex';
          }
        }
      }, 1800);

      setTimeout(() => {
        // Phase 3: full reveal panel
        const meaning = MEANINGS[fin.value];
        revelation.innerHTML = `
          <div class="hp-rev-left">
            <div class="hp-rev-tag">
              <span class="hp-dot"></span> You are a
              ${meaning?.master ? '<span class="hp-master-tag">Master Number</span>' : ''}
            </div>
            <span class="hp-rev-number">${fin.value}</span>
            <div class="hp-rev-title">${meaning?.title ?? ''}</div>
            <div class="hp-rev-archetype">${meaning?.archetype ?? ''}</div>
          </div>
          <div class="hp-rev-right">
            <p class="hp-rev-body">${meaning?.body ?? ''}</p>
            <div class="hp-rev-traits">
              <div class="hp-trait">
                <div class="hp-trait-label">In the light</div>
                <div class="hp-trait-text">${meaning?.light ?? ''}</div>
              </div>
              <div class="hp-trait">
                <div class="hp-trait-label">In the shadow</div>
                <div class="hp-trait-text">${meaning?.shadow ?? ''}</div>
              </div>
              <div class="hp-trait">
                <div class="hp-trait-label">You share this with</div>
                <div class="hp-trait-text">${meaning?.famous ?? ''}</div>
              </div>
            </div>
            <div class="hp-rev-actions">
              <a href="/learn/life-path-number-${fin.value}/" class="hp-link-btn">Read the full ${fin.value} guide &rarr;</a>
              <button id="hpc-reset" class="hp-calc-reset-btn">↩ Calculate another</button>
            </div>
          </div>
        `;
        revelation.classList.add('shown');
        document.getElementById('hpc-reset')?.addEventListener('click', resetCalc);
      }, 3000);

      // Phase 4: fade out intermediate reduction steps, leave only finals
      setTimeout(() => {
        document.querySelectorAll<HTMLElement>('.hp-dp-value:not(.raw):not(.gold)').forEach(el => {
          el.classList.add('faded');
        });
        // also fade the raw values that have been superseded (multi-step reductions)
        ['hpc-m-stack','hpc-d-stack','hpc-y-stack'].forEach(id => {
          const stack = document.getElementById(id);
          if (!stack) return;
          const all = stack.querySelectorAll<HTMLElement>('.hp-dp-value');
          if (all.length > 1) {
            // fade the raw original, keep only the gold final
            all.forEach((el, i) => {
              if (i < all.length - 1) el.classList.add('faded');
            });
          }
        });
      }, 4200);
    }

    function resetCalc() {
      calcMonth = 0; calcDay = 0; calcYear = '';
      yearInput.value = '';
      revealBtn.disabled = true;
      mathLine.innerHTML = '';
      revelation.innerHTML = '';
      revelation.classList.remove('shown');
      document.querySelectorAll('.hp-month-cell').forEach(b => b.classList.remove('selected'));
      showStage(0);
    }

  })();
  </script>

</Layout>

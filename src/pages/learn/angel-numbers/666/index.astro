---
import Layout from '../../../../layouts/Layout.astro';
import SidebarCTA from '../../../../components/SidebarCTA.astro';

const otherAngel = [
  { number: "111", title: "New Beginnings", href: "/learn/angel-numbers/111/", image: "/images/Angel Number 111.webp" },
  { number: "222", title: "Trust & Balance", href: "/learn/angel-numbers/222/", image: "/images/Angel Number 222.webp" },
  { number: "333", title: "Creative Expression", href: "/learn/angel-numbers/333/", image: "/images/Angel Number 333.webp" },
  { number: "444", title: "Stability & Protection", href: "/learn/angel-numbers/444/", image: "/images/Angel Number 444.webp" },
  { number: "555", title: "Major Change", href: "/learn/angel-numbers/555/", image: "/images/Angel Number 555.webp" },
  { number: "777", title: "Spiritual Alignment", href: "/learn/angel-numbers/777/", image: "/images/Angel Number 777.webp" },
  { number: "888", title: "Abundance & Power", href: "/learn/angel-numbers/888/", image: "/images/Angel Number 888.webp" },
  { number: "999", title: "Completion & Release", href: "/learn/angel-numbers/999/", image: "/images/Angel Number 999.webp" },
  { number: "000", title: "Infinite Potential", href: "/learn/angel-numbers/000/", image: "/images/Angel Number 000.webp" },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does 666 mean in numerology?",
      "acceptedAnswer": { "@type": "Answer", "text": "In numerology, 666 is the number 6 amplified three times. The number 6 represents nurturing, responsibility, home, and balance, particularly the balance between material concerns and emotional or spiritual wellbeing. 666 as an angel number is a realignment signal: it appears when your focus has drifted too far toward worry, material fixation, or trying to control things that aren't yours to control. It's asking you to step back and rebalance. Despite its cultural reputation, 666 in numerology has nothing to do with evil or darkness." }
    },
    {
      "@type": "Question",
      "name": "Is 666 a bad number?",
      "acceptedAnswer": { "@type": "Answer", "text": "No. The association between 666 and evil comes from the Book of Revelation in Christian scripture, where it's called the 'number of the beast.' In numerology, 666 has a completely different meaning. The number 6 is actually one of the most caring, nurturing numbers in the system. It's associated with home, family, service, and compassion. Seeing 666 as an angel number is not a bad sign. It's a gentle correction: a reminder to check where your attention has gone and bring it back to what actually matters." }
    },
    {
      "@type": "Question",
      "name": "Why do I keep seeing 666?",
      "acceptedAnswer": { "@type": "Answer", "text": "You're probably out of balance in some way. The most common trigger for seeing 666 is excessive worry about material things: money, status, possessions, appearances. The number shows up when you've been spending too much mental energy on external concerns and not enough on your emotional, relational, or spiritual life. It also appears when you're over-giving: taking on everyone else's problems, trying to fix things that aren't yours to fix, or neglecting your own needs in the process of caring for others." }
    },
    {
      "@type": "Question",
      "name": "What does 666 mean in love?",
      "acceptedAnswer": { "@type": "Answer", "text": "In love, 666 is asking about balance in how you give and receive. The 6 is the nurturer, and when it triples, the question becomes: are you nurturing the relationship, or are you smothering it? Are you caring for your partner, or are you trying to control outcomes? 666 in love also asks whether you're neglecting the relationship because of work or material pursuits. If you've been too focused on career and not enough on connection, this number is the flag. The 6 always brings things back to what matters most: the people in your life." }
    },
    {
      "@type": "Question",
      "name": "What should I do when I see 666?",
      "acceptedAnswer": { "@type": "Answer", "text": "Check where your attention has drifted. The most useful response to 666 is an honest inventory: have you been worrying too much about money or status? Have you been over-giving and neglecting yourself? Have you been trying to control things instead of trusting the process? The number is a recalibration tool. It identifies the imbalance. Once you see it, the action is to consciously redirect your focus toward what's been neglected. Usually that means more presence, more gratitude, more rest, and less anxious effort." }
    },
    {
      "@type": "Question",
      "name": "What's the spiritual meaning of 666?",
      "acceptedAnswer": { "@type": "Answer", "text": "Spiritually, 666 is about releasing attachment to material outcomes and reconnecting with your deeper values. The 6 carries the energy of service, compassion, and home. When it appears tripled, the spiritual message is that you've been operating from fear: fear of not having enough, fear of losing what you have, fear of things falling apart. 666 asks you to replace that fear with trust. Your material needs are handled. The question is whether you're living in a way that aligns with what your soul actually cares about." }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://numerologyguides.blog/" },
    { "@type": "ListItem", "position": 2, "name": "Learn", "item": "https://numerologyguides.blog/learn/" },
    { "@type": "ListItem", "position": 3, "name": "Angel Numbers", "item": "https://numerologyguides.blog/learn/angel-numbers/" },
    { "@type": "ListItem", "position": 4, "name": "666" }
  ]
};
---

<Layout
  title="Angel Number 666 Meaning: Realignment, Balance & Letting Go of Worry"
  description="Angel number 666 isn't what you think. In numerology, it's a signal to rebalance: to release worry and refocus on what matters. Learn the real meaning of 666 in love, career, and spiritual growth."
  schema={[faqSchema, breadcrumbSchema]}
>
  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" />
  <style>
    :root { --font-family-heading: 'Cormorant Garamond', Georgia, serif; }
    .p-label { font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-soft-gold); font-weight:600; }
    .p-divider { width:48px; height:2px; background:var(--color-soft-gold); margin:0 auto; }
    .section-h2 { font-family:var(--font-family-heading); font-size:clamp(1.6rem,3.5vw,2.25rem); font-weight:700; color:var(--color-body-text); margin:0 0 1.25rem; }
    .faq-list details { border-top:1px solid var(--color-border); }
    .faq-list details:last-child { border-bottom:1px solid var(--color-border); }
    .faq-list summary { padding:1.3rem 0; cursor:pointer; display:flex; align-items:center; justify-content:space-between; gap:1rem; font-weight:600; font-size:1rem; color:var(--color-body-text); list-style:none; transition:color 0.2s; }
    .faq-list summary::-webkit-details-marker { display:none; }
    .faq-list details[open] summary { color:var(--color-violet); }
    .faq-chevron { flex-shrink:0; transition:transform 0.25s; }
    .faq-list details[open] .faq-chevron { transform:rotate(180deg); }
    .faq-answer { padding-bottom:1.3rem; font-size:0.9rem; color:var(--color-muted-text); line-height:1.8; }
  </style>

  <!-- Breadcrumb -->
  <nav style="background:var(--color-card-bg);border-bottom:1px solid var(--color-border);padding:0.75rem 1.5rem;" aria-label="Breadcrumb">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:0.5rem;font-size:0.75rem;color:var(--color-muted-text);">
      <a href="/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Home</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Learn</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/angel-numbers/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Angel Numbers</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <span style="color:var(--color-body-text);font-weight:600;">666</span>
    </div>
  </nav>

  <!-- Hero -->
  <section style="position:relative;overflow:hidden;background:var(--color-midnight,#0e0a1a);">
    <div aria-hidden="true" style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(196,162,78,0.07) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>
    <div aria-hidden="true" style="position:absolute;top:-10%;left:-5%;width:55%;height:120%;background:radial-gradient(ellipse at center,rgba(124,92,191,0.18) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>
    <div style="position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:4rem 1.5rem;display:flex;align-items:center;gap:3rem;flex-wrap:wrap;">
      <div style="flex:1;min-width:280px;">
        <p class="p-label" style="margin-bottom:1.1rem;color:var(--color-soft-gold);opacity:0.9;">Angel Number</p>
        <div class="p-divider" style="margin:0 0 1.6rem;"></div>
        <h1 style="font-family:var(--font-family-heading);font-size:clamp(2.8rem,6vw,5rem);font-weight:700;line-height:1.06;color:#f5f0e8;letter-spacing:-0.02em;margin:0 0 1.25rem;">
          Angel Number <em style="color:#c8a8f0;font-style:italic;">666</em>: Realignment &amp; Letting Go of Worry
        </h1>
        <p style="font-size:1.05rem;line-height:1.8;color:rgba(240,234,255,0.78);max-width:460px;margin:0 0 2rem;">Before you panic. 666 in numerology has nothing to do with its pop-culture reputation. It's actually one of the most caring numbers in the system. Here's what it really means.</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.875rem;">
          <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:1rem;padding:0.875rem 2rem;border-radius:6px;text-decoration:none;transition:background 0.2s,transform 0.15s;box-shadow:0 4px 20px rgba(124,92,191,0.45);" onmouseover="this.style.background='#6a4eab';this.style.transform='translateY(-1px)'" onmouseout="this.style.background='var(--color-violet)';this.style.transform='none'">Get My Free Reading →</a>
          <a href="#meaning" style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.08);backdrop-filter:blur(6px);color:#f5f0e8;font-weight:600;font-size:1rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.2);transition:border-color 0.2s,background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)';this.style.borderColor='rgba(255,255,255,0.4)'" onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.borderColor='rgba(255,255,255,0.2)'">What It Means ↓</a>
        </div>
      </div>
      <div style="flex-shrink:0;width:clamp(200px,28vw,300px);filter:drop-shadow(0 8px 40px rgba(196,162,78,0.25)) drop-shadow(0 2px 12px rgba(0,0,0,0.6));">
        <img
          src="/images/learn/angel-numbers/Angel Number - 666.webp"
          alt="Angel Number 666 — Realignment &amp; Letting Go of Worry"
          fetchpriority="high"
          style="width:100%;border-radius:6px;display:block;"
        />
      </div>
    </div>
  </section>

  <!-- Author byline -->
  <div style="background:var(--color-card-bg);padding:1.75rem 1.5rem;border-bottom:1px solid var(--color-border);">
    <div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:1rem;">
      <img src="/images/author-maddi-green.webp" alt="Maddie Greene" style="width:52px;height:52px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid var(--color-border);" />
      <div>
        <p style="font-size:0.95rem;font-weight:600;color:var(--color-body-text);margin:0;">Written by <strong>Maddie Greene</strong></p>
        <p style="font-size:0.8rem;color:var(--color-muted-text);margin:0;">Numerology writer &amp; researcher</p>
      </div>
    </div>
  </div>

  <div class="xl:flex xl:gap-6 xl:max-w-[1200px] xl:mx-auto xl:px-4">
    <div class="xl:flex-1 xl:min-w-0">

  <section style="background:var(--color-card-bg);padding:2.5rem 1.5rem 3rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">What does angel number 666 actually mean?</h2>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        Let's clear this up immediately: in numerology, the number 6 is one of the warmest numbers in the system. It's the nurturer. The caretaker. The one that holds families together and makes houses feel like homes. It's associated with the <a href="/learn/life-path-number-6/" style="color:var(--color-violet);text-decoration:none;font-weight:500;">life path 6</a> energy: responsible, compassionate, service-oriented. There's nothing dark about it.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        When 6 appears three times as 666, the message is about rebalancing. Your focus has drifted somewhere it doesn't belong: usually toward worry, material fixation, or over-control. The number is asking you to step back and check: what have you been giving too much attention to, and what have you been neglecting?
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        The most common trigger for 666 is money anxiety. Not actual financial crisis — anxiety about money. The kind where you're constantly running numbers in your head, checking accounts, worrying about future expenses. The 6 says: your needs will be met. But that worry is eating up energy that could be going toward your relationships, your health, or your peace of mind.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1.5rem;">
        The other common trigger is over-giving. The 6 is the helper, and when it shows up tripled, it sometimes means you've been helping too much. Taking on other people's problems. Fixing things that aren't yours to fix. Saying yes when you mean no. 666 is the number that says: care for others, absolutely. But not at the expense of yourself.
      </p>
      <div style="background:var(--color-light-bg);border:1px solid var(--color-border);border-left:4px solid var(--color-soft-gold);border-radius:8px;padding:1.25rem 1.5rem;">
        <p style="font-size:0.9rem;color:var(--color-muted-text);line-height:1.8;margin:0;">
          <strong style="color:var(--color-body-text);">The core message of 666:</strong> Your attention has drifted. Whether it's toward worry, material fixation, or over-functioning for others, something is out of balance. Step back. Breathe. Refocus on what actually matters to you.
        </p>
      </div>
    </div>
  </section>

  <section style="background:white;padding:3rem 1.5rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">When does 666 show up?</h2>
      <div style="display:flex;flex-direction:column;gap:1rem;">
        <div class="card-light p-5">
          <h3 style="font-weight:700;color:var(--color-body-text);margin:0 0 0.5rem;">When worry has taken over</h3>
          <p style="font-size:0.875rem;color:var(--color-muted-text);line-height:1.7;margin:0;">Financial anxiety, health anxiety, anxious thoughts on repeat. 666 shows up when the worry has become disproportionate to the actual situation. It's not saying ignore real problems. It's saying your worry is consuming more energy than the problem deserves.</p>
        </div>
        <div class="card-light p-5">
          <h3 style="font-weight:700;color:var(--color-body-text);margin:0 0 0.5rem;">When you've been over-giving</h3>
          <p style="font-size:0.875rem;color:var(--color-muted-text);line-height:1.7;margin:0;">You've been everyone's support system and you haven't stopped to ask who's supporting you. The 6 is naturally generous, but 666 flags when that generosity has crossed into self-neglect. Who's taking care of the person doing all the taking care?</p>
        </div>
        <div class="card-light p-5">
          <h3 style="font-weight:700;color:var(--color-body-text);margin:0 0 0.5rem;">When material concerns are crowding out everything else</h3>
          <p style="font-size:0.875rem;color:var(--color-muted-text);line-height:1.7;margin:0;">Working too many hours. Obsessing over possessions or status. Measuring your worth by your bank account. 666 appears when the material side of life has expanded to fill all available space, leaving no room for connection, rest, or meaning.</p>
        </div>
        <div class="card-light p-5">
          <h3 style="font-weight:700;color:var(--color-body-text);margin:0 0 0.5rem;">When you need to come home to yourself</h3>
          <p style="font-size:0.875rem;color:var(--color-muted-text);line-height:1.7;margin:0;">The 6 is the home number. Sometimes 666 shows up simply to say: you've been too far from yourself for too long. Come back. Reconnect with what grounds you: your home, your people, your body, your sense of peace.</p>
        </div>
      </div>
    </div>
  </section>

  <section style="background:var(--color-card-bg);padding:3rem 1.5rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">666 in love &amp; relationships</h2>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        The 6 is the most relationship-oriented number alongside the 2. In love, 666 is asking one central question: is the dynamic balanced?
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        <strong style="color:var(--color-body-text);">If you're single:</strong> 666 is asking what you've been prioritizing over connection. Has work consumed everything? Has worry about the future made you unavailable? The number suggests that a relationship is available to you, but only if you make space for it. That might mean doing less, not more. Loosening your schedule. Being present enough to actually notice someone.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        <strong style="color:var(--color-body-text);">If you're in a relationship:</strong> Who's doing the emotional labour? Is one person always the caretaker and the other always the one being cared for? 666 flags imbalance in giving and receiving. It also asks whether the relationship has enough breathing room. The shadow side of 6 energy is over-involvement: trying to manage your partner, anticipating their needs before they've expressed them, controlling the domestic environment to an exhausting degree. Love doesn't need to be micromanaged.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0;">
        <strong style="color:var(--color-body-text);">The 666 relationship lesson:</strong> Caring for someone and controlling someone can look identical from the outside. 666 asks you to be honest about which one you're doing.
      </p>
    </div>
  </section>

  <section style="background:white;padding:3rem 1.5rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">666 in career &amp; money</h2>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        If 666 keeps showing up around financial or career thoughts, the message is direct: you're giving money and work too much power over your wellbeing. That doesn't mean quit your job or ignore your bank account. It means the anxiety is worse than the actual situation, and the anxiety itself is the problem 666 is asking you to address.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        The 6 is a practical number. It's not telling you to be irresponsible with money. It's telling you that worrying about money isn't the same as handling it. You can be financially responsible and emotionally relaxed about it at the same time. Those two things aren't in conflict.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        Career-wise, 666 often appears when your work-life balance has tipped too far toward work. Are you present when you're home, or is your brain still at the office? Are you working to live, or have you quietly started living to work? The 6 brings everything back to the domestic and relational: the parts of life that work is supposed to support, not replace.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0;">
        The 6 also connects to service-oriented careers. If 666 shows up and you've been feeling unfulfilled at work, it might be pointing you toward a role that involves more direct care for people: teaching, healing, counselling, community work. The 6 thrives when it's making a tangible difference in someone's day.
      </p>
    </div>
  </section>

  <!-- What to do section -->
  <section style="background:var(--color-light-bg);padding:3rem 1.5rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2" style="text-align:center;">What to do when you see 666</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
        <div style="background:white;border:1px solid var(--color-border);border-radius:12px;padding:1.25rem 1.5rem;">
          <div style="font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-soft-gold);margin-bottom:0.5rem;">Name the worry</div>
          <p style="font-size:0.9rem;color:var(--color-muted-text);line-height:1.7;margin:0;">What are you anxious about right now? Name it specifically. Once you see it clearly, it usually shrinks to a more manageable size.</p>
        </div>
        <div style="background:white;border:1px solid var(--color-border);border-radius:12px;padding:1.25rem 1.5rem;">
          <div style="font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-soft-gold);margin-bottom:0.5rem;">Check your balance</div>
          <p style="font-size:0.9rem;color:var(--color-muted-text);line-height:1.7;margin:0;">Where have you been giving too much? Where have you been neglecting? Redirect your energy toward whatever has been getting less than it deserves.</p>
        </div>
        <div style="background:white;border:1px solid var(--color-border);border-radius:12px;padding:1.25rem 1.5rem;">
          <div style="font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-soft-gold);margin-bottom:0.5rem;">Come home</div>
          <p style="font-size:0.9rem;color:var(--color-muted-text);line-height:1.7;margin:0;">Literally or figuratively. Reconnect with your space, your people, your body. The 6 grounds through domestic comfort and physical presence.</p>
        </div>
        <div style="background:white;border:1px solid var(--color-border);border-radius:12px;padding:1.25rem 1.5rem;">
          <div style="font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-soft-gold);margin-bottom:0.5rem;">Release control</div>
          <p style="font-size:0.9rem;color:var(--color-muted-text);line-height:1.7;margin:0;">Not everything needs to be managed. Not every problem is yours to solve. Let other people carry their own weight. Your job is to show up, not to orchestrate.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background:white;padding:3rem 1.5rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2" style="text-align:center;">Common questions about 666</h2>
      <div class="faq-list">
        {faqSchema.mainEntity.map(item => (
          <details>
            <summary>
              {item.name}
              <svg class="faq-chevron" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-answer">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

    </div>
    <SidebarCTA />
  </div>

  <!-- Other angel numbers -->
  <section style="background:var(--color-light-bg);padding:3rem 1.5rem;border-top:1px solid var(--color-border);">
    <div style="max-width:1100px;margin:0 auto;">

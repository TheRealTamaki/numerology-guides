---
import Layout from '../../../layouts/Layout.astro';
import SidebarCTA from '../../../components/SidebarCTA.astro';
import { birthdayNumbers } from '../../../data/birthdayNumbers';
---

<Layout
  title="Birthday Number in Numerology - The Energy of Your Birth Day"
  description="Your birthday number comes from the day you were born. It's one of the most personal numbers in your chart - a consistent background quality that shows up throughout your life. Find your day and explore what it means."
>

  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" />

  <style>
    :root { --font-family-heading: 'Cormorant Garamond', Georgia, serif; }
    .p-label { font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-soft-gold); font-weight:600; }
    .p-divider { width:48px; height:2px; background:var(--color-soft-gold); margin:0 auto; }
    .section-h2 { font-family:var(--font-family-heading); font-size:clamp(1.6rem,3.5vw,2.25rem); font-weight:700; color:var(--color-body-text); margin:0 0 1.25rem; }
  </style>

  <!-- Breadcrumb -->
  <nav style="background:var(--color-card-bg);border-bottom:1px solid var(--color-border);padding:0.75rem 1.5rem;" aria-label="Breadcrumb">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:0.5rem;font-size:0.75rem;color:var(--color-muted-text);">
      <a href="/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Home</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Learn</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <span style="color:var(--color-body-text);font-weight:600;">Birthday Numbers</span>
    </div>
  </nav>

  <!-- Hero -->
  <section style="position:relative;overflow:hidden;padding:6rem 1.5rem 5rem;background:#0e0a1a;min-height:440px;display:flex;align-items:center;">
    <div style="position:absolute;inset:0;z-index:0;">
      <img
        src="/images/learn/Birthday Numbers Pillar Hero.webp"
        alt="Birthday Numbers in Numerology"
        fetchpriority="high"
        style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
      />
      <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(14,10,26,0.72) 0%, rgba(14,10,26,0.52) 45%, rgba(14,10,26,0.80) 100%);"></div>
    </div>

    <!-- Ghost letters -->
    <div aria-hidden="true" style="position:absolute;left:-1%;top:50%;transform:translateY(-50%);z-index:1;font-family:var(--font-family-heading);font-size:clamp(12rem,24vw,20rem);font-weight:700;line-height:1;color:transparent;-webkit-text-stroke:1px rgba(196,162,78,0.15);user-select:none;pointer-events:none;">B</div>
    <div aria-hidden="true" style="position:absolute;right:-1%;top:50%;transform:translateY(-50%);z-index:1;font-family:var(--font-family-heading);font-size:clamp(12rem,24vw,20rem);font-weight:700;line-height:1;color:transparent;-webkit-text-stroke:1px rgba(196,162,78,0.15);user-select:none;pointer-events:none;">D</div>

    <div style="position:relative;z-index:2;max-width:860px;margin:0 auto;text-align:center;">
      <p class="p-label" style="margin-bottom:1rem;">Core Chart Numbers</p>
      <div class="p-divider" style="margin-bottom:1.5rem;"></div>
      <h1 style="font-family:var(--font-family-heading);font-size:clamp(2.4rem,6vw,4rem);font-weight:700;color:#f5f0e8;line-height:1.1;margin:0 0 1.25rem;text-shadow:0 2px 20px rgba(14,10,26,0.6);">
        Birthday Number in <em style="color:#c8a8f0;font-style:italic;">Numerology</em>
      </h1>
      <p style="font-size:clamp(1rem,2vw,1.2rem);color:rgba(240,234,255,0.82);max-width:620px;margin:0 auto 2rem;line-height:1.7;text-shadow:0 1px 8px rgba(14,10,26,0.5);">
        Your birthday number is simply the day of the month you were born. No calculation beyond the day itself — and what it tells you about how you naturally approach life.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:0.875rem;justify-content:center;">
        <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:1rem;padding:0.875rem 2rem;border-radius:6px;text-decoration:none;transition:background 0.2s,transform 0.15s;box-shadow:0 4px 20px rgba(124,92,191,0.45);" onmouseover="this.style.background='#6a4eab';this.style.transform='translateY(-1px)'" onmouseout="this.style.background='var(--color-violet)';this.style.transform='none'">Get My Free Reading →</a>
        <a href="#all-numbers" style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.08);backdrop-filter:blur(6px);color:#f5f0e8;font-weight:600;font-size:1rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.2);transition:border-color 0.2s,background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)';this.style.borderColor='rgba(255,255,255,0.4)'" onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.borderColor='rgba(255,255,255,0.2)'">Find your day ↓</a>
      </div>
    </div>
  </section>

  <!-- Author byline -->
  <div style="background:var(--color-card-bg);padding:1.75rem 1.5rem;border-bottom:1px solid var(--color-border);">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:1rem;">
      <img src="/images/author-maddi-green.webp" alt="Maddie Greene" style="width:3.25rem;height:3.25rem;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid var(--color-border);" />
      <div>
        <p style="margin:0;font-size:0.95rem;font-weight:600;color:var(--color-body-text);">Written by <strong>Maddie Greene</strong></p>
        <p style="margin:0;font-size:0.8rem;color:var(--color-muted-text);">Numerology writer &amp; researcher</p>
      </div>
    </div>
  </div>

  <!-- Content + Sticky sidebar wrapper -->
  <div class="xl:flex xl:gap-6 xl:max-w-[1200px] xl:mx-auto xl:px-4">
    <!-- Main content column -->
    <div class="xl:flex-1 xl:min-w-0">

  <!-- What is the birthday number -->
  <section id="what-is" style="padding:3.5rem 1.5rem;background:var(--color-light-bg);">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">What is the birthday number?</h2>
      <p style="color:var(--color-body-text);line-height:1.8;margin:0 0 1rem;">
        The birthday number is the most straightforward number in your numerology chart. It's just the day of the month you were born — no name, no full birth date, just the day. If you were born on the 7th, your birthday number is 7. If you were born on the 25th, you add 2+5 to get 7. Same number, slightly different texture.
      </p>
      <p style="color:var(--color-body-text);line-height:1.8;margin:0 0 1rem;">
        In the overall chart, the birthday number is considered a secondary influence — smaller in scope than the life path number, but notably personal. It describes a consistent background quality that shows up in how you naturally approach tasks and challenges. Not a defining theme, but a reliable thread.
      </p>
      <p style="color:var(--color-body-text);line-height:1.8;margin:0;">
        Some numerologists call it the gift number, because it often points to something you do naturally and early — a quality that's just there before you've had to work at much of anything. That's not a guarantee of ease, but it is a pointer toward where your instincts tend to be reliable.
      </p>
    </div>
  </section>

  <!-- How to find your birthday number -->
  <section id="calculate" style="padding:3.5rem 1.5rem;background:var(--color-card-bg);">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">How to find your birthday number</h2>
      <p style="color:var(--color-body-text);line-height:1.8;margin:0 0 1.75rem;">
        Take the day of the month you were born. If it's a single digit (1–9), that's your birthday number. If it's a two-digit number, add the digits together and reduce to one — unless you land on 11 or 22, which are master numbers and stay as they are.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem;margin-bottom:1.5rem;">
        <div style="background:var(--color-light-bg);border:1.5px solid var(--color-violet);border-left-width:4px;border-radius:8px;padding:1.25rem;">
          <div style="font-weight:700;color:var(--color-body-text);margin-bottom:0.75rem;font-size:0.95rem;">Single digit days</div>
          <div style="display:flex;flex-direction:column;gap:0.3rem;font-size:0.875rem;color:var(--color-muted-text);">
            <p style="margin:0;">Born on the <span style="color:var(--color-violet);font-weight:600;">5th</span> → Birthday number <span style="color:var(--color-violet);font-weight:600;">5</span></p>
            <p style="margin:0;">Born on the <span style="color:var(--color-violet);font-weight:600;">9th</span> → Birthday number <span style="color:var(--color-violet);font-weight:600;">9</span></p>
          </div>
        </div>
        <div style="background:var(--color-light-bg);border:1.5px solid var(--color-violet);border-left-width:4px;border-radius:8px;padding:1.25rem;">
          <div style="font-weight:700;color:var(--color-body-text);margin-bottom:0.75rem;font-size:0.95rem;">Double digit days</div>
          <div style="display:flex;flex-direction:column;gap:0.3rem;font-size:0.875rem;color:var(--color-muted-text);">
            <p style="margin:0;">Born on the <span style="color:var(--color-violet);font-weight:600;">17th</span>: 1+7=8 → Birthday number <span style="color:var(--color-violet);font-weight:600;">8</span></p>
            <p style="margin:0;">Born on the <span style="color:var(--color-violet);font-weight:600;">29th</span>: 2+9=11 → Birthday number <span style="color:var(--color-violet);font-weight:600;">11</span> (master)</p>
          </div>
        </div>
      </div>
      <div style="background:var(--color-light-bg);border:1px solid var(--color-border);border-radius:8px;padding:1.1rem 1.25rem;">
        <p style="margin:0;font-size:0.875rem;color:var(--color-body-text);"><span style="font-weight:600;">Master numbers:</span> Days 11 and 22 are master numbers — they carry a higher-intensity version of their base energy (2 and 4 respectively) and are not reduced. Day 29 also produces a master number (2+9=11).</p>
      </div>
    </div>
  </section>

  <!-- Birthday number vs life path number -->
  <section id="vs-life-path" style="padding:3.5rem 1.5rem;background:var(--color-light-bg);">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">Birthday number vs life path number</h2>
      <p style="color:var(--color-body-text);line-height:1.8;margin:0 0 1rem;">
        Your life path number is the primary number in numerology — it comes from your full birth date (day, month, and year) and describes the overarching terrain of your life. Your birthday number is more focused: it describes a specific quality or gift that's consistently available to you, regardless of which life path you're on.
      </p>
      <p style="color:var(--color-body-text);line-height:1.8;margin:0 0 1rem;">
        Think of the life path as the long road and the birthday number as something you're consistently carrying with you on it. If your life path is about building stability and your birthday number carries creative expressiveness, you're a builder who tends to bring something genuinely original to the structure.
      </p>
      <p style="color:var(--color-body-text);line-height:1.8;margin:0 0 1.75rem;">
        The birthday number also interacts with your expression number and soul urge — the full picture requires all of them. A free reading from Numerologist.com calculates your complete chart and shows how these numbers work together.
      </p>
      <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-block;padding:0.75rem 1.75rem;background:var(--color-soft-gold);color:#1a1200;border-radius:6px;font-size:0.95rem;font-weight:700;text-decoration:none;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.88'" onmouseout="this.style.opacity='1'">Get Your Free Reading</a>
    </div>
  </section>

    </div><!-- end main content column -->
    <SidebarCTA />
  </div><!-- end flex wrapper -->

  <!-- All birthday numbers grid -->
  <section id="all-numbers" style="padding:4rem 1.5rem;background:var(--color-card-bg);">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <p class="p-label" style="margin-bottom:0.75rem;">All Birthday Numbers</p>
        <div class="p-divider" style="margin-bottom:1.25rem;"></div>
        <h2 style="font-family:var(--font-family-heading);font-size:clamp(1.8rem,4vw,2.5rem);font-weight:700;color:var(--color-body-text);margin:0 0 0.75rem;">Find Your Birthday Number</h2>
        <p style="color:var(--color-muted-text);max-width:520px;margin:0 auto;line-height:1.7;font-size:0.95rem;">Select the day of the month you were born to explore what your birthday number says about your natural approach to life.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1.1rem;">
        {birthdayNumbers.map(bn => {
          const topStrength = bn.strengths[0]?.title ?? '';
          const isMaster = bn.reducedTo === null && bn.day > 9;
          return (
            <a href={`/learn/birthday-number/${bn.day}/`} style="display:block;text-decoration:none;border-radius:10px;overflow:hidden;border:1.5px solid var(--color-border);background:var(--color-light-bg);transition:all 0.2s;" onmouseover="this.style.borderColor='var(--color-violet)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='var(--color-border)';this.style.transform='translateY(0)'">
              <div style="position:relative;aspect-ratio:2/3;overflow:hidden;">
                <img src={`/images/learn/birthday-numbers/Birthday Number - ${bn.day}.webp`} alt={`Birthday Number ${bn.day}`} style="width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.5s;" loading="lazy" />
                <div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);"></div>
                <div style="position:absolute;bottom:0.5rem;left:0.75rem;display:flex;align-items:center;gap:0.5rem;">
                  <span style="font-family:var(--font-family-heading);font-size:1.6rem;font-weight:700;color:#fff;text-shadow:2px 2px 0 rgba(0,0,0,0.5);">{bn.day}</span>
                  {isMaster && <span style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;padding:0.2rem 0.5rem;background:var(--color-soft-gold);color:#1a1200;border-radius:4px;">Master</span>}
                </div>
              </div>
              <div style="padding:0.85rem 1rem 0.75rem;">
                <div style="font-weight:600;font-size:0.875rem;color:var(--color-body-text);margin-bottom:0.3rem;line-height:1.3;">{bn.title}</div>
                {topStrength && (
                  <div style="display:flex;gap:0.4rem;font-size:0.75rem;">
                    <span style="color:#4ade80;font-weight:600;flex-shrink:0;">Gift:</span>
                    <span style="color:var(--color-muted-text);">{topStrength}</span>
                  </div>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Related guides -->
  <section style="padding:3.5rem 1.5rem;background:var(--color-light-bg);border-top:1px solid var(--color-border);">
    <div style="max-width:1100px;margin:0 auto;">
      <h2 class="section-h2">Related guides</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1.25rem;">
        <a href="/learn/life-path-number/" class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block">
          <img src="/images/learn/Life Path Numbers - Tile.webp" alt="Life Path Numbers guide" class="w-full aspect-[2/3] object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          <div class="p-4">
            <h3 class="font-bold text-body-text group-hover:text-violet transition-colors mb-1">Life Path Numbers</h3>
            <p class="text-xs text-muted-text">The most important number in your chart — from your full birth date.</p>
          </div>
        </a>
        <a href="/learn/expression-number/" class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block">
          <img src="/images/learn/Expression Numbers - Tile.webp" alt="Expression Numbers guide" class="w-full aspect-[2/3] object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          <div class="p-4">
            <h3 class="font-bold text-body-text group-hover:text-violet transition-colors mb-1">Expression Numbers</h3>
            <p class="text-xs text-muted-text">Your destiny direction — from your full birth name.</p>
          </div>
        </a>
        <a href="/learn/soul-urge-number/" class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block">
          <img src="/images/learn/Soul Urge Numbers - Tile.webp" alt="Soul Urge Numbers guide" class="w-full aspect-[2/3] object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          <div class="p-4">
            <h3 class="font-bold text-body-text group-hover:text-violet transition-colors mb-1">Soul Urge Numbers</h3>
            <p class="text-xs text-muted-text">Your deepest inner motivation — from the vowels in your name.</p>
          </div>
        </a>
        <a href="/learn/personality-number/" class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block">
          <img src="/images/learn/Personality Numbers - Tile.webp" alt="Personality Numbers guide" class="w-full aspect-[2/3] object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          <div class="p-4">
            <h3 class="font-bold text-body-text group-hover:text-violet transition-colors mb-1">Personality Numbers</h3>
            <p class="text-xs text-muted-text">The impression you make on others — from the consonants in your name.</p>
          </div>
        </a>
        <a href="/learn/personal-year-number/" class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block">
          <img src="/images/learn/Personal Year Numbers - Tile.webp" alt="Personal Year Numbers guide" class="w-full aspect-[2/3] object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          <div class="p-4">
            <h3 class="font-bold text-body-text group-hover:text-violet transition-colors mb-1">Personal Year Numbers</h3>
            <p class="text-xs text-muted-text">The energy theme shaping your current year — changes annually.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section style="padding:5rem 1.5rem;background:#0e0a1a;text-align:center;">
    <div style="max-width:640px;margin:0 auto;">
      <p class="p-label" style="margin-bottom:1rem;">Go Deeper</p>
      <div class="p-divider" style="margin-bottom:1.5rem;"></div>
      <h2 style="font-family:var(--font-family-heading);font-size:clamp(1.8rem,4vw,2.5rem);font-weight:700;color:#fff;margin:0 0 1.25rem;line-height:1.2;">See how all your numbers fit together</h2>
      <p style="color:rgba(240,235,255,0.65);line-height:1.8;margin:0 0 2rem;">
        Your birthday number is one piece of the chart — but its meaning deepens when you see it alongside your life path, expression, and soul urge. A free reading from Numerologist.com brings the full picture together.
      </p>
      <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-block;padding:0.9rem 2.25rem;background:var(--color-soft-gold);color:#1a1200;border-radius:6px;font-size:1.05rem;font-weight:700;text-decoration:none;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.88'" onmouseout="this.style.opacity='1'">Get Your Free Numerology Reading</a>
    </div>
  </section>

</Layout>

---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  schema?: object | object[];
}

const SITE = 'https://numerologyguides.blog';

const {
  title = "Numerology Guides - Learn What Your Numbers Mean",
  description = "Free numerology guides covering life path numbers, angel numbers, compatibility, and more. Understand your numbers and get a free personalized reading.",
  schema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE).href;

// Normalise schema to an array so pages can pass one object or many
const schemaItems = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {schemaItems.map(s => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

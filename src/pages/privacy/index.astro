---
import Layout from '../../layouts/Layout.astro';
import SidebarCTA from '../../components/SidebarCTA.astro';
---

<link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" />
<style>
  :root { --font-family-heading: 'Cormorant Garamond', Georgia, serif; }
</style>

<Layout
  title="Privacy Policy - Numerology Guides"
  description="How Numerology Guides handles your data, cookies, and third-party services. Short version: we collect very little and sell nothing."
>
  <section style="background:var(--color-light-bg);padding:4rem 1.5rem 3.5rem;position:relative;overflow:hidden;border-bottom:1px solid var(--color-border);">
    <div style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(124,92,191,0.07) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;"></div>
    <div style="position:relative;z-index:1;max-width:760px;margin:0 auto;text-align:center;">
      <h1 style="font-family:var(--font-family-heading);font-size:clamp(2rem,5vw,3rem);font-weight:700;color:var(--color-body-text);margin:0 0 0.75rem;">
        Privacy <span style="color:var(--color-soft-gold);">Policy</span>
      </h1>
      <p style="color:var(--color-muted-text);font-size:0.875rem;margin:0;">Last updated: March 2026</p>
    </div>
  </section>

  <!-- Content + Sticky sidebar wrapper -->
  <div class="xl:flex xl:gap-6 xl:max-w-[1200px] xl:mx-auto xl:px-4">
    <!-- Main content column -->
    <div class="xl:flex-1 xl:min-w-0">

  <section style="padding:2.5rem 1rem;background:white;">
    <div class="max-w-2xl mx-auto xl:mx-0 xl:max-w-none space-y-5">

      <div class="card-light p-6 md:p-8">
        <h2 class="text-lg font-bold font-[family-name:var(--font-family-heading)] text-body-text mb-3">
          <span class="text-violet mr-2">⬥</span> The short version
        </h2>
        <p class="text-muted-text leading-relaxed text-sm">
          Numerology Guides is a free educational site. We don't require accounts, we don't ask for your name or email, and we don't sell data to anyone. The calculator and wizard tools on this site run entirely in your browser - nothing you enter is sent to a server.
        </p>
      </div>

      <div class="card-light p-6 md:p-8">
        <h2 class="text-lg font-bold font-[family-name:var(--font-family-heading)] text-body-text mb-3">
          <span class="text-violet mr-2">⬥</span> What we collect
        </h2>
        <p class="text-muted-text leading-relaxed text-sm mb-3">
          <strong class="text-body-text">Analytics:</strong> We may use privacy-focused analytics to understand how many people visit the site and which pages are most useful. This data is aggregated and anonymous - we can't identify individual visitors from it.
        </p>
        <p class="text-muted-text leading-relaxed text-sm">
          <strong class="text-body-text">No personal data:</strong> We don't collect your name, email address, birth date, or any information you enter into the calculator or wizard. Those calculations happen locally in your browser and are never transmitted anywhere.
        </p>
      </div>

      <div class="card-light p-6 md:p-8">
        <h2 class="text-lg font-bold font-[family-name:var(--font-family-heading)] text-body-text mb-3">
          <span class="text-violet mr-2">⬥</span> Cookies
        </h2>
        <p class="text-muted-text leading-relaxed text-sm">
          This site uses minimal cookies necessary for basic functionality. If you click an affiliate link to Numerologist.com or other third-party sites, those sites may set their own cookies according to their own privacy policies. We don't control those cookies and recommend reviewing the privacy policy of any site you visit through our links.
        </p>
      </div>

      <div class="card-light p-6 md:p-8">
        <h2 class="text-lg font-bold font-[family-name:var(--font-family-heading)] text-body-text mb-3">
          <span class="text-violet mr-2">⬥</span> Affiliate links
        </h2>
        <p class="text-muted-text leading-relaxed text-sm">
          Some links on this site are affiliate links to Numerologist.com, operated through the ClickBank network. When you click these links, ClickBank may use cookies to track the referral. This is standard affiliate tracking and is covered by ClickBank's own privacy policy. For more details on our affiliate relationship, see our <a href="/disclaimer/" class="text-violet hover:underline font-medium">Affiliate Disclaimer</a>.
        </p>
      </div>

      <div class="card-light p-6 md:p-8">
        <h2 class="text-lg font-bold font-[family-name:var(--font-family-heading)] text-body-text mb-3">
          <span class="text-violet mr-2">⬥</span> Third-party services
        </h2>
        <p class="text-muted-text leading-relaxed text-sm">
          This site is hosted on static infrastructure and does not use third-party login providers, advertising networks, or data brokers. The only external service we link to is Numerologist.com. If you visit that site, their privacy policy applies from the moment you land there.
        </p>
      </div>

      <div class="card-light p-6 md:p-8">
        <h2 class="text-lg font-bold font-[family-name:var(--font-family-heading)] text-body-text mb-3">
          <span class="text-violet mr-2">⬥</span> Your rights
        </h2>
        <p class="text-muted-text leading-relaxed text-sm mb-3">
          Since we don't collect personal data, there's very little to request access to or ask us to delete. But if you have any questions or concerns about how this site handles data, you're welcome to contact us.
        </p>
        <p class="text-muted-text leading-relaxed text-sm">
          If you're in the EU, UK, or California, your local data protection laws still apply. We don't believe we hold any data covered by GDPR, UK GDPR, or CCPA - but if you think otherwise, get in touch and we'll sort it out.
        </p>
      </div>

      <div class="card-light p-6 md:p-8">
        <h2 class="text-lg font-bold font-[family-name:var(--font-family-heading)] text-body-text mb-3">
          <span class="text-violet mr-2">⬥</span> Contact
        </h2>
        <p class="text-muted-text leading-relaxed text-sm">
          Questions about this policy? Email us at
          <a href="mailto:hello@numerologyguides.blog" class="text-violet hover:underline font-medium">hello@numerologyguides.blog</a>.
        </p>
      </div>

    </div>
  </section>

    </div><!-- end main content column -->
    <SidebarCTA />
  </div><!-- end flex wrapper -->
</Layout>

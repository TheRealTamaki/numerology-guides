---
import Layout from '../../../layouts/Layout.astro';
import SidebarCTA from '../../../components/SidebarCTA.astro';

const compatibility = [
 { lp: "1", label: "The Leader", score: 4, verdict: "LP1's independent drive and LP22's large-scale vision can create a formidable combination. LP1 leads at the personal level; LP22 builds the structure around it. Requires LP1 to operate within LP22's longer-term framework." },
 { lp: "2", label: "The Peacemaker", score: 4, verdict: "LP22 carries LP2's sensitivity at a higher frequency. LP2 understands LP22's inner world intuitively. LP2's relational depth grounds LP22's scale; LP22 gives LP2's care a larger vehicle." },
 { lp: "4", label: "The Builder", score: 5, verdict: "Natural resonance - LP22 is LP4's energy amplified and directed at larger scale. LP4 understands the discipline and structural thinking LP22 needs. A reliable, productive pairing when vision and execution are shared." },
 { lp: "6", label: "The Nurturer", score: 4, verdict: "LP6 builds the warmth and home that sustains LP22 through their demanding work. LP22 provides the scale and capability that gives LP6's care a broader reach. Genuinely complementary when both feel valued." },
 { lp: "8", label: "The Powerhouse", score: 5, verdict: "Two power builders. LP8's material ambition and LP22's visionary scale can construct something historic together. The risk is both prioritizing the work over the relationship - someone has to tend to the connection." },
 { lp: "9", label: "The Humanitarian", score: 4, verdict: "LP9's wisdom and sense of service give LP22's large-scale work a purpose that goes beyond achievement. LP22 gives LP9's values a real-world vehicle. Often a deeply meaningful partnership." },
 { lp: "11", label: "The Intuitive", score: 4, verdict: "LP11's spiritual insight feeds LP22's intuition about what's worth building; LP22's practical capacity gives LP11's vision somewhere to land. Two master numbers that can bring out the best in each other." },
 { lp: "22", label: "The Architect", score: 3, verdict: "Two LP22s can either build empires together or compete for primacy. Mutual respect, clear domains, and genuine recognition of each other's scale are essential." },
 { lp: "33", label: "The Teacher", score: 5, verdict: "LP22 builds; LP33 heals and teaches. Together, the infrastructure and the heart of a movement. Among the most potentially transformative pairings in all of numerology, when both are fully developed." },
];

const strengths = [
 { title: "Vision at large scale", desc: "LP22 can hold an extraordinarily large and complex picture-not just a business or career but an institution, a movement, a system that changes how people live. It's a genuine perception of what's possible and what's needed, not ambition for its own sake. What LP22 builds tends to outlast them." },
 { title: "Practical idealism", desc: "LP22 combines an elevated vision with grounded concrete steps to realize it. Most people can do one or the other. LP22 can do both simultaneously. That's why they're capable of things other visionaries only dream about." },
 { title: "Stable leadership", desc: "LP22 leads through demonstrated competence and commitment to something larger than themselves, not charisma alone. People follow because they sense LP22 is building something real and they want in." },
 { title: "Disciplined execution", desc: "LP22 combines LP4's structural instincts with a larger purpose, producing sustained, disciplined effort toward goals that take decades to realize. Not interested in quick wins. Interested in what actually lasts." },
];

const challenges = [
 { title: "The weight of potential", desc: "LP22 carries a persistent awareness of what they're capable of and a persistent gap between that and where they are. This awareness motivates. It also produces a chronic low-level dissatisfaction because no achievement quite closes the gap." },
 { title: "Reverting to LP4", desc: "When LP22's demands feel overwhelming, they retreat into LP4 mode: practical, competent, but below their actual level. This retreat can persist for years and is one of the most common ways LP22 underperforms." },
 { title: "Relational neglect", desc: "LP22 builds at a level that requires enormous energy. Relationships that sustain them can quietly become underfunded. The 22 who protects the inner life does better in every way." },
 { title: "Accepting limitation", desc: "LP22 operates with awareness of what's possible, which makes current limitations feel wrong. Working within real constraints rather than against them is some of their most important learning." },
];

const famousLP22s = [
 { name: "Paul McCartney", why: "A career that reshaped popular music globally and then kept building across decades - not just as a performer but as a cultural architect. LP22's ability to sustain and evolve over time, at civilizational scale, is precisely the McCartney story." },
 { name: "The Dalai Lama", why: "A life devoted to building something that transcends institutions: a model of compassionate leadership that operates as a global reference point. LP22's practical idealism - wisdom expressed through sustained, tangible action over a lifetime." },
 { name: "Will Smith", why: "Built one of the most durable entertainment empires of his generation through disciplined, large-scale thinking that went well beyond performance. LP22's combination of vision and execution across film, music, and production." },
 { name: "Richard Branson", why: "A serial builder of ventures that collectively transformed entire industries, aviation, telecommunications, space, through LP22's willingness to hold large ambitions and pursue them systematically across time." },
 { name: "Dean Martin", why: "Built and sustained a career that operated across multiple mediums simultaneously, music, film, television, Las Vegas, with the kind of practical, enduring appeal that is distinctly LP22's mode of operating in the world." },
 { name: "Tina Fey", why: "A writer, actor, and producer who built new institutions within comedy and television, transforming SNL, creating 30 Rock, and establishing herself as one of the definitive shapers of American humor. LP22's large-scale building through craft and vision." },
];

const allLifePaths = [
 { n: "1", name: "The Leader" },
 { n: "2", name: "The Peacemaker" },
 { n: "3", name: "The Communicator" },
 { n: "4", name: "The Builder" },
 { n: "5", name: "The Adventurer" },
 { n: "6", name: "The Nurturer" },
 { n: "7", name: "The Seeker" },
 { n: "8", name: "The Powerhouse" },
 { n: "9", name: "The Humanitarian" },
 { n: "11", name: "The Intuitive" },
 { n: "22", name: "The Architect" },
 { n: "33", name: "The Teacher" },
];

const faqSchema = {
 "@context": "https://schema.org",
 "@type": "FAQPage",
 "mainEntity": [
 { "@type": "Question", "name": "What does life path 22 mean?", "acceptedAnswer": { "@type": "Answer", "text": "Life path 22 is the Master Builder - the most materially powerful of numerology's master numbers. It describes a life with the potential to build something at civilizational scale: an institution, a movement, a system, an art form, an organization that changes how many people live. LP22 combines LP11's spiritual sensitivity with LP4's disciplined practicality, and directs both toward a vision that is larger than a single career or a single lifetime." } },
 { "@type": "Question", "name": "Is life path 22 the most powerful number?", "acceptedAnswer": { "@type": "Answer", "text": "LP22 is often described as the most powerful life path number in terms of material manifestation potential. LP11 has extraordinary spiritual and intuitive gifts; LP33 carries the deepest compassion and teaching capacity; LP9 operates with universal wisdom. LP22's particular power is the ability to turn large visions into lasting physical reality - which is, in purely material terms, an unusual capability. Whether it's the 'most powerful' depends on what kind of power you mean." } },
 { "@type": "Question", "name": "What is the difference between life path 22 and life path 4?", "acceptedAnswer": { "@type": "Answer", "text": "LP4 and LP22 share a base energy (2+2=4) and both are builders. LP4 builds at the personal and organizational scale: businesses, careers, families, systems within existing structures. LP22 builds at a larger scale - institutions, movements, transformations of whole industries or communities. LP4's work is excellent and enduring; LP22's work aims to be historic. Many LP22s operate as LP4s for a significant part of their lives, until the larger vision becomes something they can no longer defer." } },
 { "@type": "Question", "name": "What careers suit life path 22?", "acceptedAnswer": { "@type": "Answer", "text": "Large-scale organizational leadership, institutional transformation, global nonprofit work, architecture at civilizational scale, social entrepreneurship, and any domain where building something that lasts for generations is the goal. LP22 needs genuine scope: work that draws on the full range of their structural intelligence and large-horizon thinking. The frustration of working below that level is real and persistent, and worth taking seriously as a signal." } },
 { "@type": "Question", "name": "What is the shadow side of life path 22?", "acceptedAnswer": { "@type": "Answer", "text": "The most common shadow is reverting to ordinary LP4 mode, staying safe, practical, and below the level the 22 is actually capable of, because the demands of the full 22 potential feel too heavy. The second shadow is neglecting the inner life and close relationships in service of the large-scale work. LP22 who builds the world while losing the people who matter to them tends to arrive at something that looks like success and feels like failure." } },
 { "@type": "Question", "name": "How rare is life path 22?", "acceptedAnswer": { "@type": "Answer", "text": "Master numbers are less common than single-digit life paths by sheer probability. LP22 is rare, and the fully developed LP22, someone actually operating at the level the number implies, is rarer still. Many LP22s spend significant portions of their lives as LP4s, which is not a failure; it's a natural developmental arc. The 22's larger work often becomes clear only in retrospect, after the foundations have been quietly laid." } }
 ]
};

const breadcrumbSchema = {
 "@context": "https://schema.org",
 "@type": "BreadcrumbList",
 "itemListElement": [
 { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://numerologyguides.blog/" },
 { "@type": "ListItem", "position": 2, "name": "Learn", "item": "https://numerologyguides.blog/learn/" },
 { "@type": "ListItem", "position": 3, "name": "Life Path Numbers", "item": "https://numerologyguides.blog/learn/life-path-number/" },
 { "@type": "ListItem", "position": 4, "name": "Life Path 22" }
 ]
};
---

<Layout
 schema={[faqSchema, breadcrumbSchema]}
 title="Life Path Number 22: The Master Builder - Traits, Careers & Compatibility | Numerology Guides"
 description="Life path 22 is numerology's second master number - the Master Builder. Rare, powerful, and called to build at civilizational scale. Explore LP22 traits, compatibility, career, and more."
>

 <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" />

 <style>
   :root { --font-family-heading: 'Cormorant Garamond', Georgia, serif; }
   .p-label { font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-soft-gold); font-weight:600; }
   .p-divider { width:48px; height:2px; background:var(--color-soft-gold); margin:0 auto; }
   .section-h2 { font-family:var(--font-family-heading); font-size:clamp(1.6rem,3.5vw,2.25rem); font-weight:700; color:var(--color-body-text); margin:0 0 1.25rem; }
   .faq-list details { border-top:1px solid var(--color-border); }
   .faq-list details:last-child { border-bottom:1px solid var(--color-border); }
   .faq-list summary { padding:1.3rem 0; cursor:pointer; display:flex; align-items:center; justify-content:space-between; gap:1rem; font-weight:600; font-size:1rem; color:var(--color-body-text); list-style:none; transition:color 0.2s; }
   .faq-list summary::-webkit-details-marker { display:none; }
   .faq-list details[open] summary { color:var(--color-violet); }
   .faq-chevron { flex-shrink:0; transition:transform 0.25s; }
   .faq-list details[open] .faq-chevron { transform:rotate(180deg); }
   .faq-answer { padding-bottom:1.3rem; font-size:0.9rem; color:var(--color-muted-text); line-height:1.8; }
   .lp-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:0.75rem; }
   @media (max-width:640px) { .lp-grid { grid-template-columns:repeat(3,1fr); } }
   .feat-card { display:block; background:white; border:1px solid var(--color-border); border-radius:8px; overflow:hidden; text-decoration:none; transition:box-shadow 0.25s, transform 0.25s; }
   .feat-card:hover { box-shadow:0 12px 40px rgba(26,21,40,0.1); transform:translateY(-3px); }
   .feat-img-wrap { overflow:hidden; }
   .feat-card img { width:100%; aspect-ratio:2/3; object-fit:cover; transition:transform 0.5s; }
   .feat-card:hover img { transform:scale(1.05); }
 </style>

 <!-- Breadcrumb -->
 <nav style="background:var(--color-card-bg);border-bottom:1px solid var(--color-border);padding:0.75rem 1.5rem;" aria-label="Breadcrumb">
   <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:0.5rem;font-size:0.75rem;color:var(--color-muted-text);">
     <a href="/" style="color:var(--color-muted-text);text-decoration:none;">Home</a>
     <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
     <a href="/learn/" style="color:var(--color-muted-text);text-decoration:none;">Learn</a>
     <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
     <a href="/learn/life-path-number/" style="color:var(--color-muted-text);text-decoration:none;">Life Path Numbers</a>
     <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
     <span style="color:var(--color-body-text);font-weight:600;">Life Path 22</span>
   </div>
 </nav>

 <!-- Hero -->
 <section style="position:relative;overflow:hidden;background:var(--color-midnight,#0e0a1a);">
   <div aria-hidden="true" style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(196,162,78,0.07) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>
   <div aria-hidden="true" style="position:absolute;top:-10%;left:-5%;width:55%;height:120%;background:radial-gradient(ellipse at center,rgba(124,92,191,0.18) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>
   <div style="position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:4rem 1.5rem;display:flex;align-items:center;gap:3rem;flex-wrap:wrap;">
     <div style="flex:1;min-width:280px;">
       <p class="p-label" style="margin-bottom:1.1rem;color:var(--color-soft-gold);opacity:0.9;">Master Number 22</p>
       <div class="p-divider" style="margin:0 0 1.6rem;"></div>
       <h1 style="font-family:var(--font-family-heading);font-size:clamp(2.8rem,6vw,5rem);font-weight:700;line-height:1.06;color:#f5f0e8;letter-spacing:-0.02em;margin:0 0 1.25rem;">
         The <em style="color:#c8a8f0;font-style:italic;">Master Builder</em>
       </h1>
       <p style="font-size:1.05rem;line-height:1.8;color:rgba(240,234,255,0.78);max-width:460px;margin:0 0 2rem;">Life path 22 is numerology's most powerful building force - the second master number, and the one most associated with turning extraordinary visions into lasting physical reality. The 22 operates at the scale that changes how the world works.</p>
       <div style="display:flex;flex-wrap:wrap;gap:0.875rem;">
         <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:1rem;padding:0.875rem 2rem;border-radius:6px;text-decoration:none;transition:background 0.2s,transform 0.15s;box-shadow:0 4px 20px rgba(124,92,191,0.45);" onmouseover="this.style.background='#6a4eab';this.style.transform='translateY(-1px)'" onmouseout="this.style.background='var(--color-violet)';this.style.transform='none'">Get My Free Reading →</a>
         <a href="#career" style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.08);backdrop-filter:blur(6px);color:#f5f0e8;font-weight:600;font-size:1rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.2);transition:border-color 0.2s,background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)';this.style.borderColor='rgba(255,255,255,0.4)'" onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.borderColor='rgba(255,255,255,0.2)'">See LP22 Career Paths ↓</a>
       </div>
     </div>
     <div style="flex-shrink:0;width:clamp(200px,28vw,300px);filter:drop-shadow(0 8px 40px rgba(196,162,78,0.25)) drop-shadow(0 2px 12px rgba(0,0,0,0.6));">
       <img src="/images/learn/Master Number 22 - The Master Builder.webp" alt="Life Path 22 — The Master Builder tarot card" fetchpriority="high" style="width:100%;border-radius:6px;display:block;" />
     </div>
   </div>
 </section>

  <!-- Author byline -->
  <div style="background:var(--color-light-bg);padding:1.25rem 1.5rem;">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:1rem;">
      <img src="/images/author-maddi-green.webp" alt="Maddie Greene" style="width:2.75rem;height:2.75rem;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid rgba(124,92,191,0.2);" />
      <div>
        <p style="color:var(--color-body-text);font-size:0.875rem;font-weight:600;margin:0 0 0.1rem;">Written by <strong>Maddie Greene</strong></p>
        <p style="color:var(--color-muted-text);font-size:0.78rem;margin:0;">Numerology writer &amp; researcher</p>
      </div>
    </div>
  </div>

  <!-- Content + Sticky sidebar wrapper -->
  <div class="xl:flex xl:gap-6 xl:max-w-[1200px] xl:mx-auto xl:px-4">
    <!-- Main content column -->
    <div class="xl:flex-1 xl:min-w-0">

 <article style="padding:2rem 1.5rem 3rem;background:var(--color-card-bg);">
 <div class="max-w-3xl mx-auto xl:mx-0 xl:max-w-none">

 <!-- What does LP22 mean -->
 <section class="mb-10">
 <div class="max-w-3xl mx-auto">
 <h2 class="section-h2">
 What does life path number 22 mean?
 </h2>
 <div class="space-y-4 text-muted-text leading-relaxed">
 <p>
 Life path 22 is the Master Builder-the second and most materially powerful master number. Where LP11 is primarily spiritual, LP22 channels that awareness into the world: institutions, organizations, systems, and structures that outlast any individual life.
 </p>
 <p>
 LP22 combines LP11's sensitivity with LP4's discipline and operates at a scale that goes beyond either. They don't just build a career. They build something that changes how an industry functions, how a community organizes, or how an art form expresses what was previously inexpressible.
 </p>
 <p>
 The core challenge for LP22 is the gap between their potential and present reality. They carry a persistent awareness of what they're capable of and how far they are from it. Learning to work within time and real constraints is the most important practical wisdom they can develop.
 </p>
 <div class="card-light p-5 mt-6">
 <p class="text-sm text-body-text"><span class="font-semibold">Note on master numbers:</span> LP22 also resonates with LP4 energy, since 2+2=4. Many LP22s operate closer to LP4 in early life and step into the full 22 expression gradually. If LP22 fully resonates, read this page. If you're uncertain, <a href="/learn/life-path-number-4/" class="text-violet hover:underline">the LP4 page</a> may add useful context.</p>
 </div>
 </div>
 </div>
 </section>

 <!-- Traits image + intro -->
 <section class="py-16 px-4">
 <div class="max-w-5xl mx-auto">
 <div class="grid md:grid-cols-2 gap-10 items-center">
 <div>
 <div class="mb-8 rounded-lg overflow-hidden border border-border/60 shadow-lg">
 <img
 src="/images/learn/Life Path Number 22 - Traits.webp"
 alt="Life Path 22 - The Master Builder personality traits"
 class="w-full h-64 object-cover"
 />
 </div>
 </div>
 <div>
 <h2 class="section-h2">
 Personality traits of life path 22s
 </h2>
 <p class="text-muted-text leading-relaxed mb-4">
 LP22 operates on a different time horizon. Where others think in weeks or years, LP22 thinks in decades. Their plans are larger and more detailed than expected because they've been quietly working this through for much longer.
 </p>
 <p class="text-muted-text leading-relaxed mb-4">
 LP22 has a composed authority that comes from structural intelligence and sense of purpose. They know why they're building what they build. That combination of practical skill and larger meaning pulls people in. People want to be part of what LP22 is constructing.
 </p>
 <p class="text-muted-text leading-relaxed">
 The inner life of LP22 is more complex than their exterior suggests. The awareness of their potential and the responsibility that comes with it feels like a permanent weight. LP22 who learns to carry that weight without being crushed by it is more effective than one still fighting that awareness.
 </p>
 </div>
 </div>
 </div>
 </section>

 <!-- Strengths and challenges -->
 <section style="margin-bottom:3rem;">
 <div class="max-w-5xl mx-auto">
 <h2 class="section-h2">Strengths &amp; challenges</h2>
 <div class="grid md:grid-cols-2 gap-6">
 <div>
 <h3 class="text-lg font-bold font-[family-name:var(--font-family-heading)] text-body-text mb-4 flex items-center gap-2">
 <span class="text-rpg-green text-xl">✦</span> Core Strengths
 </h3>
 <div class="space-y-4">
 {strengths.map(s => (
 <div class="card-light p-5">
 <div class="font-semibold text-body-text mb-1">{s.title}</div>
 <p class="text-sm text-muted-text leading-relaxed">{s.desc}</p>
 </div>
 ))}
 </div>
 </div>
 <div>
 <h3 class="text-lg font-bold font-[family-name:var(--font-family-heading)] text-body-text mb-4 flex items-center gap-2">
 <span class="text-rpg-red text-xl">✦</span> Key Challenges
 </h3>
 <div class="space-y-4">
 {challenges.map(c => (
 <div class="card-light p-5">
 <div class="font-semibold text-body-text mb-1">{c.title}</div>
 <p class="text-sm text-muted-text leading-relaxed">{c.desc}</p>
 </div>
 ))}
 </div>
 </div>
 </div>
 </div>
 </section>

 <!-- Love and relationships -->
 <section class="py-16 px-4">
 <div class="max-w-3xl mx-auto">
 <h2 class="section-h2">
 Life path 22 in love &amp; relationships
 </h2>
 <div class="space-y-4 text-muted-text leading-relaxed">
 <p>
 LP22 in love is deeply committed when they choose to be. When they build a relationship, they build it with the same care and long-term orientation they bring to everything else. The person who earns LP22's full investment tends to find it one of the most sustaining connections of their life.
 </p>
 <p>
 The challenge is bandwidth. The scale LP22 operates at can absorb enormous energy, leaving less than the relationship needs. It's not indifference. LP22 cares with real intensity. But the competition between work and relationship is real and ongoing.
 </p>
 <p>
 LP22 needs a partner who understands the scale of what they're building and finds meaning in it. Not because they have no needs, but because they share enough of LP22's vision to feel like participants. Partners who feel excluded tend to disconnect.
 </p>
 <p>
 The strongest matches for LP22 are LP4 (shares the building instinct and the structural intelligence, in a more personal register), LP8 (ambition, scale, and a shared understanding of what sustained effort actually looks like), and LP33 (complementary - the builder and the teacher creating something that serves at the deepest level). The LP11/LP22 pairing is also notable - the intuitive and the builder, when operating well, are remarkably complete together.
 </p>
 </div>
 </div>
 </section>

 <!-- Compatibility table -->
 <section id="compatibility" style="margin-bottom:3rem;">
 <div class="max-w-5xl mx-auto">
 <h2 class="section-h2">Life path 22 compatibility</h2>
 <p style="text-align:center;color:var(--color-muted-text);margin-bottom:2.5rem;max-width:680px;margin-left:auto;margin-right:auto;">
 How life path 22 pairs with key life path numbers - based on shared vision, complementary capabilities, and where things tend to become difficult.
 </p>
 <div class="overflow-x-auto">
 <table style="width:100%;font-size:0.875rem;border-collapse:collapse;border:1px solid var(--color-border);border-radius:8px;overflow:hidden;box-shadow:0 2px 12px rgba(26,21,40,0.07);">
 <thead style="background:rgba(124,92,191,0.08);">
 <tr>
 <th style="text-align:left;padding:1rem;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-muted-text);font-weight:600;">Life Path</th>
 <th style="text-align:left;padding:1rem;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-muted-text);font-weight:600;">Archetype</th>
 <th style="text-align:center;padding:1rem;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-muted-text);font-weight:600;">Match</th>
 <th style="text-align:left;padding:1rem;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-muted-text);font-weight:600;display:none;" class="md-show">Notes</th>
 </tr>
 </thead>
 <tbody>
 {compatibility.map(row => (
 <tr style="border-bottom:1px solid var(--color-border);">
 <td style="padding:1rem;font-weight:700;color:var(--color-violet);font-size:1rem;">{row.lp}</td>
 <td style="padding:1rem;color:var(--color-body-text);font-weight:500;white-space:nowrap;">{row.label}</td>
 <td style="padding:1rem;text-align:center;white-space:nowrap;">
 {Array.from({length: 5}).map((_, i) => (

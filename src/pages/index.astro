  <script>
  (function () {
    const lpTitles: Record<number, string> = {
      1:"The Leader", 2:"The Peacemaker", 3:"The Communicator",
      4:"The Builder", 5:"The Adventurer", 6:"The Nurturer",
      7:"The Seeker", 8:"The Powerhouse", 9:"The Humanitarian",
      11:"The Intuitive Master", 22:"The Master Builder", 33:"The Master Teacher"
    };

    function reduce(n: number): number {
      if (n < 10 || n === 11 || n === 22 || n === 33) return n;
      let s = 0;
      while (n > 0) { s += n % 10; n = Math.floor(n / 10); }
      return reduce(s);
    }

    function calcLP(str: string): number {
      const [y, m, d] = str.split('-').map(Number);
      const rm = reduce(m);
      const rd = reduce(d);
      const ry = reduce(String(y).split('').map(Number).reduce((a: number, b: number) => a + b, 0));
      return reduce(rm + rd + ry);
    }

    const dobEl    = document.getElementById('finder-dob') as HTMLInputElement;
    const btnEl    = document.getElementById('finder-btn') as HTMLButtonElement;
    const errEl    = document.getElementById('finder-error') as HTMLElement;
    const resEl    = document.getElementById('finder-result') as HTMLElement;
    const numEl    = document.getElementById('result-num') as HTMLElement;
    const titleEl  = document.getElementById('result-title') as HTMLElement;
    const linkEl   = document.getElementById('result-link') as HTMLAnchorElement;
    const restart  = document.getElementById('finder-restart') as HTMLButtonElement;

    btnEl.addEventListener('click', () => {
      errEl.style.display = 'none';
      if (!dobEl.value) {
        errEl.textContent = "Pop your birthday in above and we'll do the rest.";
        errEl.style.display = 'block';
        return;
      }
      const lp = calcLP(dobEl.value);
      numEl.textContent   = String(lp);
      titleEl.textContent = lpTitles[lp] ?? 'Unknown';
      linkEl.href         = `/learn/life-path-number-${lp}/`;
      linkEl.textContent  = `Read your Life Path ${lp} guide →`;
      resEl.style.display = 'block';
      resEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });

    dobEl.addEventListener('keypress', (e: KeyboardEvent) => { if (e.key === 'Enter') btnEl.click(); });

    restart.addEventListener('click', () => {
      dobEl.value = '';
      resEl.style.display = 'none';
    });
  })();
  </script>


---

<Layout
  title="Numerology Guides: Learn What Your Numbers Mean"
  description="Free guides to life path numbers, angel numbers, compatibility, and more. Learn numerology from scratch, then get a free personalized reading."
>

  <link
    slot="head"
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;0,6..96,600;1,6..96,400;1,6..96,500;1,6..96,600&family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap"
  />

  <style>
    /* ── Almanac palette ─────────────────────────────────── */
    :root {
      --hp-paper:       #f1ecdf;
      --hp-paper-2:     #e9e2cf;
      --hp-paper-3:     #ddd4bd;
      --hp-ink:         #14172b;
      --hp-ink-soft:    #2c2f48;
      --hp-ink-mute:    #6b6c80;
      --hp-gold:        #b08d3e;
      --hp-gold-soft:   #c9a961;
      --hp-accent:      #7b3f5c;
      --hp-rule:        rgba(20,23,43,0.18);
      --hp-rule-strong: rgba(20,23,43,0.42);
      --hp-display:     'Bodoni Moda', 'Cormorant Garamond', Georgia, serif;
      --hp-body:        'Inter', system-ui, -apple-system, sans-serif;
      --hp-mono:        ui-monospace, 'JetBrains Mono', monospace;
      --hp-ui:          'Inter', system-ui, -apple-system, sans-serif;
    }

    /* Override page background for this page only */
    :global(body) { background-color: var(--hp-paper); }

    .hp-page {
      background: var(--hp-paper);
      color: var(--hp-ink);
      font-family: var(--hp-body);
      font-size: 18px;
      line-height: 1.55;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Shared utilities ────────────────────────────────── */
    .hp-eyebrow {
      display: flex;
      align-items: center;
      gap: 12px;
      font-family: var(--hp-mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--hp-ink-mute);
    }
    .hp-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--hp-gold);
      display: inline-block;
      flex-shrink: 0;
    }
    .hp-rule-line {
      flex: 1;
      height: 1px;
      background: var(--hp-rule);
      min-width: 24px;
    }
    .hp-section-title {
      font-family: var(--hp-display);
      font-weight: 400;
      font-size: clamp(2.25rem, 4.5vw, 4rem);
      line-height: 1.02;
      letter-spacing: -0.015em;
      margin: 0 0 18px;
      color: var(--hp-ink);
    }
    .hp-section-title em { color: var(--hp-gold); font-style: italic; }
    .hp-section-lede {
      font-size: 1.1rem;
      color: var(--hp-ink-soft);
      max-width: 58ch;
      line-height: 1.7;
      margin: 0;
    }


    /* ══════════════════════════════════════════════════════
       MARQUEE STRIP
    ══════════════════════════════════════════════════════ */
    .hp-marquee-wrap {
      overflow: hidden;
      white-space: nowrap;
      background: var(--hp-paper-2);
      border-bottom: 1px solid var(--hp-rule);
      font-family: var(--hp-mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--hp-ink-mute);
      padding: 10px 0;
    }
    .hp-marquee {
      display: inline-flex;
      gap: 0;
      animation: hp-scroll 70s linear infinite;
    }
    .hp-marquee span { flex-shrink: 0; padding-left: 40px; }
    @keyframes hp-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }


    /* ══════════════════════════════════════════════════════
       HERO
    ══════════════════════════════════════════════════════ */
    .hp-hero {
      background: linear-gradient(135deg, #07071a 0%, #130a2e 55%, #0d0a25 100%);
      border-bottom: none;
      padding: 64px 40px 80px;
    }
    .hp-hero-inner {
      max-width: 1440px;
      margin: 0 auto;
    }
    /* hero text on dark bg */
    .hp-hero .hp-hero-title           { color: #ebe8f7; }
    .hp-hero .hp-hero-title em        { color: var(--hp-gold-soft); }
    .hp-hero .hp-hero-sub             { color: rgba(235,232,247,0.65); }
    .hp-hero .hp-hero-dek             { color: rgba(235,232,247,0.6); font-family: var(--hp-ui); font-size: 1.05rem; }
    .hp-hero .hp-hero-stats           { border-top-color: rgba(235,232,247,0.15); }
    .hp-hero .hp-stat-lbl             { color: rgba(235,232,247,0.45); }
    .hp-hero .hp-stat-divider         { background: rgba(235,232,247,0.15); }
    .hp-hero .hp-ornament             { color: rgba(235,232,247,0.9); }
    .hp-hero .hp-today-card           { background: rgba(255,255,255,0.06); border-color: rgba(196,162,78,0.25); box-shadow: none; }
    .hp-hero .hp-today-title          { color: #ebe8f7; }
    .hp-hero .hp-today-keywords       { color: rgba(235,232,247,0.45); }
    .hp-hero .hp-today-footer         { border-top-color: rgba(235,232,247,0.12); color: rgba(235,232,247,0.35); }
    .hp-hero .hp-today-num            { color: #ebe8f7; }

    .hp-btn-affiliate {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--hp-ui);
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.04em;
      padding: 18px 36px;
      border-radius: 999px;
      background: var(--hp-gold);
      color: #07071a;
      text-decoration: none;
      transition: opacity 0.2s, transform 0.15s;
      border: none;
    }
    .hp-btn-affiliate:hover { opacity: 0.88; transform: translateY(-1px); }

    .hp-hero-grid {
      display: grid;
      grid-template-columns: 1.05fr 1fr;
      gap: 64px;
      align-items: center;
    }
    .hp-hero-eyebrow {
      margin-bottom: 32px;
    }
    .hp-hero-title {
      font-family: var(--hp-display);
      font-weight: 400;
      font-size: clamp(3rem, 6.5vw, 6rem);
      line-height: 0.96;
      letter-spacing: -0.02em;
      margin: 0 0 28px;
      color: var(--hp-ink);
    }
    .hp-hero-title em  { color: var(--hp-gold); font-style: italic; }
    .hp-hero-sub {
      display: block;
      font-style: italic;
      color: var(--hp-ink-soft);
      font-size: 0.7em;
      font-weight: 300;
    }
    .hp-hero-dek {
      font-size: 1.2rem;
      line-height: 1.6;
      color: var(--hp-ink-soft);
      max-width: 56ch;
      margin: 0 0 40px;
    }
    .hp-hero-actions {
      display: flex;
      gap: 16px;
      align-items: center;
      margin-bottom: 56px;
      flex-wrap: wrap;
    }
    /* legacy btn classes removed — see .hp-btn-affiliate */
    .hp-hero-stats {
      display: flex;
      gap: 28px;
      align-items: flex-end;
      padding-top: 32px;
      border-top: 1px solid var(--hp-rule);
    }
    .hp-stat-divider { width: 1px; background: var(--hp-rule); align-self: stretch; }
    .hp-stat-num {
      font-family: var(--hp-display);
      font-style: italic;
      font-size: 3rem;
      line-height: 0.9;
      color: var(--hp-gold);
    }
    .hp-stat-lbl {
      font-family: var(--hp-mono);
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--hp-ink-mute);
      margin-top: 6px;
    }

    /* Ornament */
    .hp-hero-right { position: relative; min-height: 520px; }
    .hp-ornament {
      position: absolute;
      inset: 0;
      color: var(--hp-ink);
      pointer-events: none;
    }
    .hp-ornament svg { width: 100%; height: 100%; }

    /* Today card */
    .hp-today-card {
      position: absolute;
      bottom: 0;
      left: -32px;
      right: 32px;
      background: var(--hp-paper-2);
      border: 1px solid var(--hp-rule-strong);
      padding: 22px 26px;
      box-shadow: 0 30px 60px -30px rgba(20,23,43,0.3);
    }
    .hp-today-eyebrow {
      font-family: var(--hp-mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--hp-gold);
      margin-bottom: 14px;
    }
    .hp-today-body { display: flex; gap: 20px; align-items: center; }
    .hp-today-num {
      font-family: var(--hp-display);
      font-style: italic;
      font-size: 4.5rem;
      line-height: 0.9;
      color: var(--hp-ink);
      min-width: 56px;
    }
    .hp-today-title {
      font-family: var(--hp-display);
      font-size: 1.4rem;
      font-style: italic;
      line-height: 1.1;
    }
    .hp-today-keywords {
      font-family: var(--hp-mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--hp-ink-mute);
      margin-top: 8px;
    }
    .hp-today-footer {
      margin-top: 14px;
      padding-top: 12px;
      border-top: 1px solid var(--hp-rule);
      display: flex;
      justify-content: space-between;
      font-family: var(--hp-mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      color: var(--hp-ink-mute);
    }
    .hp-today-footer a { color: var(--hp-gold); text-decoration: none; }
    .hp-today-footer a:hover { text-decoration: underline; }


    /* ══════════════════════════════════════════════════════
       LIFE PATH CALCULATOR
    ══════════════════════════════════════════════════════ */
    .hp-calc-section {
      padding: 100px 40px;
      background: var(--hp-paper-2);
      border-bottom: 1px solid var(--hp-rule);
    }
    .hp-calc { max-width: 1100px; margin: 0 auto; }
    .hp-calc-frame {
      background: var(--hp-paper);
      border: 1px solid var(--hp-rule-strong);
      padding: 56px 64px;
      position: relative;
    }
    .hp-calc-corners span {
      position: absolute;
      width: 14px; height: 14px;
      border: 1px solid var(--hp-gold);
    }
    .hp-calc-corners span:nth-child(1) { top:-1px;left:-1px;border-right:none;border-bottom:none; }
    .hp-calc-corners span:nth-child(2) { top:-1px;right:-1px;border-left:none;border-bottom:none; }
    .hp-calc-corners span:nth-child(3) { bottom:-1px;left:-1px;border-right:none;border-top:none; }
    .hp-calc-corners span:nth-child(4) { bottom:-1px;right:-1px;border-left:none;border-top:none; }

    .hp-calc-head { text-align: center; margin-bottom: 40px; }
    .hp-calc-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-family: var(--hp-mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--hp-ink-mute);
      margin-bottom: 18px;
    }
    .hp-calc-title {
      font-family: var(--hp-display);
      font-weight: 400;
      font-size: clamp(2.25rem, 4.2vw, 3.5rem);
      line-height: 1.02;
      margin: 0 0 16px;
      color: var(--hp-ink);
    }
    .hp-calc-title em { color: var(--hp-gold); font-style: italic; }
    .hp-calc-lede { font-size: 1.05rem; color: var(--hp-ink-soft); max-width: 56ch; margin: 0 auto; line-height: 1.65; }

    .hp-stepper {
      display: flex;
      margin: 40px 0 48px;
      border-top: 1px solid var(--hp-rule);
      border-bottom: 1px solid var(--hp-rule);
    }
    .hp-step {
      flex: 1;
      background: transparent;
      border: none;
      border-right: 1px solid var(--hp-rule);
      padding: 18px 16px;
      display: flex;
      align-items: center;
      gap: 14px;
      color: var(--hp-ink-mute);
      font-family: var(--hp-ui);
      text-align: left;
      cursor: pointer;
      transition: all 0.2s;
      position: relative;
    }
    .hp-step:last-child { border-right: none; }
    .hp-step-num {
      font-family: var(--hp-display);
      font-style: italic;
      font-size: 1.75rem;
      line-height: 1;
    }
    .hp-step-label { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; }
    .hp-step.active { color: var(--hp-ink); background: var(--hp-paper-2); }
    .hp-step.active::after {
      content: '';
      position: absolute;
      bottom: -1px; left: 0; right: 0;
      height: 2px;
      background: var(--hp-gold);
    }
    .hp-step.done { color: var(--hp-gold); }
    .hp-step:disabled { cursor: default; opacity: 0.5; }

    .hp-calc-stage { min-height: 320px; }
    .hp-stage-prompt {
      font-family: var(--hp-display);
      font-style: italic;
      font-size: 1.6rem;
      text-align: center;
      margin: 0 0 28px;
      color: var(--hp-ink-soft);
    }

    .hp-month-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      border: 1px solid var(--hp-rule);
    }
    .hp-month-cell {
      background: transparent;
      border: none;
      border-right: 1px solid var(--hp-rule);
      border-bottom: 1px solid var(--hp-rule);
      padding: 22px 12px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      color: var(--hp-ink);
      cursor: pointer;
      transition: all 0.2s;
    }
    .hp-month-cell:nth-child(6n) { border-right: none; }
    .hp-month-cell:nth-child(n+7) { border-bottom: none; }
    .hp-month-cell:hover { background: var(--hp-paper-2); }
    .hp-month-cell.selected { background: var(--hp-ink); color: var(--hp-paper); }
    .hp-month-cell.selected .hp-month-num { color: var(--hp-gold-soft); }
    .hp-month-num { font-family: var(--hp-display); font-style: italic; font-size: 1.5rem; color: var(--hp-gold); }
    .hp-month-name { font-family: var(--hp-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; }

    .hp-day-grid {
      display: grid;
      grid-template-columns: repeat(8, 1fr);
      border: 1px solid var(--hp-rule);
    }
    .hp-day-cell {
      background: transparent;
      border: none;
      border-right: 1px solid var(--hp-rule);
      border-bottom: 1px solid var(--hp-rule);
      padding: 14px 8px;
      font-family: var(--hp-display);
      font-style: italic;
      font-size: 1.375rem;
      color: var(--hp-ink);
      cursor: pointer;
      transition: all 0.2s;
      text-align: center;
    }
    .hp-day-cell:hover { background: var(--hp-paper-2); color: var(--hp-gold); }
    .hp-day-cell.selected { background: var(--hp-ink); color: var(--hp-paper); }

    .hp-stage-year { text-align: center; padding: 30px 0; }
    .hp-year-input-wrap { margin: 0 auto 32px; max-width: 280px; }
    .hp-year-input {
      width: 100%;
      background: transparent;
      border: none;
      border-bottom: 2px solid var(--hp-rule-strong);
      font-family: var(--hp-display);
      font-style: italic;
      font-size: 6rem;
      text-align: center;
      color: var(--hp-ink);
      padding: 12px 0;
      outline: none;
      letter-spacing: 0.05em;
    }
    .hp-year-input::placeholder { color: var(--hp-ink-mute); opacity: 0.4; }
    .hp-year-input:focus { border-color: var(--hp-gold); }
    .hp-year-hint {
      font-family: var(--hp-mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--hp-ink-mute);
      margin-top: 14px;
    }
    .hp-reveal-btn {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background: var(--hp-ink);
      color: var(--hp-paper);
      border: none;
      padding: 18px 36px;
      border-radius: 999px;
      font-family: var(--hp-ui);
      font-size: 13px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.25s;
    }
    .hp-reveal-btn:hover:not(:disabled) { background: var(--hp-gold); }
    .hp-reveal-btn:disabled { opacity: 0.35; cursor: not-allowed; }

    .hp-calc-fade-in { animation: hp-calc-fade 0.35s ease-out; }
    @keyframes hp-calc-fade {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hp-math-line {
      display: flex;
      align-items: flex-end;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
      padding: 24px 0 36px;
      border-bottom: 1px dashed var(--hp-rule);
      margin-bottom: 36px;
      min-height: 100px;
    }
    .hp-date-part { text-align: center; }
    .hp-dp-label {
      font-family: var(--hp-mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--hp-ink-mute);
      margin-bottom: 6px;
    }
    .hp-dp-stack { display: flex; flex-direction: column; gap: 4px; align-items: center; }
    .hp-dp-value {
      font-family: var(--hp-display);
      font-style: italic;
      color: var(--hp-ink-soft);
      transition: all 0.5s;
      font-size: 1.75rem;
      opacity: 0;
    }
    .hp-dp-value.raw   { font-size: 2.25rem; color: var(--hp-ink); opacity: 1; }
    .hp-dp-value.gold  { color: var(--hp-gold); font-size: 2.75rem; opacity: 1; }
    .hp-dp-value.shown { opacity: 1; }
    .hp-op {
      font-family: var(--hp-display);
      font-style: italic;
      font-size: 2.25rem;
      color: var(--hp-ink-mute);
      align-self: center;
    }
    .hp-op.equals { color: var(--hp-gold); }
    .hp-sum-block { text-align: center; display: none; }
    .hp-sum-block.shown { display: block; }
    .hp-sum-label {
      font-family: var(--hp-mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--hp-ink-mute);
      margin-bottom: 6px;
    }
    .hp-sum-value { font-family: var(--hp-display); font-style: italic; font-size: 3.5rem; color: var(--hp-gold); line-height: 1; }
    .hp-sum-row { display: flex; align-items: baseline; gap: 10px; justify-content: center; }
    .hp-sum-inline-trail { display: flex; align-items: baseline; gap: 8px; }
    .hp-sum-arrow-inline { font-family: var(--hp-display); font-style: italic; font-size: 2rem; color: var(--hp-ink-mute); }
    .hp-sum-final { font-family: var(--hp-display); font-style: italic; font-size: 3.5rem; color: var(--hp-gold); line-height: 1; }
    .hp-op-sum { display: none; }
    .hp-op-sum.shown { display: flex; align-items: center; }

    .hp-revelation {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 48px;
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.7s, transform 0.7s;
    }
    .hp-revelation.shown { opacity: 1; transform: translateY(0); }
    .hp-rev-left { text-align: center; border-right: 1px solid var(--hp-rule); padding-right: 48px; }
    .hp-rev-tag {
      font-family: var(--hp-mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--hp-ink-mute);
      display: flex;
      gap: 8px;
      justify-content: center;
      align-items: center;
      margin-bottom: 16px;
    }
    .hp-master-tag { background: var(--hp-gold); color: var(--hp-paper); padding: 3px 8px; letter-spacing: 0.16em; margin-left: 6px; }
    .hp-rev-number { font-family: var(--hp-display); font-style: italic; font-size: 11.25rem; line-height: 0.9; color: var(--hp-ink); display: block; }
    .hp-rev-glyph { color: var(--hp-gold); opacity: 0.6; display: flex; justify-content: center; margin: 8px 0 12px; }
    .hp-rev-title { font-family: var(--hp-display); font-style: italic; font-size: 2.1rem; line-height: 1; margin-bottom: 8px; color: var(--hp-ink); }
    .hp-rev-archetype { font-family: var(--hp-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--hp-gold); }
    .hp-rev-right { display: flex; flex-direction: column; gap: 20px; }
    .hp-rev-body { font-size: 1.15rem; line-height: 1.55; color: var(--hp-ink-soft); margin: 0; }
    .hp-rev-traits { display: flex; flex-direction: column; gap: 14px; padding-top: 16px; border-top: 1px solid var(--hp-rule); }
    .hp-trait { display: grid; grid-template-columns: 160px 1fr; gap: 18px; }
    .hp-trait-label { font-family: var(--hp-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--hp-ink-mute); padding-top: 4px; }
    .hp-trait-text { font-size: 1.05rem; color: var(--hp-ink); }
    .hp-rev-actions { display: flex; gap: 14px; padding-top: 18px; border-top: 1px solid var(--hp-rule); align-items: center; flex-wrap: wrap; }
    .hp-link-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 13px 24px;
      border-radius: 999px;
      background: var(--hp-ink);
      color: var(--hp-paper);
      font-family: var(--hp-ui);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: background 0.2s;
      white-space: nowrap;
    }
    .hp-link-btn:hover { background: var(--hp-gold); color: var(--hp-paper) !important; }
    .hp-calc-reset-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 13px 24px;
      border-radius: 999px;
      border: 1px solid var(--hp-rule-strong);
      background: transparent;
      color: var(--hp-ink-soft);
      font-family: var(--hp-ui);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
    }
    .hp-calc-reset-btn:hover { border-color: var(--hp-gold); color: var(--hp-gold); }
    /* intermediate reduction steps fade out after animation completes */
    .hp-dp-value.faded { opacity: 0.1 !important; transition: opacity 0.8s; }

    @media (max-width: 900px) {
      .hp-calc-frame { padding: 36px 24px; }
      .hp-revelation { grid-template-columns: 1fr; }
      .hp-rev-left { border-right: none; padding-right: 0; border-bottom: 1px solid var(--hp-rule); padding-bottom: 24px; }
      .hp-rev-number { font-size: 8rem; }
      .hp-trait { grid-template-columns: 1fr; gap: 4px; }
      .hp-day-grid { grid-template-columns: repeat(7, 1fr); }
    }
    @media (max-width: 600px) {
      .hp-calc-section { padding: 60px 16px; }
      .hp-month-grid { grid-template-columns: repeat(3, 1fr); }
      .hp-month-cell:nth-child(6n) { border-right: 1px solid var(--hp-rule); }
      .hp-month-cell:nth-child(3n) { border-right: none; }
      .hp-day-grid { grid-template-columns: repeat(5, 1fr); }
      .hp-step-label { display: none; }
    }


    /* ══════════════════════════════════════════════════════
       NUMBERS GRID
    ══════════════════════════════════════════════════════ */
    .hp-numbers {
      max-width: 1440px;
      margin: 0 auto;
      padding: 100px 40px;
      border-bottom: 1px solid var(--hp-rule);
    }
    .hp-numbers-head {
      text-align: center;
      margin-bottom: 56px;
    }
    .hp-numbers-head .hp-eyebrow { justify-content: center; margin-bottom: 24px; }
    .hp-numbers-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: var(--hp-rule);
    }
    .hp-num-tile {
      position: relative;
      overflow: hidden;
      display: block;
      aspect-ratio: 2 / 3;
      background: var(--hp-paper);
      text-decoration: none;
    }
    .hp-num-tile img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; display: block; }
    .hp-num-tile:hover img { transform: scale(1.07); }
    .hp-num-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(20,23,43,0.88) 0%, rgba(20,23,43,0.28) 55%, transparent 100%);
      transition: background 0.3s;
    }
    .hp-num-tile:hover .hp-num-overlay {
      background: linear-gradient(to top, rgba(20,23,43,0.95) 0%, rgba(20,23,43,0.55) 65%, transparent 100%);
    }
    .hp-num-content { position: absolute; bottom: 0; left: 0; right: 0; padding: 1rem 0.875rem; }
    .hp-num-n {
      font-family: var(--hp-display);
      font-style: italic;
      font-size: 2.5rem;
      color: var(--hp-gold-soft);
      line-height: 1;
      margin-bottom: 0.2rem;
    }
    .hp-num-n.master { font-size: 2rem; }
    .hp-num-label {
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: rgba(241,236,223,0.85);
      font-weight: 600;
      font-family: var(--hp-mono);
    }
    .hp-master-badge {
      font-size: 0.56rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--hp-gold-soft);
      margin-top: 0.25rem;
      font-weight: 600;
      display: block;
      font-family: var(--hp-mono);
    }
    .hp-numbers-note {
      text-align: center;
      margin-top: 2rem;
      font-family: var(--hp-mono);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--hp-ink-mute);
    }
    .hp-numbers-note a { color: var(--hp-gold); text-decoration: none; }
    .hp-numbers-note a:hover { text-decoration: underline; }


    /* ══════════════════════════════════════════════════════
       METHOD
    ══════════════════════════════════════════════════════ */
    .hp-method {
      background: var(--hp-ink);
      color: var(--hp-paper);
      padding: 100px 40px;
    }
    .hp-method-inner { max-width: 1200px; margin: 0 auto; }
    .hp-method .hp-eyebrow { color: var(--hp-paper-3); margin-bottom: 0; }
    .hp-method .hp-section-title { color: var(--hp-paper); margin-top: 24px; }
    .hp-method .hp-section-title em { color: var(--hp-gold-soft); }
    .hp-method-steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      margin: 56px 0 0;
      border-top: 1px solid rgba(241,236,223,0.18);
      border-bottom: 1px solid rgba(241,236,223,0.18);
    }
    .hp-method-step {
      padding: 36px 32px;
      border-right: 1px solid rgba(241,236,223,0.18);
    }
    .hp-method-step:last-child { border-right: none; }
    .hp-method-num {
      font-family: var(--hp-display);
      font-style: italic;
      font-size: 3.5rem;
      color: var(--hp-gold-soft);
      line-height: 1;
      margin-bottom: 18px;
    }
    .hp-method-title {
      font-family: var(--hp-display);
      font-size: 1.35rem;
      font-style: italic;
      margin-bottom: 10px;
      color: var(--hp-paper);
    }
    .hp-method-body { color: var(--hp-paper-3); font-size: 1rem; line-height: 1.55; }
    .hp-method-example {
      margin-top: 56px;
      padding: 36px;
      border: 1px solid rgba(241,236,223,0.22);
      background: rgba(241,236,223,0.04);
    }
    .hp-ex-label {
      font-family: var(--hp-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--hp-gold-soft);
      margin-bottom: 22px;
    }
    .hp-ex-math {
      display: flex;
      flex-wrap: wrap;
      gap: 18px;
      align-items: baseline;
      font-family: var(--hp-display);
      font-size: 1.35rem;
      color: var(--hp-paper);
      line-height: 1.5;
    }
    .hp-ex-math em { color: var(--hp-paper-3); font-style: italic; font-size: 1.1rem; }
    .hp-ex-math strong { color: var(--hp-gold-soft); font-style: italic; font-weight: 400; font-size: 1.7rem; }
    .hp-ex-final { font-size: 2.75rem !important; }
    .hp-ex-op { color: var(--hp-paper-3); font-style: italic; }
    .hp-ex-note { margin-top: 22px; font-style: italic; color: var(--hp-paper-3); font-size: 1.1rem; }


    /* ══════════════════════════════════════════════════════
       ARTICLES / JOURNAL
    ══════════════════════════════════════════════════════ */
    .hp-articles {
      max-width: 1440px;
      margin: 0 auto;
      padding: 100px 40px;
      border-bottom: 1px solid var(--hp-rule);
    }
    .hp-articles-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 56px;
    }
    .hp-articles-head .hp-eyebrow { margin-bottom: 20px; }
    .hp-link-underline {
      font-family: var(--hp-mono);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--hp-gold);
      text-decoration: none;
      border-bottom: 1px solid var(--hp-gold);
      padding-bottom: 2px;
      white-space: nowrap;
      transition: opacity 0.2s;
    }
    .hp-link-underline:hover { opacity: 0.75; }
    .hp-article-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-top: 1px solid var(--hp-rule-strong);
    }
    .hp-article {
      padding: 32px 28px 36px;
      border-right: 1px solid var(--hp-rule);
      border-bottom: 1px solid var(--hp-rule);
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      transition: background 0.2s;
    }
    .hp-article:nth-child(3n) { border-right: none; }
    .hp-article:nth-last-child(-n+3) { border-bottom: none; }
    .hp-article:hover { background: var(--hp-paper-2); }
    .hp-article-meta {
      display: flex;
      justify-content: space-between;
      font-family: var(--hp-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--hp-ink-mute);
      margin-bottom: 20px;
    }
    .kicker-gold  { color: var(--hp-gold); }
    .kicker-plum  { color: var(--hp-accent); }
    .kicker-ink   { color: var(--hp-ink); }
    .kicker-sage  { color: #5e7350; }
    .hp-article-title {
      font-family: var(--hp-display);
      font-weight: 400;
      font-style: italic;
      font-size: 1.65rem;
      line-height: 1.15;
      margin: 0 0 12px;
      color: var(--hp-ink);
    }
    .hp-article-dek { color: var(--hp-ink-soft); font-size: 0.95rem; line-height: 1.55; margin: 0 0 24px; flex: 1; }
    .hp-article-foot {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 14px;
      border-top: 1px solid var(--hp-rule);
      font-family: var(--hp-mono);
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--hp-ink-mute);
    }
    .hp-article-arrow { color: var(--hp-gold); transition: transform 0.25s; display: flex; align-items: center; }
    .hp-article:hover .hp-article-arrow { transform: translateX(6px); }


    /* ══════════════════════════════════════════════════════
       READING AFFILIATE BLOCK
    ══════════════════════════════════════════════════════ */
    .hp-reading {
      background: var(--hp-paper-2);
      border-bottom: 1px solid var(--hp-rule);
      padding: 80px 40px;
    }
    .hp-reading-inner { max-width: 1100px; margin: 0 auto; }
    .hp-reading-block {
      background: var(--hp-ink);
      display: grid;
      grid-template-columns: 1fr 1fr;
      overflow: hidden;
    }
    .hp-reading-left {
      padding: 3rem 2.75rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .hp-reading-left .hp-eyebrow { color: var(--hp-paper-3); margin-bottom: 20px; }
    .hp-reading-left h2 {
      font-family: var(--hp-display);
      font-weight: 400;
      font-size: clamp(1.6rem, 3vw, 2.1rem);
      color: var(--hp-paper);
      line-height: 1.25;
      margin: 0 0 1rem;
    }
    .hp-reading-left h2 em { color: var(--hp-gold-soft); font-style: italic; }
    .hp-reading-left > p {
      font-size: 0.9rem;
      line-height: 1.75;
      color: rgba(241,236,223,0.58);
      margin-bottom: 2rem;
    }
    .hp-btn-gold {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--hp-gold);
      color: var(--hp-ink);
      font-family: var(--hp-ui);
      font-weight: 700;
      font-size: 0.9rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.875rem 1.75rem;
      border-radius: 999px;
      text-decoration: none;
      width: fit-content;
      transition: opacity 0.2s;
    }
    .hp-btn-gold:hover { opacity: 0.88; }
    .hp-reading-disclaimer {
      margin-top: 1rem;
      font-size: 0.68rem;
      color: rgba(241,236,223,0.22);
      line-height: 1.5;
      font-family: var(--hp-mono);
      letter-spacing: 0.04em;
    }
    .hp-reading-right {
      border-left: 1px solid rgba(241,236,223,0.12);
      padding: 3rem 2.5rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 1.5rem;
    }
    .hp-reading-point { display: flex; gap: 1rem; align-items: flex-start; }
    .hp-reading-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--hp-gold-soft);
      margin-top: 0.45rem;
      flex-shrink: 0;
    }
    .hp-reading-point-head { font-size: 0.875rem; font-weight: 600; color: var(--hp-paper); margin-bottom: 0.2rem; }
    .hp-reading-point-body { font-size: 0.8rem; color: rgba(241,236,223,0.5); line-height: 1.6; }


    /* ══════════════════════════════════════════════════════
       FAQ
    ══════════════════════════════════════════════════════ */
    .hp-faq {
      background: var(--hp-paper);
      border-bottom: 1px solid var(--hp-rule);
      padding: 80px 40px;
    }
    .hp-faq-inner { max-width: 720px; margin: 0 auto; }
    .hp-faq-head { text-align: center; margin-bottom: 40px; }
    .hp-faq-head .hp-eyebrow { justify-content: center; margin-bottom: 20px; }
    .hp-faq-head h2 {
      font-family: var(--hp-display);
      font-weight: 400;
      font-size: clamp(1.75rem, 3.5vw, 2.5rem);
      color: var(--hp-ink);
      margin: 0;
    }
    .hp-faq details { border-top: 1px solid var(--hp-rule); }
    .hp-faq details:last-child { border-bottom: 1px solid var(--hp-rule); }
    .hp-faq summary {
      padding: 1.3rem 0;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      font-weight: 600;
      font-size: 1rem;
      color: var(--hp-ink);
      list-style: none;
      font-family: var(--hp-body);
      transition: color 0.2s;
    }
    .hp-faq summary::-webkit-details-marker { display: none; }
    .hp-faq details[open] summary { color: var(--hp-gold); }
    .hp-faq-chevron { flex-shrink: 0; transition: transform 0.25s; }
    .hp-faq details[open] .hp-faq-chevron { transform: rotate(180deg); }
    .hp-faq-answer {
      padding-bottom: 1.3rem;
      font-size: 0.95rem;
      color: var(--hp-ink-soft);
      line-height: 1.8;
    }


    /* ══════════════════════════════════════════════════════
       BOTTOM CTA
    ══════════════════════════════════════════════════════ */
    .hp-cta {
      background: var(--hp-ink);
      color: var(--hp-paper);
      padding: 100px 40px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hp-cta::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 120%, rgba(176,141,62,0.2) 0%, transparent 70%);
      pointer-events: none;
    }
    .hp-cta-inner { position: relative; z-index: 1; max-width: 580px; margin: 0 auto; }
    .hp-cta .hp-eyebrow { justify-content: center; color: var(--hp-paper-3); margin-bottom: 20px; }
    .hp-cta h2 {
      font-family: var(--hp-display);
      font-weight: 400;
      font-size: clamp(2rem, 4vw, 3.25rem);
      color: var(--hp-paper);
      line-height: 1.1;
      margin: 0 0 1rem;
    }
    .hp-cta h2 em { color: var(--hp-gold-soft); font-style: italic; }
    .hp-cta > .hp-cta-inner > p {
      color: rgba(241,236,223,0.55);
      font-size: 1rem;
      line-height: 1.8;
      margin-bottom: 2.5rem;
    }


    /* ══════════════════════════════════════════════════════
       RESPONSIVE
    ══════════════════════════════════════════════════════ */
    @media (max-width: 1100px) {
      .hp-hero-grid    { grid-template-columns: 1fr; }
      .hp-hero-right   { display: none; }
      .hp-finder-inner { grid-template-columns: 1fr; gap: 40px; }
      .hp-reading-block { grid-template-columns: 1fr; }
      .hp-reading-right { border-left: none; border-top: 1px solid rgba(241,236,223,0.12); }
    }
    @media (max-width: 900px) {
      .hp-hero, .hp-numbers, .hp-method, .hp-articles,
      .hp-reading, .hp-faq, .hp-cta { padding-left: 24px; padding-right: 24px; }
      .hp-numbers-grid  { grid-template-columns: repeat(3, 1fr); }
      .hp-method-steps  { grid-template-columns: 1fr; }
      .hp-method-step   { border-right: none; border-bottom: 1px solid rgba(241,236,223,0.18); }
      .hp-method-step:last-child { border-bottom: none; }
      .hp-article-grid  { grid-template-columns: 1fr 1fr; }
      .hp-article:nth-child(3n) { border-right: 1px solid var(--hp-rule); }
      .hp-article:nth-child(2n) { border-right: none; }
      .hp-article:nth-last-child(-n+3) { border-bottom: 1px solid var(--hp-rule); }
      .hp-article:nth-last-child(-n+2) { border-bottom: none; }
    }
    @media (max-width: 600px) {
      .hp-hero, .hp-numbers, .hp-method, .hp-articles,
      .hp-reading, .hp-faq, .hp-cta { padding-left: 16px; padding-right: 16px; }
      .hp-numbers-grid { grid-template-columns: repeat(3, 1fr); }
      .hp-article-grid { grid-template-columns: 1fr; }

---
import Layout from '../../../layouts/Layout.astro';
import SidebarCTA from '../../../components/SidebarCTA.astro';
import { personalYearNumbers } from '../../../data/personalYearNumbers';

export function getStaticPaths() {
  return personalYearNumbers.map(py => ({
    params: { n: String(py.n) },
    props: { py },
  }));
}

const { py } = Astro.props;

const allNumbers = personalYearNumbers.map(p => ({ n: String(p.n), label: p.title }));

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": py.faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a.join(" ") }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://numerologyguides.blog/" },
    { "@type": "ListItem", "position": 2, "name": "Learn", "item": "https://numerologyguides.blog/learn/" },
    { "@type": "ListItem", "position": 3, "name": "Personal Year Numbers", "item": "https://numerologyguides.blog/learn/personal-year-number/" },
    { "@type": "ListItem", "position": 4, "name": `Personal Year ${py.n}` }
  ]
};
---

<Layout
  schema={[faqSchema, breadcrumbSchema]}
  title={`Personal Year ${py.n}: What This Year Is Asking of You | Numerology Guides`}
  description={py.shortDesc}
>

  <link
    slot="head"
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap"
  />

  <style>
    :root { --font-family-heading: 'Cormorant Garamond', Georgia, serif; }
    .p-label { font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-soft-gold); font-weight:600; }
    .p-divider { width:48px; height:2px; background:var(--color-soft-gold); margin:0 auto; }
    .section-h2 { font-family:var(--font-family-heading); font-size:clamp(1.6rem,3.5vw,2.25rem); font-weight:700; color:var(--color-body-text); margin:0 0 1.25rem; }
    .faq-list details { border-top:1px solid var(--color-border); }
    .faq-list details:last-child { border-bottom:1px solid var(--color-border); }
    .faq-list summary { padding:1.3rem 0; cursor:pointer; display:flex; align-items:center; justify-content:space-between; gap:1rem; font-weight:600; font-size:1rem; color:var(--color-body-text); list-style:none; transition:color 0.2s; }
    .faq-list summary::-webkit-details-marker { display:none; }
    .faq-list details[open] summary { color:var(--color-violet); }
    .faq-chevron { flex-shrink:0; transition:transform 0.25s; }
    .faq-list details[open] .faq-chevron { transform:rotate(180deg); }
    .faq-answer { padding-bottom:1.3rem; font-size:0.9rem; color:var(--color-muted-text); line-height:1.8; }
  </style>

  <!-- Breadcrumb -->
  <nav style="background:var(--color-card-bg);border-bottom:1px solid var(--color-border);padding:0.75rem 1.5rem;" aria-label="Breadcrumb">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:0.5rem;font-size:0.75rem;color:var(--color-muted-text);">
      <a href="/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Home</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Learn</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/personal-year-number/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Personal Year Numbers</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <span style="color:var(--color-body-text);font-weight:600;">Personal Year {py.n}</span>
    </div>
  </nav>

  <!-- Hero -->
  <section style="position:relative;overflow:hidden;background:var(--color-midnight,#0e0a1a);">
    <div aria-hidden="true" style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(196,162,78,0.07) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>
    <div aria-hidden="true" style="position:absolute;top:-10%;left:-5%;width:55%;height:120%;background:radial-gradient(ellipse at center,rgba(124,92,191,0.18) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>
    <div style="position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:4rem 1.5rem;display:flex;align-items:center;gap:3rem;flex-wrap:wrap;">
      <div style="flex:1;min-width:280px;">
        <p class="p-label" style="margin-bottom:1.1rem;color:var(--color-soft-gold);opacity:0.9;">Personal Year Number {py.n}</p>
        <div class="p-divider" style="margin:0 0 1.6rem;"></div>
        <h1 style="font-family:var(--font-family-heading);font-size:clamp(2.8rem,6vw,5rem);font-weight:700;line-height:1.06;color:#f5f0e8;letter-spacing:-0.02em;margin:0 0 1.25rem;">
          Personal Year <em style="color:#c8a8f0;font-style:italic;">{py.n}</em>: {py.title}
        </h1>
        <p style="font-size:1.05rem;line-height:1.8;color:rgba(240,234,255,0.78);max-width:460px;margin:0 0 2rem;">{py.shortDesc}</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.875rem;">
          <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:1rem;padding:0.875rem 2rem;border-radius:6px;text-decoration:none;transition:background 0.2s,transform 0.15s;box-shadow:0 4px 20px rgba(124,92,191,0.45);" onmouseover="this.style.background='#6a4eab';this.style.transform='translateY(-1px)'" onmouseout="this.style.background='var(--color-violet)';this.style.transform='none'">Get My Free Reading →</a>
          <a href="#meaning" style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.08);backdrop-filter:blur(6px);color:#f5f0e8;font-weight:600;font-size:1rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.2);transition:border-color 0.2s,background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)';this.style.borderColor='rgba(255,255,255,0.4)'" onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.borderColor='rgba(255,255,255,0.2)'">What It Means ↓</a>
        </div>
      </div>
      <div style="flex-shrink:0;width:clamp(200px,28vw,300px);filter:drop-shadow(0 8px 40px rgba(196,162,78,0.25)) drop-shadow(0 2px 12px rgba(0,0,0,0.6));">
        <img
          src={`/images/learn/personal-year-numbers/Personal Year Number - ${py.title}.webp`}
          alt={`Personal Year ${py.n}, ${py.title}`}
          fetchpriority="high"
          style="width:100%;border-radius:6px;display:block;"
        />
      </div>
    </div>
  </section>

  <!-- Author byline -->
  <div style="background:var(--color-card-bg);padding:1.25rem 1.5rem;border-bottom:1px solid var(--color-border);">
    <div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:1rem;">
      <img src="/images/author-maddi-green.webp" alt="Maddie Greene" style="width:3rem;height:3rem;border-radius:50%;object-fit:cover;border:2px solid var(--color-border);" />
      <div>
        <p style="font-size:0.875rem;font-weight:600;color:var(--color-body-text);margin:0;">Written by <strong>Maddie Greene</strong></p>
        <p style="font-size:0.75rem;color:var(--color-muted-text);margin:0;">Numerology writer &amp; researcher</p>
      </div>
    </div>
  </div>

  <!-- Content + Sticky sidebar wrapper -->
  <div class="xl:flex xl:gap-6 xl:max-w-[1200px] xl:mx-auto xl:px-4">
    <!-- Main content column -->
    <div class="xl:flex-1 xl:min-w-0">

  <!-- Main content -->
  <article style="padding:2.5rem 1.5rem 3rem;background:var(--color-card-bg);">
    <div style="max-width:720px;margin:0 auto;">

      <!-- What does PY[n] mean -->
      <section id="meaning" style="margin-bottom:3rem;">
        <h2 class="section-h2">What personal year {py.n} means</h2>
        <div style="display:grid;gap:0.875rem;">
          {py.meaning.map(para => <p style="color:var(--color-body-text);line-height:1.8;">{para}</p>)}
        </div>
      </section>

      <!-- Key themes -->
      <section id="themes" style="margin-bottom:3rem;">
        <h2 class="section-h2">Key themes</h2>
        <div style="background:var(--color-light-bg);border:1px solid var(--color-border);border-radius:8px;padding:1.5rem;">
          <p style="color:var(--color-body-text);line-height:1.8;margin:0;">{py.themes}</p>
        </div>
      </section>

      <!-- Strengths and challenges -->
      <section id="strengths" style="margin-bottom:3rem;">
        <h2 class="section-h2">Strengths &amp; challenges</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;">
          <div>
            <h3 style="font-family:var(--font-family-heading);font-size:1.1rem;font-weight:700;color:var(--color-body-text);margin:0 0 1rem;display:flex;align-items:center;gap:0.5rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" style="color:var(--color-soft-gold);" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              What this year supports
            </h3>
            <div style="display:grid;gap:1rem;">
              {py.strengths.map(s => (
                <div style="background:white;border:1px solid var(--color-border);border-radius:8px;padding:1.25rem;">
                  <div style="font-weight:600;color:var(--color-body-text);margin-bottom:0.3rem;">{s.title}</div>
                  <p style="font-size:0.85rem;color:var(--color-muted-text);line-height:1.7;margin:0;">{s.desc}</p>
                </div>
              ))}
            </div>
          </div>
          <div>
            <h3 style="font-family:var(--font-family-heading);font-size:1.1rem;font-weight:700;color:var(--color-body-text);margin:0 0 1rem;display:flex;align-items:center;gap:0.5rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#f87171;" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              What needs attention
            </h3>
            <div style="display:grid;gap:1rem;">
              {py.challenges.map(c => (
                <div style="background:white;border:1px solid var(--color-border);border-radius:8px;padding:1.25rem;">
                  <div style="font-weight:600;color:var(--color-body-text);margin-bottom:0.3rem;">{c.title}</div>
                  <p style="font-size:0.85rem;color:var(--color-muted-text);line-height:1.7;margin:0;">{c.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Month-by-month energy -->
      <section id="monthly" style="margin-bottom:3rem;">
        <h2 class="section-h2">How the year unfolds</h2>
        <p style="color:var(--color-body-text);line-height:1.8;">{py.monthlyFocus}</p>
      </section>

      <!-- How to calculate -->
      <section id="calculate" style="margin-bottom:3rem;">
        <h2 class="section-h2">How to calculate your Personal Year</h2>
        <p style="color:var(--color-body-text);line-height:1.8;margin-bottom:1.25rem;">
          Add your birth month + birth day + the current calendar year, then reduce to a single digit. If you land on 11, 22, or 33, keep it as-is. Those are master numbers.
        </p>
        <div style="background:var(--color-light-bg);border:1px solid var(--color-border);border-radius:8px;padding:1.25rem;margin-bottom:1.25rem;">
          <h3 style="font-family:var(--font-family-heading);font-size:1.05rem;font-weight:700;color:var(--color-body-text);margin:0 0 0.5rem;">Formula</h3>
          <p style="color:var(--color-muted-text);font-size:0.875rem;line-height:1.7;margin:0;">Birth month + Birth day + Current year = Total, then reduce by adding the digits together until you get a single digit.</p>
        </div>
        <p style="color:var(--color-muted-text);font-size:0.875rem;line-height:1.7;margin-bottom:1.25rem;">Not sure if you've calculated correctly? A free reading at Numerologist.com calculates your Personal Year and shows how all your numbers interact.</p>
        <a
          href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net"
          target="_blank"
          rel="noopener sponsored"
          style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:1rem;padding:0.875rem 2rem;border-radius:6px;text-decoration:none;transition:background 0.2s;"
        >
          Get Your Free Numerology Reading →
        </a>
      </section>

      <!-- FAQ -->
      <section id="faq" style="margin-bottom:3rem;">
        <h2 class="section-h2">Common questions</h2>
        <div class="faq-list">
          {py.faq.map(item => (
            <details>
              <summary>
                {item.q}
                <svg class="faq-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-answer">
                <div style="display:grid;gap:0.75rem;">
                  {item.a.map(para => <p style="margin:0;">{para}</p>)}
                </div>
              </div>
            </details>
          ))}
        </div>
      </section>

      <!-- All personal year numbers grid -->
      <section id="all" style="margin-bottom:3rem;">
        <h2 class="section-h2">All personal year numbers</h2>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;">
          {allNumbers.map(num => (
            <a
              href={`/learn/personal-year-number/${num.n}/`}
              style={num.n === String(py.n)
                ? "display:block;padding:0.75rem;text-align:center;border-radius:6px;border:2px solid var(--color-soft-gold);background:rgba(196,162,78,0.08);text-decoration:none;font-weight:700;color:var(--color-body-text);"
                : "display:block;padding:0.75rem;text-align:center;border-radius:6px;border:2px solid var(--color-border);background:var(--color-light-bg);text-decoration:none;color:var(--color-muted-text);transition:border-color 0.2s,color 0.2s;"}
            >
              <div style={`font-family:var(--font-family-heading);font-size:1.5rem;font-weight:700;${num.n === String(py.n) ? 'color:var(--color-soft-gold);' : 'color:var(--color-body-text);'}`}>{num.n}</div>
              <div style="font-size:0.7rem;margin-top:0.2rem;">{num.label.replace('The ', '')}</div>
            </a>
          ))}
        </div>
      </section>

      <!-- Related guides -->
      <section id="related" style="margin-bottom:1rem;">
        <h2 class="section-h2">Related guides</h2>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
          <a href="/learn/life-path-number/" class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block" style="text-decoration:none;">
            <img src="/images/learn/Life Path Numbers - Tile.webp" alt="Life Path Numbers" class="w-full aspect-[2/3] object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
            <div style="padding:1rem;">
              <div style="font-weight:700;color:var(--color-body-text);margin-bottom:0.35rem;" class="group-hover:text-violet transition-colors">Life Path Numbers</div>
              <p style="font-size:0.8rem;color:var(--color-muted-text);margin:0;">Your core number, the terrain and energy of your entire life journey.</p>
            </div>
          </a>
          <a href="/learn/expression-number/" class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block" style="text-decoration:none;">
            <img src="/images/learn/Expression Numbers - Tile.webp" alt="Expression Numbers" class="w-full aspect-[2/3] object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
            <div style="padding:1rem;">
              <div style="font-weight:700;color:var(--color-body-text);margin-bottom:0.35rem;" class="group-hover:text-violet transition-colors">Expression Numbers</div>
              <p style="font-size:0.8rem;color:var(--color-muted-text);margin:0;">The direction your destiny is pulling you, your life's purpose and calling.</p>
            </div>
          </a>
          <a href="/learn/soul-urge-number/" class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block" style="text-decoration:none;">
            <img src="/images/learn/Soul Urge Numbers - Tile.webp" alt="Soul Urge Numbers" class="w-full aspect-[2/3] object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
            <div style="padding:1rem;">
              <div style="font-weight:700;color:var(--color-body-text);margin-bottom:0.35rem;" class="group-hover:text-violet transition-colors">Soul Urge Numbers</div>
              <p style="font-size:0.8rem;color:var(--color-muted-text);margin:0;">What you want at a deep level, your heart's true desire and motivation.</p>
            </div>
          </a>
        </div>
      </section>

    </div>
  </article>

    </div><!-- end main content column -->
    <SidebarCTA />
  </div><!-- end flex wrapper -->

  <!-- Bottom CTA -->
  <section style="background:var(--color-midnight);padding:5.5rem 1.5rem;position:relative;overflow:hidden;text-align:center;">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 120%,rgba(124,92,191,0.18) 0%,transparent 70%);pointer-events:none;"></div>
    <div style="position:relative;z-index:1;max-width:560px;margin:0 auto;">
      <p class="p-label">Numerologist.com</p>
      <div class="p-divider" style="margin:1rem auto;"></div>
      <h2 style="font-family:var(--font-family-heading);font-size:clamp(1.85rem,4vw,2.9rem);font-weight:700;color:var(--color-starlight);margin:1rem 0;line-height:1.2;">
        Want the full picture?
      </h2>
      <p style="color:rgba(235,232,247,0.5);font-size:0.95rem;line-height:1.8;margin-bottom:2.5rem;">
        Your Personal Year Number shows you what's happening this cycle. A free reading from Numerologist.com calculates your entire numerology chart, including your Life Path, Expression Number, Soul Urge, Personality Number, and how they all dance together.
      </p>
      <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-soft-gold);color:var(--color-midnight);font-weight:700;font-size:0.95rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;margin:0 auto;transition:opacity 0.2s;">
        Get Your Free Numerology Reading
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
  </section>

</Layout>

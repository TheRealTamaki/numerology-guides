---
interface Props {
  rating: number;
  size?: 'sm' | 'md' | 'lg';
}

const { rating, size = 'md' } = Astro.props;

const sizePx = { sm: 14, md: 18, lg: 24 };
const px = sizePx[size];

const fullHearts = Math.floor(rating);
const hasHalf = rating % 1 >= 0.5;
const emptyHearts = 5 - fullHearts - (hasHalf ? 1 : 0);
---

<div class="flex items-center gap-0.5" aria-label={`${rating} out of 5`}>
  {Array.from({ length: fullHearts }).map(() => (
    <svg xmlns="http://www.w3.org/2000/svg" width={px} height={px} viewBox="0 0 24 24" fill="currentColor" stroke="none" class="heart-full" aria-hidden="true" style="filter: drop-shadow(1px 1px 0 rgba(0,0,0,0.2));"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
  ))}
  {hasHalf && (
    <svg xmlns="http://www.w3.org/2000/svg" width={px} height={px} viewBox="0 0 24 24" fill="currentColor" stroke="none" class="heart-half" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
  )}
  {Array.from({ length: emptyHearts }).map(() => (
    <svg xmlns="http://www.w3.org/2000/svg" width={px} height={px} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="heart-empty" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
  ))}
  <span class="text-sm text-muted-text ml-1 font-semibold">{rating.toFixed(1)}</span>
</div>

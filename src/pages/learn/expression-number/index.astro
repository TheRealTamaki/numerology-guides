---
import Layout from '../../../layouts/Layout.astro';
import SidebarCTA from '../../../components/SidebarCTA.astro';
import { expressionNumbers } from '../../../data/expressionNumbers';

// Rich display metadata for each core expression number
const enMeta: Record<number, { traits: string; career: string }> = {
  1: { traits: "Independent, original, driven to lead",       career: "Entrepreneur, executive, innovator" },
  2: { traits: "Diplomatic, cooperative, perceptive",         career: "Counsellor, mediator, diplomat" },
  3: { traits: "Expressive, creative, communicative",         career: "Writer, artist, performer" },
  4: { traits: "Practical, systematic, reliable",             career: "Engineer, architect, project manager" },
  5: { traits: "Adaptable, curious, freedom-seeking",         career: "Travel, sales, consulting" },
  6: { traits: "Responsible, nurturing, devoted",             career: "Teacher, healer, community work" },
  7: { traits: "Perceptive, private, truth-seeking",          career: "Research, analysis, philosophy" },
  8: { traits: "Ambitious, authoritative, results-driven",    career: "Business, finance, leadership" },
  9: { traits: "Compassionate, idealistic, here to serve",    career: "Non-profit, arts, education" },
};

const coreNumbers = expressionNumbers.filter(e => e.n <= 9);
const masterNumbers = expressionNumbers.filter(e => e.n > 9);
---

<Layout
  title="Expression Number in Numerology - What It Means & How to Calculate Yours"
  description="Your expression number reveals the direction your destiny is pulling you - the qualities you're here to develop and express. Find yours and explore all 12 expression numbers."
>

  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" />

  <style>
    :root { --font-family-heading: 'Cormorant Garamond', Georgia, serif; }
    .p-label { font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-soft-gold); font-weight:600; }
    .p-divider { width:48px; height:2px; background:var(--color-soft-gold); margin:0 auto; }
    .section-h2 { font-family:var(--font-family-heading); font-size:clamp(1.6rem,3.5vw,2.25rem); font-weight:700; color:var(--color-body-text); margin:0 0 1.25rem; }
    .faq-list details { border-top:1px solid var(--color-border); }
    .faq-list details:last-child { border-bottom:1px solid var(--color-border); }
    .faq-list summary { padding:1.3rem 0; cursor:pointer; display:flex; align-items:center; justify-content:space-between; gap:1rem; font-weight:600; font-size:1rem; color:var(--color-body-text); list-style:none; transition:color 0.2s; }
    .faq-list summary::-webkit-details-marker { display:none; }
    .faq-list details[open] summary { color:var(--color-violet); }
    .faq-chevron { flex-shrink:0; transition:transform 0.25s; }
    .faq-list details[open] .faq-chevron { transform:rotate(180deg); }
    .faq-answer { padding-bottom:1.3rem; font-size:0.9rem; color:var(--color-muted-text); line-height:1.8; }
  </style>

  <!-- Breadcrumb -->
  <nav style="background:var(--color-card-bg);border-bottom:1px solid var(--color-border);padding:0.75rem 1.5rem;" aria-label="Breadcrumb">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:0.5rem;font-size:0.75rem;color:var(--color-muted-text);">
      <a href="/" style="color:var(--color-muted-text);text-decoration:none;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Home</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/" style="color:var(--color-muted-text);text-decoration:none;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Learn</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <span style="color:var(--color-body-text);font-weight:600;">Expression Numbers</span>
    </div>
  </nav>

  <!-- Hero -->
  <section style="position:relative;overflow:hidden;padding:6rem 1.5rem 5rem;text-align:center;min-height:480px;display:flex;align-items:center;">
    <div style="position:absolute;inset:0;z-index:0;">
      <img
        src="/images/learn/Expression Numbers Pillar Hero.webp"
        alt=""
        aria-hidden="true"
        fetchpriority="high"
        style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;"
      />
      <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(14,10,26,0.75) 0%, rgba(14,10,26,0.58) 45%, rgba(14,10,26,0.80) 100%);"></div>
      <div style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(196,162,78,0.08) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;"></div>
    </div>
    <div aria-hidden="true" style="position:absolute;left:-1rem;top:0.5rem;z-index:1;font-family:var(--font-family-heading);font-size:clamp(10rem,20vw,16rem);font-weight:700;line-height:1;color:transparent;-webkit-text-stroke:1px rgba(196,162,78,0.18);pointer-events:none;user-select:none;">E</div>
    <div aria-hidden="true" style="position:absolute;right:-0.5rem;bottom:-1.5rem;z-index:1;font-family:var(--font-family-heading);font-size:clamp(12rem,24vw,20rem);font-weight:700;line-height:1;color:transparent;-webkit-text-stroke:1px rgba(124,92,191,0.15);pointer-events:none;user-select:none;">N</div>
    <div style="position:relative;z-index:2;max-width:760px;margin:0 auto;width:100%;">
      <p class="p-label" style="margin-bottom:1.25rem;color:var(--color-soft-gold);opacity:0.9;">Core Chart Numbers</p>
      <div class="p-divider" style="margin-bottom:1.75rem;"></div>
      <h1 style="font-family:var(--font-family-heading);font-size:clamp(2.6rem,6.5vw,4.75rem);font-weight:700;line-height:1.08;color:#f5f0e8;letter-spacing:-0.02em;margin:0 0 1.5rem;text-shadow:0 2px 20px rgba(14,10,26,0.6);">
        Expression Number in<br><em style="color:#c8a8f0;font-style:italic;">Numerology</em>
      </h1>
      <p style="font-size:1.05rem;line-height:1.8;color:rgba(240,234,255,0.82);max-width:560px;margin:0 auto 2.5rem;text-shadow:0 1px 8px rgba(14,10,26,0.5);">
        Calculated from your full birth name, your expression number reveals the direction your destiny is pulling you — the qualities you're here to develop and express.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:0.875rem;justify-content:center;">
        <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:1rem;padding:0.875rem 2rem;border-radius:6px;text-decoration:none;transition:background 0.2s,transform 0.15s;box-shadow:0 4px 20px rgba(124,92,191,0.45);" onmouseover="this.style.background='#6a4eab';this.style.transform='translateY(-1px)'" onmouseout="this.style.background='var(--color-violet)';this.style.transform='none'">Get My Free Reading →</a>
        <a href="#all-numbers" style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.1);backdrop-filter:blur(6px);color:#f5f0e8;font-weight:600;font-size:1rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.25);transition:border-color 0.2s,background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.18)';this.style.borderColor='rgba(255,255,255,0.45)'" onmouseout="this.style.background='rgba(255,255,255,0.1)';this.style.borderColor='rgba(255,255,255,0.25)'">Find My Number ↓</a>
      </div>
    </div>
  </section>

  <!-- Author byline -->
  <div style="background:var(--color-light-bg);padding:1.5rem 1.5rem;">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:1rem;">
      <img src="/images/author-maddi-green.webp" alt="Maddie Greene" style="width:3rem;height:3rem;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid rgba(124,92,191,0.2);box-shadow:0 2px 8px rgba(26,21,40,0.08);" />
      <div>
        <p style="color:var(--color-body-text);font-size:0.9rem;font-weight:600;margin:0 0 0.15rem;">Written by <strong>Maddie Greene</strong></p>
        <p style="color:var(--color-muted-text);font-size:0.8rem;margin:0;">Numerology writer &amp; researcher</p>
      </div>
    </div>
  </div>

  <!-- Content + Sticky sidebar wrapper -->
  <div class="xl:flex xl:gap-6 xl:max-w-[1200px] xl:mx-auto xl:px-4">
    <!-- Main content column -->
    <div class="xl:flex-1 xl:min-w-0">

  <!-- What is the expression number -->
  <section style="padding:3.5rem 1.5rem 3.5rem;background:var(--color-card-bg);">
    <div class="max-w-3xl mx-auto xl:mx-0 xl:max-w-none">
      <h2 class="section-h2">What is the expression number?</h2>
      <p style="font-size:1rem;line-height:1.8;color:var(--color-muted-text);margin:0 0 1.25rem;">
        In Pythagorean numerology, your chart is built from two primary sources: your date of birth and your birth name. The birth date gives you your life path number — the terrain of your life. The birth name gives you your expression number — the direction you're meant to travel through it.
      </p>
      <p style="font-size:1rem;line-height:1.8;color:var(--color-muted-text);margin:0 0 1.25rem;">
        It's sometimes called the destiny number, and that framing is useful. It doesn't describe what will happen to you. It describes what you're here to do and become. The expression number captures the qualities your life is asking you to develop and express — the skills and orientations that, when you're working with them rather than against them, make your life feel like it actually fits.
      </p>
      <p style="font-size:1rem;line-height:1.8;color:var(--color-muted-text);margin:0 0 1.5rem;">
        The reason it's called the expression number is that these qualities want to come out. Suppressing them doesn't make them go away — it just creates friction between who you're being and who you're built to be.
      </p>
    </div>
  </section>

  <!-- How to calculate -->
  <section style="padding:4rem 1.5rem;background:var(--color-light-bg);border-top:1px solid var(--color-border);">
    <div class="max-w-3xl mx-auto xl:mx-0 xl:max-w-none">
      <h2 class="section-h2">How to calculate your expression number</h2>
      <p style="font-size:1rem;line-height:1.8;color:var(--color-muted-text);margin:0 0 1.5rem;">
        Use your full birth name — exactly as it appears on your birth certificate, including any middle names. Assign each letter a number using the Pythagorean chart below. Add all the letter values together and reduce to a single digit. If the total is 11, 22, or 33, stop — those are master numbers and aren't reduced further.
      </p>

      <div style="background:var(--color-card-bg);border:1px solid var(--color-border);border-radius:8px;padding:1.5rem;margin-bottom:1.5rem;">
        <h3 style="font-family:var(--font-family-heading);font-weight:700;color:var(--color-body-text);margin:0 0 1rem;font-size:1.05rem;">Pythagorean Number Chart</h3>
        <div class="grid grid-cols-9 gap-1 text-center text-sm">
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">1</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">2</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">3</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">4</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">5</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">6</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">7</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">8</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">9</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">A</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">B</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">C</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">D</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">E</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">F</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">G</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">H</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">I</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">J</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">K</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">L</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">M</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">N</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">O</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">P</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">Q</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">R</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">S</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">T</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">U</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">V</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">W</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">X</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">Y</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">Z</div>
          <div></div><div></div><div></div><div></div><div></div><div></div>
        </div>
      </div>

      <div style="background:var(--color-card-bg);border:1px solid var(--color-border);border-left:4px solid var(--color-violet);border-radius:8px;padding:1.5rem;">
        <h3 style="font-family:var(--font-family-heading);font-weight:700;color:var(--color-body-text);margin:0 0 0.75rem;font-size:1.05rem;">Worked example: Amy Lee Jones</h3>
        <div style="font-size:0.875rem;color:var(--color-muted-text);display:flex;flex-direction:column;gap:0.5rem;">
          <p style="margin:0;"><strong style="color:var(--color-body-text);">AMY:</strong> A(1) + M(4) + Y(7) = 12 → 1+2 = <strong style="color:var(--color-violet);">3</strong></p>
          <p style="margin:0;"><strong style="color:var(--color-body-text);">LEE:</strong> L(3) + E(5) + E(5) = 13 → 1+3 = <strong style="color:var(--color-violet);">4</strong></p>
          <p style="margin:0;"><strong style="color:var(--color-body-text);">JONES:</strong> J(1) + O(6) + N(5) + E(5) + S(1) = 18 → 1+8 = <strong style="color:var(--color-violet);">9</strong></p>
          <p style="margin:0.5rem 0 0;padding-top:0.5rem;border-top:1px solid var(--color-border);"><strong style="color:var(--color-body-text);">Total:</strong> 3 + 4 + 9 = 16 → 1+6 = <strong style="color:var(--color-violet);font-size:1rem;">Expression Number 7</strong></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Expression vs life path -->
  <section style="padding:4rem 1.5rem;background:var(--color-card-bg);border-top:1px solid var(--color-border);">
    <div class="max-w-3xl mx-auto xl:mx-0 xl:max-w-none">
      <h2 class="section-h2">Expression number vs life path number</h2>
      <p style="font-size:1rem;line-height:1.8;color:var(--color-muted-text);margin:0 0 1.25rem;">
        People often ask which number matters more — the life path or the expression number. Both matter, and they're describing different things.
      </p>
      <p style="font-size:1rem;line-height:1.8;color:var(--color-muted-text);margin:0 0 1.25rem;">
        Your life path number comes from your birth date. It describes the energy and conditions you were born into — the terrain your life is moving through. Your expression number comes from your name. It describes the direction you're meant to move through that terrain, and the qualities you're here to develop.
      </p>
      <p style="font-size:1rem;line-height:1.8;color:var(--color-muted-text);margin:0 0 2rem;">
        If your life path is the road, your expression number is the vehicle. When they work together — when your life path energy and your expression number are pointing in compatible directions — your life tends to feel like it makes sense. When they pull against each other, there's usually some interesting friction to work with.
      </p>
      <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:0.95rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;transition:background 0.2s;" onmouseover="this.style.background='#6a4eab'" onmouseout="this.style.background='var(--color-violet)'">
        Get Your Free Reading →
      </a>
    </div>
  </section>

  <!-- All expression numbers grid -->
  <section id="all-numbers" style="padding:5rem 1.5rem;background:var(--color-light-bg);border-top:1px solid var(--color-border);">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p class="p-label" style="margin-bottom:0.75rem;">All Expression Numbers</p>
        <h2 style="font-family:var(--font-family-heading);font-size:clamp(1.75rem,4vw,2.75rem);font-weight:700;color:var(--color-body-text);margin:0 0 0.75rem;">Find Your Expression Number</h2>
        <div class="p-divider" style="margin:0 auto;"></div>
        <p style="color:var(--color-muted-text);margin-top:1rem;max-width:560px;margin-left:auto;margin-right:auto;font-size:0.95rem;line-height:1.7;">Select your number to explore what it means for your destiny, your personality, your career, and how you're meant to show up in the world.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-14">
        {coreNumbers.map(en => {
          const meta = enMeta[en.n];
          const topStrength = en.strengths[0]?.title ?? '';
          const topChallenge = en.challenges[0]?.title ?? '';
          return (
            <a href={`/learn/expression-number/${en.n}/`} class="card-light group block overflow-hidden hover:border-violet/60 hover:-translate-y-1 transition-all duration-200" style="text-decoration:none;">
              <div style="position:relative;overflow:hidden;">
                <img
                  src={`/images/learn/expression-numbers/Expression Number - ${en.title}.webp`}
                  alt={`Expression number ${en.n} - ${en.title}`}
                  class="w-full group-hover:scale-105 transition-transform duration-500"
                  style="aspect-ratio:2/3;object-fit:cover;display:block;width:100%;"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div style="padding:1.25rem;">
                <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--color-muted-text);margin-bottom:0.2rem;">Expression {en.n}</div>
                <div style="font-weight:700;color:var(--color-body-text);font-size:1.1rem;margin-bottom:0.5rem;" class="group-hover:text-violet transition-colors">{en.title}</div>
                <p style="font-size:0.875rem;color:var(--color-muted-text);margin:0 0 1rem;line-height:1.6;">{meta.traits}</p>
                <div style="display:flex;flex-direction:column;gap:0.35rem;font-size:0.8rem;margin-bottom:1rem;">
                  <div style="display:flex;gap:0.5rem;">
                    <span style="color:#4a9e5c;font-weight:600;width:5rem;flex-shrink:0;">Strength:</span>
                    <span style="color:var(--color-muted-text);">{topStrength}</span>
                  </div>
                  <div style="display:flex;gap:0.5rem;">
                    <span style="color:#c0444a;font-weight:600;width:5rem;flex-shrink:0;">Challenge:</span>
                    <span style="color:var(--color-muted-text);">{topChallenge}</span>
                  </div>
                  <div style="display:flex;gap:0.5rem;">
                    <span style="color:var(--color-violet);font-weight:600;width:5rem;flex-shrink:0;">Career:</span>
                    <span style="color:var(--color-muted-text);">{meta.career}</span>
                  </div>
                </div>
                <span style="font-size:0.875rem;font-weight:600;color:var(--color-violet);" class="group-hover:text-soft-violet transition-colors">Full {en.n} guide →</span>
              </div>
            </a>
          );
        })}
      </div>

      <!-- Master numbers -->
      <div style="padding-top:3rem;border-top:1px solid var(--color-border);">
        <div style="text-align:center;margin-bottom:2.5rem;">
          <p class="p-label" style="margin-bottom:0.75rem;">Special Vibrations</p>
          <h2 style="font-family:var(--font-family-heading);font-size:clamp(1.5rem,3vw,2rem);font-weight:700;color:var(--color-body-text);margin:0 0 0.75rem;">Master Expression Numbers</h2>
          <div class="p-divider" style="margin:0 auto;"></div>
          <p style="color:var(--color-muted-text);margin-top:1rem;max-width:520px;margin-left:auto;margin-right:auto;font-size:0.9rem;line-height:1.7;">Master numbers carry a higher-frequency version of the base number's energy. They're never reduced further — and they come with a greater call and a greater challenge.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {masterNumbers.map(en => (
            <a href={`/learn/expression-number/${en.n}/`} class="card-light group block overflow-hidden hover:border-violet/60 hover:-translate-y-1 transition-all duration-200" style="text-decoration:none;border-color:rgba(124,92,191,0.2);">
              <div style="position:relative;overflow:hidden;">
                <img
                  src={`/images/learn/expression-numbers/Expression Number - ${en.title}.webp`}
                  alt={`Expression number ${en.n} - ${en.title}`}
                  class="w-full group-hover:scale-105 transition-transform duration-500"
                  style="aspect-ratio:2/3;object-fit:cover;display:block;width:100%;"
                  loading="lazy"
                  decoding="async"
                />

---
import Layout from '../../layouts/Layout.astro';
import SidebarCTA from '../../components/SidebarCTA.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://numerologyguides.blog"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Calculator",
      "item": "https://numerologyguides.blog/calculator/"
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the difference between Life Path Number and Expression Number?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your Life Path Number comes from your birth date and shows the overall theme and direction of your life. Your Expression Number comes from your full name at birth and reveals your natural talents, gifts, and how you express yourself in the world. Think of it this way: Life Path is the terrain you're walking, Expression is how you walk it."
      }
    },
    {
      "@type": "Question",
      "name": "Why aren't master numbers 11, 22, and 33 reduced further?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Master numbers carry amplified energy and special significance in numerology. They're not reduced because that amplification is the whole point. An 11 isn't a 2-it's an elevated, intensified 1+1 energy. Same with 22 and 33. The only exception: if your Birthday Number, Soul Urge, or Personality Number is a master number, it stays as is. But if it's something like 47, that reduces to 4+7=11, which then stays as 11."
      }
    },
    {
      "@type": "Question",
      "name": "What do the five numbers in this calculator actually tell me?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your five core numbers paint a complete numerological picture. Life Path shows your overall direction. Expression shows your gifts and natural abilities. Soul Urge reveals your deepest wants and emotional core. Personality shows how others perceive you and how you show up publicly. Birthday Number gives you insight into your specific strengths and the energy of the day you were born."
      }
    },
    {
      "@type": "Question",
      "name": "Can I have a Life Path Number of 0?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Life Path Numbers range from 1 to 9, plus the master numbers 11, 22, and 33. If you're getting 0, you've left out a step in the reduction. Make sure you're reducing each digit: 1+0 = 1, not 10 left as-is."
      }
    },
    {
      "@type": "Question",
      "name": "What if my name is hyphenated or has a special spelling?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Use your full name exactly as it appears on your birth certificate. That's the name that carries the energy your parents (or the universe) intended for you. Hyphens, apostrophes, and spaces don't count-only the actual letters do. So if your name is Anne-Marie, you'd use A-N-N-E-M-A-R-I-E."
      }
    },
    {
      "@type": "Question",
      "name": "Should I use my birth name or the name I go by now?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Always use your birth name for Life Path and all the five core numbers in this calculator. Your birth name carries the vibration that corresponds to the energy of the moment you were born. If you've legally changed your name later in life, that's a separate numerological story-and it creates a Destiny Number worth exploring separately. But your five core numbers always come from your original birth name and date."
      }
    }
  ]
};

---
import Layout from '../../../layouts/Layout.astro';
import SidebarCTA from '../../../components/SidebarCTA.astro';
import { personalityNumbers } from '../../../data/personalityNumbers';

export function getStaticPaths() {
  return personalityNumbers.map(pn => ({
    params: { n: String(pn.n) },
    props: { pn },
  }));
}

const { pn } = Astro.props;

function relatedHref(n: string): string {
  if (n.startsWith('life-path-number')) return `/learn/${n}/`;
  if (n.startsWith('soul-urge-')) return `/learn/soul-urge-number/${n.replace('soul-urge-', '')}/`;
  if (n.startsWith('expression-')) return `/learn/expression-number/${n.replace('expression-', '')}/`;
  return `/learn/personality-number/${n}/`;
}

function relatedImg(n: string): string {
  if (n.startsWith('life-path-number')) return '/images/learn/Life Path Numbers.webp';
  if (n.startsWith('soul-urge-')) return '/images/learn/Soul Urge Numbers.webp';
  if (n.startsWith('expression-')) return '/images/learn/Expression Numbers.webp';
  return '/images/learn/Personality Numbers Guide.webp';
}

const allNumbers = personalityNumbers.map(p => ({ n: String(p.n), label: p.title }));

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": pn.faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a.join(" ") }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://numerologyguides.blog/" },
    { "@type": "ListItem", "position": 2, "name": "Learn", "item": "https://numerologyguides.blog/learn/" },
    { "@type": "ListItem", "position": 3, "name": "Personality Numbers", "item": "https://numerologyguides.blog/learn/personality-number/" },
    { "@type": "ListItem", "position": 4, "name": `Personality Number ${pn.n}` }
  ]
};
---

<Layout
  schema={[faqSchema, breadcrumbSchema]}
  title={`Personality Number ${pn.n}: How Others See You vs. Who You Really Are | Numerology Guides`}
  description={pn.shortDesc}
>

  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" />

  <style>
    :root { --font-family-heading: 'Cormorant Garamond', Georgia, serif; }
    .p-label { font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-soft-gold); font-weight:600; }
    .p-divider { width:48px; height:2px; background:var(--color-soft-gold); margin:0 auto; }
    .section-h2 { font-family:var(--font-family-heading); font-size:clamp(1.6rem,3.5vw,2.25rem); font-weight:700; color:var(--color-body-text); margin:0 0 1.25rem; }
    .faq-list details { border-top:1px solid var(--color-border); }
    .faq-list details:last-child { border-bottom:1px solid var(--color-border); }
    .faq-list summary { padding:1.3rem 0; cursor:pointer; display:flex; align-items:center; justify-content:space-between; gap:1rem; font-weight:600; font-size:1rem; color:var(--color-body-text); list-style:none; transition:color 0.2s; }
    .faq-list summary::-webkit-details-marker { display:none; }
    .faq-list details[open] summary { color:var(--color-violet); }
    .faq-chevron { flex-shrink:0; transition:transform 0.25s; }
    .faq-list details[open] .faq-chevron { transform:rotate(180deg); }
    .faq-answer { padding-bottom:1.3rem; font-size:0.9rem; color:var(--color-muted-text); line-height:1.8; }
  </style>

  <!-- Breadcrumb -->
  <nav style="background:var(--color-card-bg);border-bottom:1px solid var(--color-border);padding:0.75rem 1.5rem;" aria-label="Breadcrumb">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:0.5rem;font-size:0.75rem;color:var(--color-muted-text);">
      <a href="/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Home</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Learn</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/personality-number/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Personality Numbers</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <span style="color:var(--color-body-text);font-weight:600;">Personality {pn.n}</span>
    </div>
  </nav>

  <!-- Hero -->
  <section style="position:relative;overflow:hidden;background:var(--color-midnight,#0e0a1a);">
    <div aria-hidden="true" style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(196,162,78,0.07) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>
    <div aria-hidden="true" style="position:absolute;top:-10%;left:-5%;width:55%;height:120%;background:radial-gradient(ellipse at center,rgba(124,92,191,0.18) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>
    <div style="position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:4rem 1.5rem;display:flex;align-items:center;gap:3rem;flex-wrap:wrap;">
      <div style="flex:1;min-width:280px;">
        <p class="p-label" style="margin-bottom:1.1rem;color:var(--color-soft-gold);opacity:0.9;">Personality Number {pn.n}</p>
        <div class="p-divider" style="margin:0 0 1.6rem;"></div>
        <h1 style="font-family:var(--font-family-heading);font-size:clamp(2.8rem,6vw,5rem);font-weight:700;line-height:1.06;color:#f5f0e8;letter-spacing:-0.02em;margin:0 0 1.25rem;">
          The <em style="color:#c8a8f0;font-style:italic;">{pn.title.replace('The ', '')}</em>
        </h1>
        <p style="font-size:1.05rem;line-height:1.8;color:rgba(240,234,255,0.78);max-width:460px;margin:0 0 2rem;">{pn.heroSubtitle}</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.875rem;">
          <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:1rem;padding:0.875rem 2rem;border-radius:6px;text-decoration:none;transition:background 0.2s,transform 0.15s;box-shadow:0 4px 20px rgba(124,92,191,0.45);" onmouseover="this.style.background='#6a4eab';this.style.transform='translateY(-1px)'" onmouseout="this.style.background='var(--color-violet)';this.style.transform='none'">Get My Free Reading →</a>
          <a href="#meaning" style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.08);backdrop-filter:blur(6px);color:#f5f0e8;font-weight:600;font-size:1rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.2);transition:border-color 0.2s,background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)';this.style.borderColor='rgba(255,255,255,0.4)'" onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.borderColor='rgba(255,255,255,0.2)'">What It Means ↓</a>
        </div>
      </div>
      <div style="flex-shrink:0;width:clamp(200px,28vw,300px);filter:drop-shadow(0 8px 40px rgba(196,162,78,0.25)) drop-shadow(0 2px 12px rgba(0,0,0,0.6));">
        <img
          src={`/images/learn/personality-numbers/Personality Number - ${pn.title}.webp`}
          alt={`Personality Number ${pn.n}, ${pn.title}`}
          fetchpriority="high"
          style="width:100%;border-radius:6px;display:block;"
        />
      </div>
    </div>
  </section>

  <!-- Author byline -->
  <div style="background:var(--color-card-bg);padding:1.75rem 1.5rem;border-bottom:1px solid var(--color-border);">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:1rem;">
      <img src="/images/author-maddi-green.webp" alt="Maddie Greene" style="width:3.25rem;height:3.25rem;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid var(--color-border);" />
      <div>
        <p style="margin:0;font-size:0.95rem;font-weight:600;color:var(--color-body-text);">Written by <strong>Maddie Greene</strong></p>
        <p style="margin:0;font-size:0.8rem;color:var(--color-muted-text);">Numerology writer &amp; researcher</p>
      </div>
    </div>
  </div>

  <!-- Content + Sticky sidebar wrapper -->
  <div class="xl:flex xl:gap-6 xl:max-w-[1200px] xl:mx-auto xl:px-4">
    <!-- Main content column -->
    <div class="xl:flex-1 xl:min-w-0">

  <!-- What does PN[n] mean -->
  <section id="meaning" style="padding:3.5rem 1.5rem;background:var(--color-light-bg);">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">What personality number {pn.n} means</h2>
      <div style="display:flex;flex-direction:column;gap:1rem;">
        {pn.meaning.map(para => <p style="color:var(--color-body-text);line-height:1.8;margin:0;">{para}</p>)}
      </div>
    </div>
  </section>

  <!-- First impression -->
  <section id="impression" style="padding:3.5rem 1.5rem;background:var(--color-card-bg);">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">The first impression personality {pn.n} makes</h2>
      <div style="display:flex;flex-direction:column;gap:1rem;">
        {pn.firstImpression.map(para => <p style="color:var(--color-body-text);line-height:1.8;margin:0;">{para}</p>)}
      </div>
    </div>
  </section>

  <!-- Strengths & challenges -->
  <section id="strengths" style="padding:3.5rem 1.5rem;background:var(--color-light-bg);">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">Strengths &amp; challenges</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2rem;">
        <div>
          <h3 style="font-family:var(--font-family-heading);font-size:1.1rem;font-weight:700;color:var(--color-body-text);margin:0 0 1rem;display:flex;align-items:center;gap:0.5rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" style="color:#4ade80;flex-shrink:0;" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            What works for you
          </h3>
          <div style="display:flex;flex-direction:column;gap:0.75rem;">
            {pn.strengths.map(s => (
              <div style="background:var(--color-card-bg);border:1px solid var(--color-border);border-radius:8px;padding:1.1rem 1.25rem;">
                <div style="font-weight:600;color:var(--color-body-text);margin-bottom:0.3rem;font-size:0.95rem;">{s.title}</div>
                <p style="margin:0;font-size:0.875rem;color:var(--color-muted-text);line-height:1.7;">{s.desc}</p>
              </div>
            ))}
          </div>
        </div>
        <div>
          <h3 style="font-family:var(--font-family-heading);font-size:1.1rem;font-weight:700;color:var(--color-body-text);margin:0 0 1rem;display:flex;align-items:center;gap:0.5rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#f87171;flex-shrink:0;" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            What to watch
          </h3>
          <div style="display:flex;flex-direction:column;gap:0.75rem;">
            {pn.challenges.map(c => (
              <div style="background:var(--color-card-bg);border:1px solid var(--color-border);border-radius:8px;padding:1.1rem 1.25rem;">
                <div style="font-weight:600;color:var(--color-body-text);margin-bottom:0.3rem;font-size:0.95rem;">{c.title}</div>
                <p style="margin:0;font-size:0.875rem;color:var(--color-muted-text);line-height:1.7;">{c.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Style & presence -->
  <section id="style" style="padding:3.5rem 1.5rem;background:var(--color-card-bg);">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">Style &amp; presence</h2>
      <div style="display:flex;flex-direction:column;gap:1rem;">
        {pn.style.map(para => <p style="color:var(--color-body-text);line-height:1.8;margin:0;">{para}</p>)}
      </div>
    </div>
  </section>

  <!-- How to calculate -->
  <section id="calculate" style="padding:3.5rem 1.5rem;background:var(--color-light-bg);">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">How to calculate your personality number</h2>
      <p style="color:var(--color-body-text);line-height:1.8;margin:0 0 1.5rem;">
        Your personality number comes from the consonants in your full birth name, every letter that isn't A, E, I, O, or U. Assign each consonant its Pythagorean value, add the totals, and reduce to a single digit. Unlike expression and soul urge numbers, personality numbers don't produce master numbers.
      </p>
      <div style="background:var(--color-card-bg);border:1px solid var(--color-border);border-radius:10px;padding:1.5rem;margin-bottom:1.5rem;overflow-x:auto;">
        <div style="display:grid;grid-template-columns:repeat(9,1fr);gap:0.25rem;text-align:center;font-size:0.85rem;min-width:420px;">
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">1</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">2</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">3</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">4</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">5</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">6</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">7</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">8</div>
          <div style="font-weight:700;color:var(--color-violet);padding:0.5rem 0;">9</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">J,S</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">B,K,T</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">C,L</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">D,M,V</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">F,N,W</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">G,X</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">H,P,Y</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">Q,Z</div>
          <div style="color:var(--color-muted-text);padding:0.25rem 0;">R</div>
        </div>
      </div>
      <p style="color:var(--color-muted-text);font-size:0.875rem;line-height:1.7;margin:0 0 1.5rem;">A free reading from Numerologist.com calculates your full chart, including your personality number, soul urge, expression, and life path together.</p>
      <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-block;padding:0.75rem 1.75rem;background:var(--color-soft-gold);color:#1a1200;border-radius:6px;font-size:0.95rem;font-weight:700;text-decoration:none;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.88'" onmouseout="this.style.opacity='1'">Get Your Free Numerology Reading</a>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" style="padding:3.5rem 1.5rem;background:var(--color-card-bg);">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">Common questions</h2>
      <div class="faq-list">
        {pn.faq.map(item => (
          <details>
            <summary>
              <span>{item.q}</span>
              <svg class="faq-chevron" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-answer">
              {item.a.map(para => <p style="margin:0 0 0.6rem;">{para}</p>)}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- All personality numbers -->
  <section id="all" style="padding:3.5rem 1.5rem;background:var(--color-light-bg);">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">All personality numbers</h2>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.65rem;">
        {allNumbers.map(num => (
          <a
            href={`/learn/personality-number/${num.n}/`}
            style={num.n === String(pn.n)
              ? "display:block;padding:0.75rem 0.5rem;text-align:center;border-radius:8px;border:2px solid var(--color-soft-gold);background:rgba(196,162,78,0.08);text-decoration:none;transition:all 0.2s;"
              : "display:block;padding:0.75rem 0.5rem;text-align:center;border-radius:8px;border:1.5px solid var(--color-border);background:var(--color-card-bg);text-decoration:none;transition:all 0.2s;"}
            onmouseover={num.n !== String(pn.n) ? "this.style.borderColor='var(--color-violet)';this.style.background='rgba(124,58,237,0.05)'" : ""}
            onmouseout={num.n !== String(pn.n) ? "this.style.borderColor='var(--color-border)';this.style.background='var(--color-card-bg)'" : ""}
          >
            <div style={num.n === String(pn.n)
              ? "font-family:var(--font-family-heading);font-size:1.4rem;font-weight:700;color:var(--color-soft-gold);line-height:1;"
              : "font-family:var(--font-family-heading);font-size:1.4rem;font-weight:700;color:var(--color-body-text);line-height:1;"}>
              {num.n}
            </div>
            <div style="font-size:0.7rem;margin-top:0.3rem;color:var(--color-muted-text);">{num.label.replace('The ', '')}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Related guides -->
  {pn.related.length > 0 && (
    <section style="padding:3.5rem 1.5rem;background:var(--color-card-bg);border-top:1px solid var(--color-border);">
      <div style="max-width:760px;margin:0 auto;">
        <h2 class="section-h2">Related guides</h2>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
          {pn.related.map(rel => (
            <a href={relatedHref(rel.n)} class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block" style="text-decoration:none;">
              <img src={relatedImg(rel.n)} alt={rel.label} class="w-full aspect-[2/3] object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
              <div style="padding:1rem;">
                <div style="font-weight:700;color:var(--color-body-text);margin-bottom:0.35rem;" class="group-hover:text-violet transition-colors">{rel.label}</div>
                <p style="font-size:0.8rem;color:var(--color-muted-text);margin:0;">{rel.note}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

    </div><!-- end main content column -->
    <SidebarCTA />
  </div><!-- end flex wrapper -->

  <!-- Bottom CTA -->
  <section style="padding:5rem 1.5rem;background:#0e0a1a;text-align:center;">
    <div style="max-width:640px;margin:0 auto;">
      <p class="p-label" style="margin-bottom:1rem;">Go Deeper</p>
      <div class="p-divider" style="margin-bottom:1.5rem;"></div>
      <h2 style="font-family:var(--font-family-heading);font-size:clamp(1.8rem,4vw,2.5rem);font-weight:700;color:#fff;margin:0 0 1.25rem;line-height:1.2;">See how your numbers interact</h2>
      <p style="color:rgba(240,235,255,0.65);line-height:1.8;margin:0 0 2rem;">
        Your personality number is the outer layer. Your full chart shows how it relates to your inner motivations, your destiny direction, and your life path. A free reading from Numerologist.com brings the complete picture together.
      </p>
      <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-block;padding:0.9rem 2.25rem;background:var(--color-soft-gold);color:#1a1200;border-radius:6px;font-size:1.05rem;font-weight:700;text-decoration:none;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.88'" onmouseout="this.style.opacity='1'">Get Your Free Numerology Reading</a>
    </div>
  </section>

</Layout>

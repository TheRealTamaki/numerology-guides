---
import Layout from '../../../layouts/Layout.astro';
import SidebarCTA from '../../../components/SidebarCTA.astro';
import { allNumbers, lifePathTraits, getAllPairs, getCompatibility, matchToStars, pairDetails } from '../../../data/compatibility';

export function getStaticPaths() {
  const paths: { params: { pair: string } }[] = [];
  // All unique pairs where a < b numerically
  for (let i = 0; i < allNumbers.length; i++) {
    for (let j = i + 1; j < allNumbers.length; j++) {
      paths.push({ params: { pair: `${allNumbers[i]}-and-${allNumbers[j]}` } });
    }
  }
  // Same-number pairs
  for (const n of allNumbers) {
    paths.push({ params: { pair: `${n}-and-${n}` } });
  }
  return paths;
}

const { pair } = Astro.params;
const parts = pair!.split('-and-');
const numA = parts[0];
const numB = parts[1];
const traitsA = lifePathTraits[numA];
const traitsB = lifePathTraits[numB];
const compat = getCompatibility(numA, numB)!;
const stars = matchToStars(compat.match);
const details = pairDetails[pair!];

// Match level display
const matchLabel = compat.match === 'strong' ? 'Strong Match' : compat.match === 'good' ? 'Good Match' : 'Challenging Match';
const matchColor = compat.match === 'strong' ? '#16a34a' : compat.match === 'good' ? 'var(--color-soft-gold)' : '#e11d48';
const matchBorderColor = compat.match === 'strong' ? 'rgba(22,163,74,0.25)' : compat.match === 'good' ? 'rgba(196,162,78,0.35)' : 'rgba(225,29,72,0.25)';
const matchBg = compat.match === 'strong' ? 'rgba(22,163,74,0.05)' : compat.match === 'good' ? 'rgba(196,162,78,0.07)' : 'rgba(225,29,72,0.05)';

// Related pairs: other pairs involving these numbers
const allPairSlugs = getAllPairs();
const relatedPairs = allPairSlugs
  .filter(p => p.slug !== pair && p.a !== p.b && (p.a === numA || p.b === numA || p.a === numB || p.b === numB))
  .slice(0, 4);

// FAQ for this specific pair
const isSame = numA === numB;
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Are life path ${numA} and ${numB} compatible?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Life path ${numA} and ${numB} have a ${compat.match} compatibility rating. ${compat.description} This doesn't mean the relationship is predetermined, it means this is the energy dynamic you're working with. Awareness of these patterns helps you navigate them intentionally.`
      }
    },
    {
      "@type": "Question",
      "name": `Can life path ${numA} and ${numB} have a good relationship?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Yes. Every life path pairing can have a successful relationship. ${compat.match === 'challenging' ? `A ${numA} and ${numB} pairing requires more awareness and intentional effort, but the growth potential is significant. The friction between these numbers often creates the strongest personal development.` : `A ${numA} and ${numB} pairing has natural strengths to build on. The key is understanding where the energy flows easily and where you'll need to pay more attention.`}`
      }
    },
    {
      "@type": "Question",
      "name": `What are the biggest challenges for life path ${numA} and ${numB}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${isSame ? `Two ${numA}s share the same strengths and the same blind spots. The challenge is that neither person compensates for the other's weaknesses. You'll need to consciously develop the qualities that your shared number naturally lacks.` : `The main tension between ${numA} (${traitsA.title}) and ${numB} (${traitsB.title}) comes from their different approaches to life. ${traitsA.challenge} Meanwhile, ${traitsB.challenge} Understanding these patterns helps you work with them instead of against them.`}`
      }
    },
    {
      "@type": "Question",
      "name": `What makes life path ${numA} and ${numB} work well together?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${isSame ? `Two ${numA}s understand each other deeply because they share the same core energy. There's an immediate recognition. You don't have to explain yourself. The pairing works best when both people develop different areas of expertise so you complement rather than duplicate each other.` : `${numA} (${traitsA.title}) brings ${traitsA.coreTraits.join(', ').toLowerCase()} energy. ${numB} (${traitsB.title}) brings ${traitsB.coreTraits.join(', ').toLowerCase()} energy. When these combine well, each person fills in what the other lacks, creating a more complete partnership than either could build alone.`}`
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://numerologyguides.blog/" },
    { "@type": "ListItem", "position": 2, "name": "Learn", "item": "https://numerologyguides.blog/learn/" },
    { "@type": "ListItem", "position": 3, "name": "Life Path Compatibility", "item": "https://numerologyguides.blog/learn/life-path-compatibility/" },
    { "@type": "ListItem", "position": 4, "name": `LP ${numA} & LP ${numB}` }
  ]
};

const pageTitle = isSame
  ? `Two Life Path ${numA}s: Compatibility Guide | Numerology Guides`
  : `Life Path ${numA} and ${numB} Compatibility: ${compat.verdict} | Numerology Guides`;
const pageDesc = isSame
  ? `What happens when two life path ${numA}s get together? Full compatibility breakdown for ${numA} and ${numA} in love, friendship, and work.`
  : `How compatible are life path ${numA} (${traitsA.title}) and ${numB} (${traitsB.title})? Rated ${compat.match}. Full breakdown for love, friendship, and work.`;

// Ghost numeral font size — master numbers (11,22,33) use smaller size
const isMasterA = ['11','22','33'].includes(numA);
const isMasterB = ['11','22','33'].includes(numB);
const ghostSizeA = isMasterA ? 'clamp(10rem,18vw,16rem)' : 'clamp(14rem,28vw,22rem)';
const ghostSizeB = isMasterB ? 'clamp(10rem,18vw,16rem)' : 'clamp(14rem,28vw,22rem)';
---

<Layout
  schema={[faqSchema, breadcrumbSchema]}
  title={pageTitle}
  description={pageDesc}
>

  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" />

  <style>
    :root { --font-family-heading: 'Cormorant Garamond', Georgia, serif; }
    .p-label { font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-soft-gold); font-weight:600; }
    .p-divider { width:48px; height:2px; background:var(--color-soft-gold); margin:0 auto; }
    .section-h2 { font-family:var(--font-family-heading); font-size:clamp(1.6rem,3.5vw,2.25rem); font-weight:700; color:var(--color-body-text); margin:0 0 1.25rem; }
    .faq-list details { border-top:1px solid var(--color-border); }
    .faq-list details:last-child { border-bottom:1px solid var(--color-border); }
    .faq-list summary { padding:1.3rem 0; cursor:pointer; display:flex; align-items:center; justify-content:space-between; gap:1rem; font-weight:600; font-size:1rem; color:var(--color-body-text); list-style:none; transition:color 0.2s; }
    .faq-list summary::-webkit-details-marker { display:none; }
    .faq-list details[open] summary { color:var(--color-violet); }
    .faq-chevron { flex-shrink:0; transition:transform 0.25s; }
    .faq-list details[open] .faq-chevron { transform:rotate(180deg); }
    .faq-answer { padding-bottom:1.3rem; font-size:0.9rem; color:var(--color-muted-text); line-height:1.8; }
    .num-card { background:var(--color-card-bg); border:1px solid var(--color-border); border-radius:8px; padding:1.5rem; }
    .tip-item { display:flex; align-items:flex-start; gap:1rem; padding:1rem 1.25rem; background:var(--color-card-bg); border:1px solid var(--color-border); border-radius:8px; margin-bottom:0.625rem; }
    .related-card { display:block; background:var(--color-card-bg); border:1px solid var(--color-border); border-radius:8px; padding:1rem 1.25rem; text-decoration:none; transition:border-color 0.2s, box-shadow 0.2s, transform 0.2s; }
    .related-card:hover { border-color:var(--color-violet); box-shadow:0 4px 16px rgba(124,92,191,0.1); transform:translateY(-1px); }
  </style>

  <!-- Breadcrumb -->
  <nav style="background:var(--color-card-bg);border-bottom:1px solid var(--color-border);padding:0.75rem 1.5rem;" aria-label="Breadcrumb">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:0.5rem;font-size:0.75rem;color:var(--color-muted-text);">
      <a href="/" style="color:var(--color-muted-text);text-decoration:none;">Home</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/" style="color:var(--color-muted-text);text-decoration:none;">Learn</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/life-path-compatibility/" style="color:var(--color-muted-text);text-decoration:none;">Life Path Compatibility</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <span style="color:var(--color-body-text);font-weight:600;">LP {numA} &amp; LP {numB}</span>
    </div>
  </nav>

  <!-- Hero -->
  <section style="position:relative;overflow:hidden;padding:6rem 1.5rem 5rem;text-align:center;min-height:440px;display:flex;align-items:center;">
    <!-- Background image -->
    <div style="position:absolute;inset:0;z-index:0;">
      <img
        src="/images/learn/Numerology Compatibility.webp"
        alt=""
        aria-hidden="true"
        fetchpriority="high"
        style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;"
      />
      <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(14,10,26,0.75) 0%, rgba(14,10,26,0.58) 45%, rgba(14,10,26,0.80) 100%);"></div>
      <div style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(196,162,78,0.08) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;"></div>
    </div>
    <!-- Ghost numeral A (left) -->
    <div aria-hidden="true" style={`position:absolute;left:-1rem;top:0;z-index:1;font-family:var(--font-family-heading);font-size:${ghostSizeA};font-weight:700;line-height:0.9;color:transparent;-webkit-text-stroke:1px rgba(196,162,78,0.18);pointer-events:none;user-select:none;`}>{numA}</div>
    <!-- Ghost numeral B (right) -->
    <div aria-hidden="true" style={`position:absolute;right:-1rem;bottom:-2rem;z-index:1;font-family:var(--font-family-heading);font-size:${ghostSizeB};font-weight:700;line-height:0.9;color:transparent;-webkit-text-stroke:1px rgba(124,92,191,0.15);pointer-events:none;user-select:none;`}>{numB}</div>
    <!-- Content -->
    <div style="position:relative;z-index:2;max-width:680px;margin:0 auto;width:100%;">
      <p class="p-label" style="margin-bottom:1.25rem;color:var(--color-soft-gold);opacity:0.9;">Life Path Compatibility</p>
      <div class="p-divider" style="margin-bottom:1.75rem;"></div>
      <!-- Pair numerals display -->
      <div style="display:flex;align-items:center;justify-content:center;gap:1.25rem;margin-bottom:1.25rem;">
        <span style={`font-family:var(--font-family-heading);font-size:clamp(3.5rem,8vw,6rem);font-weight:700;line-height:1;color:var(--color-soft-gold);text-shadow:0 2px 20px rgba(14,10,26,0.6);`}>{numA}</span>
        <span style="font-size:1.5rem;color:rgba(240,234,255,0.4);font-weight:300;">&amp;</span>
        <span style={`font-family:var(--font-family-heading);font-size:clamp(3.5rem,8vw,6rem);font-weight:700;line-height:1;color:#c8a8f0;text-shadow:0 2px 20px rgba(14,10,26,0.6);`}>{numB}</span>
      </div>
      <h1 style="font-family:var(--font-family-heading);font-size:clamp(1.8rem,4.5vw,3rem);font-weight:700;line-height:1.1;color:#f5f0e8;letter-spacing:-0.01em;margin:0 0 1rem;text-shadow:0 2px 20px rgba(14,10,26,0.6);">
        {isSame ? `Two ${numA}s Together` : `Life Path ${numA} &amp; ${numB}`}: <em style="color:#c8a8f0;font-style:italic;">{compat.verdict}</em>
      </h1>
      <!-- Match badge -->
      <div style="margin-bottom:1.25rem;">
        <span style={`display:inline-block;background:rgba(255,255,255,0.08);border:1px solid ${matchBorderColor};color:${compat.match === 'strong' ? '#6ee7b7' : compat.match === 'good' ? 'var(--color-soft-gold)' : '#fca5a5'};font-size:0.72rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:0.35rem 0.9rem;border-radius:999px;backdrop-filter:blur(4px);`}>{matchLabel}</span>
      </div>
      <p style="font-size:1.05rem;line-height:1.8;color:rgba(240,234,255,0.82);max-width:520px;margin:0 auto;text-shadow:0 1px 8px rgba(14,10,26,0.5);">{compat.description}</p>
      <div style="display:flex;flex-wrap:wrap;gap:0.875rem;justify-content:center;margin-top:2rem;">
        <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:1rem;padding:0.875rem 2rem;border-radius:6px;text-decoration:none;transition:background 0.2s,transform 0.15s;box-shadow:0 4px 20px rgba(124,92,191,0.45);" onmouseover="this.style.background='#6a4eab';this.style.transform='translateY(-1px)'" onmouseout="this.style.background='var(--color-violet)';this.style.transform='none'">Get My Free Reading →</a>
        <a href="#love" style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.1);backdrop-filter:blur(6px);color:#f5f0e8;font-weight:600;font-size:1rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.25);transition:border-color 0.2s,background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.18)';this.style.borderColor='rgba(255,255,255,0.45)'" onmouseout="this.style.background='rgba(255,255,255,0.1)';this.style.borderColor='rgba(255,255,255,0.25)'">See Love &amp; Romance ↓</a>
      </div>
    </div>
  </section>

  <!-- Author byline -->
  <div style="background:var(--color-light-bg);padding:1.25rem 1.5rem;">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:1rem;">
      <img src="/images/author-maddi-green.webp" alt="Maddie Greene" style="width:2.75rem;height:2.75rem;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid rgba(124,92,191,0.2);" />
      <div>
        <p style="color:var(--color-body-text);font-size:0.875rem;font-weight:600;margin:0 0 0.1rem;">Written by <strong>Maddie Greene</strong></p>
        <p style="color:var(--color-muted-text);font-size:0.78rem;margin:0;">Numerology writer &amp; researcher</p>
      </div>
    </div>
  </div>

  <!-- Content + Sticky sidebar wrapper -->
  <div class="xl:flex xl:gap-6 xl:max-w-[1200px] xl:mx-auto xl:px-4">
    <!-- Main content column -->
    <div class="xl:flex-1 xl:min-w-0">

  <article style="padding:2rem 1.5rem 3rem;background:var(--color-card-bg);">
    <div class="max-w-3xl mx-auto xl:mx-0 xl:max-w-none">

      <!-- Overview -->
      <section id="overview" style="margin-bottom:3rem;">
        <h2 class="section-h2">{isSame ? `What two ${numA}s look like together` : `${numA} and ${numB}: the overview`}</h2>

        {details.overview.split('\n\n').map((p: string) => (
          <p style="color:var(--color-body-text);line-height:1.8;margin-bottom:1rem;">{p}</p>
        ))}
      </section>

      <!-- Individual number summaries -->
      <section id="numbers" style="margin-bottom:3rem;padding-top:2rem;border-top:1px solid var(--color-border);">
        <h2 class="section-h2">The numbers</h2>

        <div style={`display:grid;grid-template-columns:${isSame ? '1fr' : '1fr 1fr'};gap:1rem;`}>
          <div class="num-card">
            <div style="display:flex;align-items:center;gap:0.875rem;margin-bottom:1rem;">
              <span style="font-family:var(--font-family-heading);font-size:2.5rem;font-weight:700;color:var(--color-soft-gold);line-height:1;">{numA}</span>
              <div>
                <h3 style="font-family:var(--font-family-heading);font-size:1.15rem;font-weight:700;color:var(--color-body-text);margin:0 0 0.2rem;">{traitsA.title}</h3>
                <p style="font-size:0.72rem;color:var(--color-muted-text);margin:0;">{traitsA.element} · {traitsA.coreTraits.join(' · ')}</p>
              </div>
            </div>
            <p style="font-size:0.875rem;color:var(--color-body-text);line-height:1.7;margin-bottom:0.625rem;">{traitsA.lovestyle}</p>
            <p style="font-size:0.8rem;color:var(--color-muted-text);line-height:1.7;margin-bottom:0.875rem;"><strong style="color:var(--color-body-text);">Watch out for:</strong> {traitsA.challenge}</p>
            <a href={`/learn/life-path-number-${numA}/`} style="font-size:0.8rem;font-weight:600;color:var(--color-violet);text-decoration:none;">Full LP{numA} guide →</a>
          </div>

          {!isSame && (
            <div class="num-card">
              <div style="display:flex;align-items:center;gap:0.875rem;margin-bottom:1rem;">
                <span style="font-family:var(--font-family-heading);font-size:2.5rem;font-weight:700;color:var(--color-soft-gold);line-height:1;">{numB}</span>
                <div>
                  <h3 style="font-family:var(--font-family-heading);font-size:1.15rem;font-weight:700;color:var(--color-body-text);margin:0 0 0.2rem;">{traitsB.title}</h3>
                  <p style="font-size:0.72rem;color:var(--color-muted-text);margin:0;">{traitsB.element} · {traitsB.coreTraits.join(' · ')}</p>
                </div>
              </div>
              <p style="font-size:0.875rem;color:var(--color-body-text);line-height:1.7;margin-bottom:0.625rem;">{traitsB.lovestyle}</p>
              <p style="font-size:0.8rem;color:var(--color-muted-text);line-height:1.7;margin-bottom:0.875rem;"><strong style="color:var(--color-body-text);">Watch out for:</strong> {traitsB.challenge}</p>
              <a href={`/learn/life-path-number-${numB}/`} style="font-size:0.8rem;font-weight:600;color:var(--color-violet);text-decoration:none;">Full LP{numB} guide →</a>
            </div>
          )}
        </div>
      </section>

      <!-- Match rating -->
      <section id="rating" style="margin-bottom:3rem;padding-top:2rem;border-top:1px solid var(--color-border);">
        <h2 class="section-h2">Match rating</h2>

        <div style={`background:${matchBg};border:1px solid ${matchBorderColor};border-radius:10px;padding:2rem;text-align:center;`}>
          <div style="font-size:1.75rem;margin-bottom:0.75rem;" aria-label={`${stars} out of 5 stars`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <span style={i < stars ? `color:var(--color-soft-gold);` : `color:var(--color-border);`}>★</span>
            ))}
          </div>
          <p style={`font-size:1.1rem;font-weight:700;color:${matchColor};margin:0 0 0.4rem;`}>{matchLabel}</p>
          <p style="font-size:0.875rem;color:var(--color-muted-text);margin:0;">{compat.verdict}</p>
        </div>
      </section>

      <!-- Love & Romance -->
      <section id="love" style="margin-bottom:3rem;padding-top:2rem;border-top:1px solid var(--color-border);">
        <h2 class="section-h2">Love &amp; romance</h2>
        {details.loveInsight.split('\n\n').map((p: string) => (
          <p style="color:var(--color-body-text);line-height:1.8;margin-bottom:1rem;">{p}</p>
        ))}
      </section>

      <!-- Friendship -->
      <section id="friendship" style="margin-bottom:3rem;padding-top:2rem;border-top:1px solid var(--color-border);">
        <h2 class="section-h2">Friendship</h2>
        {details.friendshipInsight.split('\n\n').map((p: string) => (
          <p style="color:var(--color-body-text);line-height:1.8;margin-bottom:1rem;">{p}</p>
        ))}
      </section>

      <!-- Work & Career -->
      <section id="work" style="margin-bottom:3rem;padding-top:2rem;border-top:1px solid var(--color-border);">
        <h2 class="section-h2">Work &amp; career</h2>
        {details.workInsight.split('\n\n').map((p: string) => (
          <p style="color:var(--color-body-text);line-height:1.8;margin-bottom:1rem;">{p}</p>
        ))}
      </section>

      <!-- Tips -->
      <section id="tips" style="margin-bottom:3rem;padding-top:2rem;border-top:1px solid var(--color-border);">
        <h2 class="section-h2">Tips for making it work</h2>

        <div>
          {details.tips.map((tip: string, i: number) => (
            <div class="tip-item">
              <span style="font-family:var(--font-family-heading);font-size:1.5rem;font-weight:700;color:var(--color-soft-gold);line-height:1;flex-shrink:0;min-width:1.5rem;">{i + 1}</span>
              <p style="color:var(--color-body-text);line-height:1.7;font-size:0.9rem;margin:0;">{tip}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section id="faq" style="margin-bottom:3rem;padding-top:2rem;border-top:1px solid var(--color-border);">
        <h2 class="section-h2">Common questions</h2>

        <div class="faq-list">
          {faqSchema.mainEntity.map((item: { name: string; acceptedAnswer: { text: string } }) => (
            <details>
              <summary>
                {item.name}
                <svg class="faq-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-answer">{item.acceptedAnswer.text}</div>
            </details>
          ))}
        </div>
      </section>

      <!-- Related pairs -->
      <section id="related" style="margin-bottom:2rem;padding-top:2rem;border-top:1px solid var(--color-border);">
        <h2 class="section-h2">Related pairs</h2>


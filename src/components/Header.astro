---
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Learn", href: "/learn/" },
  { label: "Calculator", href: "/calculator/" },
  { label: "About", href: "/about/" },
];
---

<header class="relative bg-midnight border-b border-white/5">
  <!-- Subtle gold top accent line -->
  <div class="h-0.5 w-full" style="background: linear-gradient(90deg, transparent, var(--color-gold) 30%, var(--color-soft-violet) 70%, transparent);"></div>

  <nav class="relative z-10 max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 text-xl font-bold font-[family-name:var(--font-family-heading)]">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-soft-gold" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      <span class="text-gold-gradient">Numerology Guides</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              "text-sm tracking-wide transition-colors duration-150 px-4 py-2 rounded-md",
              currentPath === link.href
                ? "text-soft-gold font-semibold bg-white/5"
                : "text-starlight/65 hover:text-soft-gold hover:bg-white/5"
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="ml-3">
        <a
          href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net"
          target="_blank"
          rel="noopener sponsored"
          class="text-sm tracking-wide px-4 py-2 rounded-md font-semibold transition-all duration-150 hover:brightness-110"
          style="background: #6ab165; color: #fff; border: 1px solid #5a9a56; box-shadow: 0 2px 8px rgba(106,177,101,0.3);"
        >
          Free Reading
        </a>
      </li>
    </ul>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-starlight/65 hover:text-soft-gold transition-colors"
      aria-label="Toggle menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-deep-purple/95 relative z-10">
    <ul class="px-4 py-3 flex flex-col gap-1">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              "block text-sm tracking-wide transition-colors duration-150 px-3 py-2.5 rounded-md",
              currentPath === link.href
                ? "text-soft-gold font-semibold bg-white/5"
                : "text-starlight/65 hover:text-soft-gold hover:bg-white/5"
            ]}
          >
            {currentPath === link.href && <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="inline mr-1.5 mb-0.5" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>}{link.label}
          </a>
        </li>
      ))}
      <li class="mt-1 pt-1 border-t border-white/5">
        <a
          href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net"
          target="_blank"
          rel="noopener sponsored"
          class="block text-sm px-3 py-2.5 rounded-md font-semibold"
          style="background: #6ab165; color: #fff; border: 1px solid #5a9a56;"
        >
          Get Free Reading
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>

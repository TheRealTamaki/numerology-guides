---
import Layout from '../../../layouts/Layout.astro';
import SidebarCTA from '../../../components/SidebarCTA.astro';
import { soulUrgeNumbers } from '../../../data/soulUrgeNumbers';

const coreNumbers = soulUrgeNumbers.filter(s => s.n <= 9);
const masterNumbers = soulUrgeNumbers.filter(s => s.n > 9);

// Traits summary for each core soul urge number
const suMeta: Record<number, { traits: string; deepWant: string }> = {
  1: { traits: "Independent, self-directed, original",        deepWant: "To lead, to stand out, to forge their own path" },
  2: { traits: "Cooperative, sensitive, relationship-focused", deepWant: "To connect deeply, to belong, to bring harmony" },
  3: { traits: "Expressive, joyful, creative",                deepWant: "To create, to communicate, to be heard" },
  4: { traits: "Grounded, orderly, security-seeking",         deepWant: "To build something lasting and dependable" },
  5: { traits: "Freedom-loving, curious, restless",           deepWant: "To experience, to roam, to never stop exploring" },
  6: { traits: "Nurturing, responsible, devoted",             deepWant: "To love and be loved; to protect and serve" },
  7: { traits: "Private, analytical, spiritually curious",    deepWant: "To understand the deepest truths of existence" },
  8: { traits: "Ambitious, powerful, achievement-driven",     deepWant: "To succeed, to be recognised, to build real power" },
  9: { traits: "Idealistic, compassionate, giving",           deepWant: "To serve, to give back, to leave the world better" },
};
---

<Layout
  title="Soul Urge Number in Numerology - Your Heart's Desire Revealed"
  description="Your soul urge number comes from the vowels in your birth name and reveals your deepest inner motivations - what you truly want, beneath the surface. Find yours and explore all 12 soul urge numbers."
>

  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" />

  <style>
    :root { --font-family-heading: 'Cormorant Garamond', Georgia, serif; }
    .p-label { font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-soft-gold); font-weight:600; }
    .p-divider { width:48px; height:2px; background:var(--color-soft-gold); margin:0 auto; }
    .section-h2 { font-family:var(--font-family-heading); font-size:clamp(1.6rem,3.5vw,2.25rem); font-weight:700; color:var(--color-body-text); margin:0 0 1.25rem; }
  </style>

  <!-- Breadcrumb -->
  <nav style="background:var(--color-card-bg);border-bottom:1px solid var(--color-border);padding:0.75rem 1.5rem;" aria-label="Breadcrumb">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:0.5rem;font-size:0.75rem;color:var(--color-muted-text);">
      <a href="/" style="color:var(--color-muted-text);text-decoration:none;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Home</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/" style="color:var(--color-muted-text);text-decoration:none;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Learn</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <span style="color:var(--color-body-text);font-weight:600;">Soul Urge Numbers</span>
    </div>
  </nav>

  <!-- Hero -->
  <section style="position:relative;overflow:hidden;padding:6rem 1.5rem 5rem;text-align:center;min-height:480px;display:flex;align-items:center;">
    <div style="position:absolute;inset:0;z-index:0;">
      <img
        src="/images/learn/Soul Urge Numbers Pillar Hero.webp"
        alt=""
        aria-hidden="true"
        fetchpriority="high"
        style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;"
      />
      <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(14,10,26,0.75) 0%, rgba(14,10,26,0.58) 45%, rgba(14,10,26,0.80) 100%);"></div>
      <div style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(196,162,78,0.08) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;"></div>
    </div>
    <div aria-hidden="true" style="position:absolute;left:-1rem;top:0.5rem;z-index:1;font-family:var(--font-family-heading);font-size:clamp(10rem,20vw,16rem);font-weight:700;line-height:1;color:transparent;-webkit-text-stroke:1px rgba(196,162,78,0.18);pointer-events:none;user-select:none;">S</div>
    <div aria-hidden="true" style="position:absolute;right:-0.5rem;bottom:-1.5rem;z-index:1;font-family:var(--font-family-heading);font-size:clamp(12rem,24vw,20rem);font-weight:700;line-height:1;color:transparent;-webkit-text-stroke:1px rgba(124,92,191,0.15);pointer-events:none;user-select:none;">U</div>
    <div style="position:relative;z-index:2;max-width:760px;margin:0 auto;width:100%;">
      <p class="p-label" style="margin-bottom:1.25rem;color:var(--color-soft-gold);opacity:0.9;">Core Chart Numbers</p>
      <div class="p-divider" style="margin-bottom:1.75rem;"></div>
      <h1 style="font-family:var(--font-family-heading);font-size:clamp(2.6rem,6.5vw,4.75rem);font-weight:700;line-height:1.08;color:#f5f0e8;letter-spacing:-0.02em;margin:0 0 1.5rem;text-shadow:0 2px 20px rgba(14,10,26,0.6);">
        Soul Urge Number in<br><em style="color:#c8a8f0;font-style:italic;">Numerology</em>
      </h1>
      <p style="font-size:1.05rem;line-height:1.8;color:rgba(240,234,255,0.82);max-width:560px;margin:0 auto 2.5rem;text-shadow:0 1px 8px rgba(14,10,26,0.5);">
        Calculated from the vowels in your birth name, your soul urge number reveals your deepest inner motivation, what you most truly want, beneath the career, the relationships, and the choices you've made.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:0.875rem;justify-content:center;">
        <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:1rem;padding:0.875rem 2rem;border-radius:6px;text-decoration:none;transition:background 0.2s,transform 0.15s;box-shadow:0 4px 20px rgba(124,92,191,0.45);" onmouseover="this.style.background='#6a4eab';this.style.transform='translateY(-1px)'" onmouseout="this.style.background='var(--color-violet)';this.style.transform='none'">Get My Free Reading →</a>
        <a href="#all-numbers" style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.1);backdrop-filter:blur(6px);color:#f5f0e8;font-weight:600;font-size:1rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.25);transition:border-color 0.2s,background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.18)';this.style.borderColor='rgba(255,255,255,0.45)'" onmouseout="this.style.background='rgba(255,255,255,0.1)';this.style.borderColor='rgba(255,255,255,0.25)'">Find My Number ↓</a>
      </div>
    </div>
  </section>

  <!-- Author byline -->
  <div style="background:var(--color-light-bg);padding:1.5rem 1.5rem;">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:1rem;">
      <img src="/images/author-maddi-green.webp" alt="Maddie Greene" style="width:3rem;height:3rem;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid rgba(124,92,191,0.2);box-shadow:0 2px 8px rgba(26,21,40,0.08);" />
      <div>
        <p style="color:var(--color-body-text);font-size:0.9rem;font-weight:600;margin:0 0 0.15rem;">Written by <strong>Maddie Greene</strong></p>
        <p style="color:var(--color-muted-text);font-size:0.8rem;margin:0;">Numerology writer &amp; researcher</p>
      </div>
    </div>
  </div>

  <!-- Content + Sticky sidebar wrapper -->
  <div class="xl:flex xl:gap-6 xl:max-w-[1200px] xl:mx-auto xl:px-4">
    <!-- Main content column -->
    <div class="xl:flex-1 xl:min-w-0">

  <!-- What is the soul urge number -->
  <section style="padding:3.5rem 1.5rem 3.5rem;background:var(--color-card-bg);">
    <div class="max-w-3xl mx-auto xl:mx-0 xl:max-w-none">
      <h2 class="section-h2">What is the soul urge number?</h2>
      <p style="font-size:1rem;line-height:1.8;color:var(--color-muted-text);margin:0 0 1.25rem;">
        In Pythagorean numerology, your name carries two separate pieces of information. The consonants in your name give you your personality number, the outer impression you make. The vowels give you your soul urge number, the private, inner motivation that drives your choices from below the surface.
      </p>
      <p style="font-size:1rem;line-height:1.8;color:var(--color-muted-text);margin:0 0 1.25rem;">
        It's sometimes called the heart's desire number, and that framing is useful. It's not about what you think you should want, or what looks good from the outside. It's about what genuinely moves you, what you'd choose if nobody was watching, what makes life feel like it actually means something. The soul urge describes the engine underneath the choices.
      </p>
      <p style="font-size:1rem;line-height:1.8;color:var(--color-muted-text);margin:0 0 1.5rem;">
        Understanding your soul urge number is often the piece that makes other things make sense. Why certain situations feel right even when they look wrong from the outside. Why certain achievements feel hollow even when they look like success. The soul urge knows what it wants. It just doesn't always communicate in words.
      </p>
    </div>
  </section>

  <!-- How to calculate -->
  <section style="padding:4rem 1.5rem;background:var(--color-light-bg);border-top:1px solid var(--color-border);">
    <div class="max-w-3xl mx-auto xl:mx-0 xl:max-w-none">
      <h2 class="section-h2">How to calculate your soul urge number</h2>
      <p style="font-size:1rem;line-height:1.8;color:var(--color-muted-text);margin:0 0 1.5rem;">
        Use your full birth name, first, middle, and last, exactly as it appears on your birth certificate. Extract only the vowels: A, E, I, O, U. Assign each vowel its Pythagorean value, add them all together, and reduce to a single digit. If you land on 11, 22, or 33, stop. Those are master numbers.
      </p>

      <div style="background:var(--color-card-bg);border:1px solid var(--color-border);border-radius:8px;padding:1.5rem;margin-bottom:1.5rem;">
        <h3 style="font-family:var(--font-family-heading);font-weight:700;color:var(--color-body-text);margin:0 0 1rem;font-size:1.05rem;">Vowel Values (Pythagorean)</h3>
        <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:1rem;text-align:center;">
          {[{v:'A',n:'1'},{v:'E',n:'5'},{v:'I',n:'9'},{v:'O',n:'6'},{v:'U',n:'3'}].map(item => (
            <div style="background:var(--color-light-bg);border:1px solid var(--color-border);padding:0.75rem;border-radius:6px;">
              <div style="font-family:var(--font-family-heading);font-size:1.5rem;font-weight:700;color:var(--color-violet);">{item.v}</div>
              <div style="font-size:0.875rem;color:var(--color-muted-text);">{item.n}</div>
            </div>
          ))}
        </div>
      </div>

      <div style="background:var(--color-card-bg);border:1px solid var(--color-border);border-left:4px solid var(--color-violet);border-radius:8px;padding:1.5rem;">
        <h3 style="font-family:var(--font-family-heading);font-weight:700;color:var(--color-body-text);margin:0 0 0.75rem;font-size:1.05rem;">Worked example: Sarah Jane Lee</h3>
        <div style="font-size:0.875rem;color:var(--color-muted-text);display:flex;flex-direction:column;gap:0.5rem;">
          <p style="margin:0;"><strong style="color:var(--color-body-text);">SARAH:</strong> A(1) + A(1) = <strong style="color:var(--color-violet);">2</strong></p>
          <p style="margin:0;"><strong style="color:var(--color-body-text);">JANE:</strong> A(1) + E(5) = <strong style="color:var(--color-violet);">6</strong></p>
          <p style="margin:0;"><strong style="color:var(--color-body-text);">LEE:</strong> E(5) + E(5) = 10 → 1+0 = <strong style="color:var(--color-violet);">1</strong></p>
          <p style="margin:0.5rem 0 0;padding-top:0.5rem;border-top:1px solid var(--color-border);"><strong style="color:var(--color-body-text);">Total:</strong> 2 + 6 + 1 = 9 → <strong style="color:var(--color-violet);font-size:1rem;">Soul Urge 9</strong></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Soul urge vs other numbers -->
  <section style="padding:4rem 1.5rem;background:var(--color-card-bg);border-top:1px solid var(--color-border);">
    <div class="max-w-3xl mx-auto xl:mx-0 xl:max-w-none">
      <h2 class="section-h2">Soul urge vs your other numbers</h2>
      <p style="font-size:1rem;line-height:1.8;color:var(--color-muted-text);margin:0 0 1.25rem;">
        Your numerology chart has several core numbers, each describing something different. The life path number describes the terrain of your life. The expression number describes the direction you're meant to move in. The soul urge number describes what you want at the deepest private level.
      </p>
      <p style="font-size:1rem;line-height:1.8;color:var(--color-muted-text);margin:0 0 1.25rem;">
        When all three are aligned, when what your life is asking of you (life path), what you're built to do (expression), and what you actually want (soul urge) are all pointing in a similar direction, life tends to feel coherent. When they pull against each other, there's interesting friction to understand.
      </p>
      <p style="font-size:1rem;line-height:1.8;color:var(--color-muted-text);margin:0 0 2rem;">
        A full reading from Numerologist.com looks at all of these numbers together and shows you how they interact. If you want to see the full picture, that's the most efficient way to get there.
      </p>
      <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:0.95rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;transition:background 0.2s;" onmouseover="this.style.background='#6a4eab'" onmouseout="this.style.background='var(--color-violet)'">
        Get Your Free Reading →
      </a>
    </div>
  </section>

  <!-- All soul urge numbers grid -->
  <section id="all-numbers" style="padding:5rem 1.5rem;background:var(--color-light-bg);border-top:1px solid var(--color-border);">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p class="p-label" style="margin-bottom:0.75rem;">All Soul Urge Numbers</p>
        <h2 style="font-family:var(--font-family-heading);font-size:clamp(1.75rem,4vw,2.75rem);font-weight:700;color:var(--color-body-text);margin:0 0 0.75rem;">Find Your Soul Urge Number</h2>
        <div class="p-divider" style="margin:0 auto;"></div>
        <p style="color:var(--color-muted-text);margin-top:1rem;max-width:560px;margin-left:auto;margin-right:auto;font-size:0.95rem;line-height:1.7;">Select your number to explore your deepest inner motivations, and what they mean for your relationships, your career, and the choices that shape your life.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-14">
        {coreNumbers.map(su => {
          const meta = suMeta[su.n];
          const topStrength = su.strengths[0]?.title ?? '';
          const topChallenge = su.challenges[0]?.title ?? '';
          return (
            <a href={`/learn/soul-urge-number/${su.n}/`} class="card-light group block overflow-hidden hover:border-violet/60 hover:-translate-y-1 transition-all duration-200" style="text-decoration:none;">
              <div style="position:relative;overflow:hidden;">
                <img
                  src={`/images/learn/soul-urge-numbers/Soul Urge Number - ${su.title}.webp`}
                  alt={`Soul Urge ${su.n} - ${su.title}`}
                  class="w-full group-hover:scale-105 transition-transform duration-500"
                  style="aspect-ratio:2/3;object-fit:cover;display:block;width:100%;"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div style="padding:1.25rem;">
                <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--color-muted-text);margin-bottom:0.2rem;">Soul Urge {su.n}</div>
                <div style="font-weight:700;color:var(--color-body-text);font-size:1.1rem;margin-bottom:0.35rem;" class="group-hover:text-violet transition-colors">{su.title}</div>
                <p style="font-size:0.875rem;color:var(--color-muted-text);margin:0 0 0.75rem;line-height:1.6;">{meta.traits}</p>
                <div style="font-size:0.8rem;color:var(--color-muted-text);font-style:italic;border-left:2px solid rgba(124,92,191,0.3);padding-left:0.75rem;margin-bottom:1rem;">"{meta.deepWant}"</div>
                <div style="display:flex;flex-direction:column;gap:0.35rem;font-size:0.8rem;margin-bottom:1rem;">
                  <div style="display:flex;gap:0.5rem;">
                    <span style="color:#4a9e5c;font-weight:600;width:5rem;flex-shrink:0;">Strength:</span>
                    <span style="color:var(--color-muted-text);">{topStrength}</span>
                  </div>
                  <div style="display:flex;gap:0.5rem;">
                    <span style="color:#c0444a;font-weight:600;width:5rem;flex-shrink:0;">Challenge:</span>
                    <span style="color:var(--color-muted-text);">{topChallenge}</span>
                  </div>
                </div>
                <span style="font-size:0.875rem;font-weight:600;color:var(--color-violet);" class="group-hover:text-soft-violet transition-colors">Full {su.n} guide →</span>
              </div>
            </a>
          );
        })}
      </div>

      <!-- Master numbers -->
      <div style="padding-top:3rem;border-top:1px solid var(--color-border);">
        <div style="text-align:center;margin-bottom:2.5rem;">
          <p class="p-label" style="margin-bottom:0.75rem;">Special Vibrations</p>
          <h2 style="font-family:var(--font-family-heading);font-size:clamp(1.5rem,3vw,2rem);font-weight:700;color:var(--color-body-text);margin:0 0 0.75rem;">Master Soul Urge Numbers</h2>
          <div class="p-divider" style="margin:0 auto;"></div>
          <p style="color:var(--color-muted-text);margin-top:1rem;max-width:520px;margin-left:auto;margin-right:auto;font-size:0.9rem;line-height:1.7;">Master soul urge numbers indicate a higher calling and a greater degree of intensity in the inner life. They're rarer, and they ask more.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {masterNumbers.map(su => (
            <a href={`/learn/soul-urge-number/${su.n}/`} class="card-light group block overflow-hidden hover:border-violet/60 hover:-translate-y-1 transition-all duration-200" style="text-decoration:none;border-color:rgba(124,92,191,0.2);">
              <div style="position:relative;overflow:hidden;">
                <img
                  src={`/images/learn/soul-urge-numbers/Soul Urge Number - ${su.title}.webp`}
                  alt={`Soul Urge ${su.n} - ${su.title}`}
                  class="w-full group-hover:scale-105 transition-transform duration-500"
                  style="aspect-ratio:2/3;object-fit:cover;display:block;width:100%;"
                  loading="lazy"
                  decoding="async"
                />
                <div style="position:absolute;top:0.75rem;right:0.75rem;background:rgba(15,13,40,0.85);color:var(--color-soft-gold);font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;padding:0.25rem 0.5rem;border-radius:4px;">Master</div>
              </div>
              <div style="padding:1.25rem;">
                <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--color-muted-text);margin-bottom:0.2rem;">Master Number {su.n}</div>
                <div style="font-weight:700;color:var(--color-body-text);font-size:1.1rem;margin-bottom:0.5rem;" class="group-hover:text-violet transition-colors">{su.title}</div>
                <p style="font-size:0.875rem;color:var(--color-muted-text);margin:0 0 1rem;line-height:1.6;">{su.shortDesc}</p>
                <span style="font-size:0.875rem;font-weight:600;color:var(--color-violet);" class="group-hover:text-soft-violet transition-colors">Full {su.n} guide →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

    </div><!-- end main content column -->
    <SidebarCTA />
  </div><!-- end flex wrapper -->

  <!-- Related guides -->
  <section style="padding:5rem 1.5rem;background:var(--color-card-bg);border-top:1px solid var(--color-border);">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p class="p-label" style="margin-bottom:0.75rem;">Keep Exploring</p>
        <h2 style="font-family:var(--font-family-heading);font-size:clamp(1.5rem,3vw,2rem);font-weight:700;color:var(--color-body-text);margin:0 0 0.75rem;">Related Guides</h2>
        <div class="p-divider" style="margin:0 auto;"></div>
      </div>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-5">
        <a href="/learn/life-path-number/" class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block" style="text-decoration:none;">
          <img src="/images/learn/Life Path Numbers - Tile.webp" alt="Life Path Numbers" class="w-full object-cover transition-transform duration-500 group-hover:scale-105" style="aspect-ratio:2/3;display:block;" loading="lazy" decoding="async" />
          <div style="padding:1.25rem;">
            <div style="font-weight:700;color:var(--color-body-text);margin-bottom:0.35rem;" class="group-hover:text-violet transition-colors">Life Path Numbers</div>
            <p style="font-size:0.8rem;color:var(--color-muted-text);margin:0;">The most important number in your chart, the terrain of your life.</p>
          </div>
        </a>
        <a href="/learn/expression-number/" class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block" style="text-decoration:none;">
          <img src="/images/learn/Expression Numbers - Tile.webp" alt="Expression Numbers" class="w-full object-cover transition-transform duration-500 group-hover:scale-105" style="aspect-ratio:2/3;display:block;" loading="lazy" decoding="async" />
          <div style="padding:1.25rem;">
            <div style="font-weight:700;color:var(--color-body-text);margin-bottom:0.35rem;" class="group-hover:text-violet transition-colors">Expression Numbers</div>
            <p style="font-size:0.8rem;color:var(--color-muted-text);margin:0;">The direction your destiny is pulling you, from your full birth name.</p>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:1rem;">
        {otherAngel.map(an => (
          <a href={an.href} style="text-decoration:none;display:block;" class="group">
            <div style="overflow:hidden;border-radius:8px;border:1px solid var(--color-border);transition:border-color 0.2s,transform 0.2s;background:white;" class="group-hover:border-violet/60 group-hover:-translate-y-1">
              <img
                src={`/images/learn/angel-numbers/Angel Number - ${an.number}.webp`}

---
import Layout from '../../../../layouts/Layout.astro';
import SidebarCTA from '../../../../components/SidebarCTA.astro';

const otherAngel = [
  { number: "111", title: "New Beginnings", href: "/learn/angel-numbers/111/", image: "/images/Angel Number 111.webp" },
  { number: "222", title: "Trust & Balance", href: "/learn/angel-numbers/222/", image: "/images/Angel Number 222.webp" },
  { number: "333", title: "Creative Expression", href: "/learn/angel-numbers/333/", image: "/images/Angel Number 333.webp" },
  { number: "444", title: "Stability & Protection", href: "/learn/angel-numbers/444/", image: "/images/Angel Number 444.webp" },
  { number: "555", title: "Major Change", href: "/learn/angel-numbers/555/", image: "/images/Angel Number 555.webp" },
  { number: "666", title: "Realignment & Balance", href: "/learn/angel-numbers/666/", image: "/images/Angel Number 666.webp" },
  { number: "888", title: "Abundance & Power", href: "/learn/angel-numbers/888/", image: "/images/Angel Number 888.webp" },
  { number: "999", title: "Completion & Release", href: "/learn/angel-numbers/999/", image: "/images/Angel Number 999.webp" },
  { number: "000", title: "Infinite Potential", href: "/learn/angel-numbers/000/", image: "/images/Angel Number 000.webp" },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does 777 mean in numerology?",
      "acceptedAnswer": { "@type": "Answer", "text": "In numerology, 777 is the number 7 amplified three times. The number 7 represents spiritual awakening, inner wisdom, analysis, and truth-seeking. 777 as an angel number is confirmation that you're on the right path, spiritually aligned and moving in the direction your soul actually wants to go. It appears when your internal work is manifesting externally. 777 is often called the luckiest angel number because it signals that the universe is supporting your choices and things are falling into place in almost magical ways." }
    },
    {
      "@type": "Question",
      "name": "Why do I keep seeing 777?",
      "acceptedAnswer": { "@type": "Answer", "text": "You're seeing 777 because something inside you has shifted into alignment. This usually happens after you've done genuine spiritual work: meditation, therapy, honest self-reflection, time alone with your thoughts. Your intuition has sharpened. Your values have clarified. And now the outer world is beginning to reflect that inner alignment. 777 appears during moments of spiritual clarity, after difficult decisions that turned out to be right, or when you're noticing synchronicities that feel too perfect to be random. The universe is saying: yes, keep going." }
    },
    {
      "@type": "Question",
      "name": "Is 777 lucky?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes, and in a specific way. 777 isn't luck like winning the lottery. It's the luck of being in the right place because you're thinking clearly and following your intuition. It's the luck of opportunities showing up for people who are paying attention. When 777 appears, things have a way of working out. Not because the universe is handing you free passes, but because your alignment with your own truth is magnetic. You're attracting situations that match who you actually are. That's luck in its truest form." }
    },
    {
      "@type": "Question",
      "name": "What does 777 mean in love?",
      "acceptedAnswer": { "@type": "Answer", "text": "In love, 777 is about spiritual depth and genuine connection. The 7 isn't interested in surface-level attraction. It wants to understand, to trust, to really know someone. If you're seeing 777 in your love life, it means you're being called toward deeper intimacy through honesty and vulnerability. Single? 777 says the right person appears when you're aligned with yourself first. Stop trying to be what you think someone wants. Be who you actually are, and the person who matches that will show up. In a relationship? 777 signals that you're moving into a phase of genuine understanding, the kind built on truth rather than compromise." }
    },
    {
      "@type": "Question",
      "name": "What should I do when I see 777?",
      "acceptedAnswer": { "@type": "Answer", "text": "Trust your instinct. That's the core message. 777 is saying: your inner knowing is accurate. Follow it. This is the moment to trust the quiet voice inside you, the one that's been speaking truthfully all along. Continue whatever spiritual practice brought you to this point, whether that's meditation, journaling, time in nature, or honest conversation. Pay attention to synchronicities and follow the breadcrumbs. The universe is communicating with you in whispers and signs. Stay open. Stay aligned. And let things unfold without trying to force outcomes." }
    },
    {
      "@type": "Question",
      "name": "What's the difference between 777 and 7777?",
      "acceptedAnswer": { "@type": "Answer", "text": "777 is confirmation of alignment. You're on the right path, trust it. 7777 is amplification into mastery. It's saying you've moved beyond just being aligned, you're actually becoming a teacher or guide for others. Four 7s takes the introspective, spiritual energy and turns it outward. Where 777 is about your own awakening, 7777 is about your role in others' awakening. If you're seeing 7777, you're being asked to step more fully into your wisdom and share what you've learned. Either number is beautiful. 777 just says 'you're doing great'. 7777 says 'now help others.'" }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://numerologyguides.blog/" },
    { "@type": "ListItem", "position": 2, "name": "Learn", "item": "https://numerologyguides.blog/learn/" },
    { "@type": "ListItem", "position": 3, "name": "Angel Numbers", "item": "https://numerologyguides.blog/learn/angel-numbers/" },
    { "@type": "ListItem", "position": 4, "name": "777" }
  ]
};
---

<Layout
  title="Angel Number 777 Meaning: Spiritual Alignment, Inner Wisdom & Lucky Breaks"
  description="Angel number 777 is the most spiritual angel number. It appears when you're aligned with your soul's path and your inner work is manifesting. Learn the real meaning of 777 in love, career, and spiritual growth."
  schema={[faqSchema, breadcrumbSchema]}
>
  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" />
  <style>
    :root { --font-family-heading: 'Cormorant Garamond', Georgia, serif; }
    .p-label { font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-soft-gold); font-weight:600; }
    .p-divider { width:48px; height:2px; background:var(--color-soft-gold); margin:0 auto; }
    .section-h2 { font-family:var(--font-family-heading); font-size:clamp(1.6rem,3.5vw,2.25rem); font-weight:700; color:var(--color-body-text); margin:0 0 1.25rem; }
    .faq-list details { border-top:1px solid var(--color-border); }
    .faq-list details:last-child { border-bottom:1px solid var(--color-border); }
    .faq-list summary { padding:1.3rem 0; cursor:pointer; display:flex; align-items:center; justify-content:space-between; gap:1rem; font-weight:600; font-size:1rem; color:var(--color-body-text); list-style:none; transition:color 0.2s; }
    .faq-list summary::-webkit-details-marker { display:none; }
    .faq-list details[open] summary { color:var(--color-violet); }
    .faq-chevron { flex-shrink:0; transition:transform 0.25s; }
    .faq-list details[open] .faq-chevron { transform:rotate(180deg); }
    .faq-answer { padding-bottom:1.3rem; font-size:0.9rem; color:var(--color-muted-text); line-height:1.8; }
  </style>

  <!-- Breadcrumb -->
  <nav style="background:var(--color-card-bg);border-bottom:1px solid var(--color-border);padding:0.75rem 1.5rem;" aria-label="Breadcrumb">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:0.5rem;font-size:0.75rem;color:var(--color-muted-text);">
      <a href="/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Home</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Learn</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/angel-numbers/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Angel Numbers</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <span style="color:var(--color-body-text);font-weight:600;">777</span>
    </div>
  </nav>

  <!-- Hero -->
  <section style="position:relative;overflow:hidden;background:var(--color-midnight,#0e0a1a);">
    <div aria-hidden="true" style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(196,162,78,0.07) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>
    <div aria-hidden="true" style="position:absolute;top:-10%;left:-5%;width:55%;height:120%;background:radial-gradient(ellipse at center,rgba(124,92,191,0.18) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>
    <div style="position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:4rem 1.5rem;display:flex;align-items:center;gap:3rem;flex-wrap:wrap;">
      <div style="flex:1;min-width:280px;">
        <p class="p-label" style="margin-bottom:1.1rem;color:var(--color-soft-gold);opacity:0.9;">Angel Number</p>
        <div class="p-divider" style="margin:0 0 1.6rem;"></div>
        <h1 style="font-family:var(--font-family-heading);font-size:clamp(2.8rem,6vw,5rem);font-weight:700;line-height:1.06;color:#f5f0e8;letter-spacing:-0.02em;margin:0 0 1.25rem;">
          Angel Number <em style="color:#c8a8f0;font-style:italic;">777</em>: Spiritual Alignment &amp; Inner Wisdom
        </h1>
        <p style="font-size:1.05rem;line-height:1.8;color:rgba(240,234,255,0.78);max-width:460px;margin:0 0 2rem;">777 is the most spiritual angel number. It appears when you're on exactly the right path and your inner work is paying off. It's the signal that everything is aligning.</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.875rem;">
          <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:1rem;padding:0.875rem 2rem;border-radius:6px;text-decoration:none;transition:background 0.2s,transform 0.15s;box-shadow:0 4px 20px rgba(124,92,191,0.45);" onmouseover="this.style.background='#6a4eab';this.style.transform='translateY(-1px)'" onmouseout="this.style.background='var(--color-violet)';this.style.transform='none'">Get My Free Reading →</a>
          <a href="#meaning" style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.08);backdrop-filter:blur(6px);color:#f5f0e8;font-weight:600;font-size:1rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.2);transition:border-color 0.2s,background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)';this.style.borderColor='rgba(255,255,255,0.4)'" onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.borderColor='rgba(255,255,255,0.2)'">What It Means ↓</a>
        </div>
      </div>
      <div style="flex-shrink:0;width:clamp(200px,28vw,300px);filter:drop-shadow(0 8px 40px rgba(196,162,78,0.25)) drop-shadow(0 2px 12px rgba(0,0,0,0.6));">
        <img
          src="/images/learn/angel-numbers/Angel Number - 777.webp"
          alt="Angel Number 777 — Spiritual Alignment &amp; Inner Wisdom"
          fetchpriority="high"
          style="width:100%;border-radius:6px;display:block;"
        />
      </div>
    </div>
  </section>

  <!-- Author byline -->
  <div style="background:var(--color-card-bg);padding:1.75rem 1.5rem;border-bottom:1px solid var(--color-border);">
    <div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:1rem;">
      <img src="/images/author-maddi-green.webp" alt="Maddie Greene" style="width:52px;height:52px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid var(--color-border);" />
      <div>
        <p style="font-size:0.95rem;font-weight:600;color:var(--color-body-text);margin:0;">Written by <strong>Maddie Greene</strong></p>
        <p style="font-size:0.8rem;color:var(--color-muted-text);margin:0;">Numerology writer &amp; researcher</p>
      </div>
    </div>
  </div>

  <div class="xl:flex xl:gap-6 xl:max-w-[1200px] xl:mx-auto xl:px-4">
    <div class="xl:flex-1 xl:min-w-0">

  <section style="background:var(--color-card-bg);padding:2.5rem 1.5rem 3rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">What does angel number 777 actually mean?</h2>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        The number 7 is the seeker. The analyst. The one who isn't satisfied with surface answers and keeps digging until something feels true. It's associated with the <a href="/learn/life-path-number-7/" style="color:var(--color-violet);text-decoration:none;font-weight:500;">life path 7</a> energy: introspective, spiritual, truth-driven. It's the number of inner work and intuitive knowing.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        When 7 appears three times as 777, the message is about alignment. You've done something inside that's shifting things outside. Maybe you've been meditating. Maybe you finally had the conversation you'd been avoiding. Maybe you made the hard choice to honor what you actually want instead of what you thought you should want. Whatever it was, you're aligned now, and the universe is responding to that.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        777 carries a lucky dimension too, but it's not luck like chance. It's the luck of being in tune with yourself so deeply that you notice the opportunities that match your energy. It's synchronicity. It's things falling into place because you're finally moving in the direction your soul wants to go. The external world reflects the internal clarity you've achieved.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1.5rem;">
        The most common trigger for 777 is a moment of genuine spiritual clarity. After meditation or solitude. After therapy or honest self-reflection. After you've stopped trying to be what you thought you should be and started being who you actually are. That shift, that alignment, is what 777 is announcing.
      </p>
      <div style="background:var(--color-light-bg);border:1px solid var(--color-border);border-left:4px solid var(--color-soft-gold);border-radius:8px;padding:1.25rem 1.5rem;">
        <p style="font-size:0.9rem;color:var(--color-muted-text);line-height:1.8;margin:0;">
          <strong style="color:var(--color-body-text);">The core message of 777:</strong> You're on the right path. Your inner work is real and it's working. Keep trusting your intuition. The universe is supporting you right now.
        </p>
      </div>
    </div>
  </section>

  <section style="background:white;padding:3rem 1.5rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">When does 777 show up?</h2>
      <div style="display:flex;flex-direction:column;gap:1rem;">
        <div class="card-light p-5">
          <h3 style="font-weight:700;color:var(--color-body-text);margin:0 0 0.5rem;">After spiritual practice or deep work</h3>
          <p style="font-size:0.875rem;color:var(--color-muted-text);line-height:1.7;margin:0;">You've been meditating regularly, journaling, doing therapy. 777 appears as confirmation that the work is registering. It's the universe saying: yes, what you're doing matters. Keep going.</p>
        </div>
        <div class="card-light p-5">
          <h3 style="font-weight:700;color:var(--color-body-text);margin:0 0 0.5rem;">When you're noticing synchronicities</h3>
          <p style="font-size:0.875rem;color:var(--color-muted-text);line-height:1.7;margin:0;">Events lining up in seemingly impossible ways. Running into the right person at the right time. Getting the answer you needed exactly when you asked. These aren't coincidences — they're synchronicities. 777 shows up when the veil between you and the universe feels thin.</p>
        </div>
        <div class="card-light p-5">
          <h3 style="font-weight:700;color:var(--color-body-text);margin:0 0 0.5rem;">When things are working out almost magically</h3>
          <p style="font-size:0.875rem;color:var(--color-muted-text);line-height:1.7;margin:0;">Opportunities appearing without you forcing them. Doors opening. The right person saying yes. 777 confirms: yes, this is luck. The luck of being aligned. When you're thinking clearly and following your intuition, the world cooperates.</p>
        </div>
        <div class="card-light p-5">
          <h3 style="font-weight:700;color:var(--color-body-text);margin:0 0 0.5rem;">When you need validation that you're on track</h3>
          <p style="font-size:0.875rem;color:var(--color-muted-text);line-height:1.7;margin:0;">You made a big choice. You went with your gut instead of the safe option. You chose truth over comfort. And then 777 shows up. It's the universe saying: you were right. Trust yourself. You knew what you were doing.</p>
        </div>
      </div>
    </div>
  </section>

  <section style="background:var(--color-card-bg);padding:3rem 1.5rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">777 in love &amp; relationships</h2>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        The 7 is not interested in surface connection. In love, 777 is calling for depth and spiritual alignment over superficial chemistry.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        <strong style="color:var(--color-body-text);">If you're single:</strong> 777 is signaling that you're becoming attractive in a different way. Not because you've changed how you look or what you say, but because you've become more genuinely yourself. Stop trying to manifest a partner. Start being so aligned with yourself that the right person can't miss you. When someone meets you, they meet the real you — no performance, no compromise, no waiting to see who they need you to be. That's magnetic. 777 says the right person appears when you're not looking for anyone, just being yourself completely.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        <strong style="color:var(--color-body-text);">If you're in a relationship:</strong> 777 often signals a shift into deeper intimacy through honesty. The relationship is moving from surface connection into genuine understanding. This is where you stop performing and start being real. Where vulnerabilities become bridges instead of weaknesses. The 7 energy demands truth, and that truth deepens the bond. If you're seeing 777, your partner is becoming someone you can be fully yourself with. That's rare. Honor it.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0;">
        <strong style="color:var(--color-body-text);">The 777 relationship lesson:</strong> The deepest love isn't about finding someone who completes you. It's finding someone who loves the person you actually are, not the version you've been performing.
      </p>
    </div>
  </section>

  <section style="background:white;padding:3rem 1.5rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2">777 in career &amp; money</h2>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        The 7 in career favors analysis, research, specialized expertise, and deep understanding. If 777 shows up around work, it's often signaling recognition for exactly that: recognition that your deep work matters.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        This isn't the number of hustle and grind. It's the number of genuine expertise. If you've been building something real, becoming genuinely skilled at something, developing real expertise, doing the unglamorous work of actually understanding your field — 777 is saying: that's about to pay off. Not through luck in the lottery sense, but through the luck of being the person who actually knows what you're doing.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0 0 1rem;">
        Money-wise, 777 often brings financial gain through specialization. You get paid for what you know that others don't. For research, analysis, consulting, deep technical work, healing work, spiritual teaching. The 7 is never the salesperson or the networker. It's the person who's so genuinely expert that people seek them out specifically.
      </p>
      <p style="font-size:0.95rem;color:var(--color-muted-text);line-height:1.8;margin:0;">
        If you've been feeling undervalued for the depth of your work, 777 is saying: that's about to shift. Your real expertise is about to be recognized, not by everyone, but by the people whose recognition actually matters.
      </p>
    </div>
  </section>

  <!-- What to do section -->
  <section style="background:var(--color-light-bg);padding:3rem 1.5rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2" style="text-align:center;">What to do when you see 777</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
        <div style="background:white;border:1px solid var(--color-border);border-radius:12px;padding:1.25rem 1.5rem;">
          <div style="font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-soft-gold);margin-bottom:0.5rem;">Trust your inner knowing</div>
          <p style="font-size:0.9rem;color:var(--color-muted-text);line-height:1.7;margin:0;">That quiet voice inside? The one that's been speaking truthfully all along? Listen to it. 777 is confirmation that your intuition is accurate.</p>
        </div>
        <div style="background:white;border:1px solid var(--color-border);border-radius:12px;padding:1.25rem 1.5rem;">
          <div style="font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-soft-gold);margin-bottom:0.5rem;">Continue your spiritual practice</div>
          <p style="font-size:0.9rem;color:var(--color-muted-text);line-height:1.7;margin:0;">Whatever brought you to alignment (meditation, therapy, journaling, time in nature), keep doing it. The results are speaking for themselves.</p>
        </div>
        <div style="background:white;border:1px solid var(--color-border);border-radius:12px;padding:1.25rem 1.5rem;">
          <div style="font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-soft-gold);margin-bottom:0.5rem;">Follow the synchronicities</div>
          <p style="font-size:0.9rem;color:var(--color-muted-text);line-height:1.7;margin:0;">Pay attention to the breadcrumbs. The coincidences that feel too perfect. The ideas that keep returning. The people who keep appearing. The universe is communicating with you in signs.</p>
        </div>
        <div style="background:white;border:1px solid var(--color-border);border-radius:12px;padding:1.25rem 1.5rem;">
          <div style="font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-soft-gold);margin-bottom:0.5rem;">Let things unfold</div>
          <p style="font-size:0.9rem;color:var(--color-muted-text);line-height:1.7;margin:0;">You're aligned. The work is done. Now get out of your own way. Stop trying to force outcomes. Trust the process and watch what happens when you don't resist.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background:white;padding:3rem 1.5rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="section-h2" style="text-align:center;">Common questions about 777</h2>
      <div class="faq-list">
        {faqSchema.mainEntity.map(item => (
          <details>
            <summary>
              {item.name}
              <svg class="faq-chevron" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-answer">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

    </div>
    <SidebarCTA />
  </div>

  <!-- Other angel numbers -->
  <section style="background:var(--color-light-bg);padding:3rem 1.5rem;border-top:1px solid var(--color-border);">
    <div style="max-width:1100px;margin:0 auto;">

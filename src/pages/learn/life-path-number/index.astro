            </div>
            <div style="padding:1.25rem 1.5rem;">
              <p class="p-label" style="margin-bottom:0.4rem;">Life Path {lp.number}</p>
              <h3 style="font-family:var(--font-family-heading);font-size:1.3rem;font-weight:700;color:var(--color-body-text);margin:0 0 0.5rem;line-height:1.2;">{lp.title}</h3>
              <p style="font-size:0.85rem;color:var(--color-muted-text);line-height:1.65;margin:0 0 0.875rem;">{lp.traits}</p>
              <div style="display:flex;flex-direction:column;gap:0.35rem;font-size:0.78rem;margin-bottom:1rem;">
                <div style="display:flex;gap:0.5rem;"><span style="color:var(--color-soft-gold);font-weight:600;width:5rem;flex-shrink:0;">Strengths:</span><span style="color:var(--color-muted-text);">{lp.strengths}</span></div>
                <div style="display:flex;gap:0.5rem;"><span style="color:#b04a4e;font-weight:600;width:5rem;flex-shrink:0;">Challenges:</span><span style="color:var(--color-muted-text);">{lp.challenges}</span></div>
                <div style="display:flex;gap:0.5rem;"><span style="color:var(--color-violet);font-weight:600;width:5rem;flex-shrink:0;">Career:</span><span style="color:var(--color-muted-text);">{lp.careers}</span></div>
              </div>
              <span style="font-size:0.85rem;font-weight:600;color:var(--color-violet);">Full {lp.number} guide →</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Master Numbers -->
      <div style="margin-top:4rem;padding-top:3.5rem;border-top:1px solid var(--color-border);">
        <div style="text-align:center;margin-bottom:2.5rem;">
          <p class="p-label" style="margin-bottom:1rem;">Special Vibrations</p>
          <h2 style="font-family:var(--font-family-heading);font-size:clamp(1.75rem,4vw,2.75rem);font-weight:700;color:var(--color-body-text);margin:0 0 0.75rem;">
            Master Numbers: 11, 22 &amp; 33
          </h2>
          <div class="p-divider" style="margin:0 auto 1.25rem;"></div>
          <p style="color:var(--color-muted-text);font-size:1rem;line-height:1.7;max-width:560px;margin:0 auto;">
            Master numbers carry amplified gifts, and amplified challenges. If your birth date adds to one of these, you're working with a higher-voltage energy.
          </p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;">
          {masterNumbers.map(mn => (
            <a href={mn.href} class="feat-card" style="text-decoration:none;">
              <div class="feat-img-wrap">
                <img src={mn.image} alt={`Master Number ${mn.number}, ${mn.title}`} loading="lazy" decoding="async" style="width:100%;aspect-ratio:2/3;object-fit:cover;transition:transform 0.5s;" />
              </div>
              <div style="padding:1.25rem 1.5rem;">
                <p class="p-label" style="margin-bottom:0.4rem;">Master Number</p>
                <h3 style="font-family:var(--font-family-heading);font-size:1.3rem;font-weight:700;color:var(--color-body-text);margin:0 0 0.75rem;line-height:1.2;">{mn.title}</h3>
                <p style="font-size:0.85rem;color:var(--color-muted-text);line-height:1.65;margin:0 0 1rem;">{mn.desc}</p>
                <span style="font-size:0.85rem;font-weight:600;color:var(--color-violet);">Full {mn.number} guide →</span>

---
import Layout from '../../../layouts/Layout.astro';
import SidebarCTA from '../../../components/SidebarCTA.astro';
import { karmicDebtNumbers } from '../../../data/karmicDebtNumbers';

export function getStaticPaths() {
  return karmicDebtNumbers.map(kd => ({
    params: { n: String(kd.n) },
    props: { kd },
  }));
}

const { kd } = Astro.props;

const reducesTo: Record<number, number> = { 13: 4, 14: 5, 16: 7, 19: 1 };
const lpTitle: Record<number, string> = { 1: "The Leader", 4: "The Builder", 5: "The Adventurer", 7: "The Seeker" };
const allNumbers = karmicDebtNumbers.map(k => ({ n: k.n, title: k.title }));

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": kd.faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://numerologyguides.blog/" },
    { "@type": "ListItem", "position": 2, "name": "Learn", "item": "https://numerologyguides.blog/learn/" },
    { "@type": "ListItem", "position": 3, "name": "Karmic Debt Numbers", "item": "https://numerologyguides.blog/learn/karmic-debt-numbers/" },
    { "@type": "ListItem", "position": 4, "name": `Karmic Debt ${kd.n}` }
  ]
};
---

<Layout
  schema={[faqSchema, breadcrumbSchema]}
  title={`Karmic Debt Number ${kd.n}: ${kd.title} | Numerology Guides`}
  description={kd.shortDesc}
>

  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" />
  <style>
    :root { --font-family-heading: 'Cormorant Garamond', Georgia, serif; }
    .p-label { font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-soft-gold); font-weight:600; }
    .p-divider { width:48px; height:2px; background:var(--color-soft-gold); margin:0 auto; }
    .section-h2 { font-family:var(--font-family-heading); font-size:clamp(1.6rem,3.5vw,2.25rem); font-weight:700; color:var(--color-body-text); margin:0 0 1.25rem; }
    .faq-list details { border-top:1px solid var(--color-border); }
    .faq-list details:last-child { border-bottom:1px solid var(--color-border); }
    .faq-list summary { padding:1.3rem 0; cursor:pointer; display:flex; align-items:center; justify-content:space-between; gap:1rem; font-weight:600; font-size:1rem; color:var(--color-body-text); list-style:none; transition:color 0.2s; }
    .faq-list summary::-webkit-details-marker { display:none; }
    .faq-list details[open] summary { color:var(--color-violet); }
    .faq-chevron { flex-shrink:0; transition:transform 0.25s; }
    .faq-list details[open] .faq-chevron { transform:rotate(180deg); }
    .faq-answer { padding-bottom:1.3rem; font-size:0.9rem; color:var(--color-muted-text); line-height:1.8; }
  </style>

  <!-- Breadcrumb -->
  <nav style="background:var(--color-card-bg);border-bottom:1px solid var(--color-border);padding:0.75rem 1.5rem;" aria-label="Breadcrumb">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:0.5rem;font-size:0.75rem;color:var(--color-muted-text);">
      <a href="/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Home</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Learn</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <a href="/learn/karmic-debt-numbers/" style="color:inherit;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--color-violet)'" onmouseout="this.style.color='var(--color-muted-text)'">Karmic Debt Numbers</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <span style="color:var(--color-body-text);font-weight:600;">Karmic Debt {kd.n}</span>
    </div>
  </nav>

  <!-- Hero -->
  <section style="position:relative;overflow:hidden;background:var(--color-midnight,#0e0a1a);">
    <div aria-hidden="true" style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(196,162,78,0.07) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>
    <div aria-hidden="true" style="position:absolute;top:-10%;left:-5%;width:55%;height:120%;background:radial-gradient(ellipse at center,rgba(124,92,191,0.18) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>
    <div style="position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:4rem 1.5rem;display:flex;align-items:center;gap:3rem;flex-wrap:wrap;">
      <div style="flex:1;min-width:280px;">
        <p class="p-label" style="margin-bottom:1.1rem;color:var(--color-soft-gold);opacity:0.9;">Karmic Debt Number {kd.n}</p>
        <div class="p-divider" style="margin:0 0 1.6rem;"></div>
        <h1 style="font-family:var(--font-family-heading);font-size:clamp(2.8rem,6vw,5rem);font-weight:700;line-height:1.06;color:#f5f0e8;letter-spacing:-0.02em;margin:0 0 1.25rem;">
          Karmic Debt <em style="color:#c8a8f0;font-style:italic;">{kd.n}</em>: {kd.title}
        </h1>
        <p style="font-size:1.05rem;line-height:1.8;color:rgba(240,234,255,0.78);max-width:460px;margin:0 0 1.25rem;">{kd.heroSubtitle}</p>
        <p style="font-size:0.85rem;color:rgba(196,162,78,0.75);font-weight:500;margin:0 0 2rem;">Reduces to {reducesTo[kd.n]}</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.875rem;">
          <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:1rem;padding:0.875rem 2rem;border-radius:6px;text-decoration:none;transition:background 0.2s,transform 0.15s;box-shadow:0 4px 20px rgba(124,92,191,0.45);" onmouseover="this.style.background='#6a4eab';this.style.transform='translateY(-1px)'" onmouseout="this.style.background='var(--color-violet)';this.style.transform='none'">Get My Free Reading →</a>
          <a href="#meaning" style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.08);backdrop-filter:blur(6px);color:#f5f0e8;font-weight:600;font-size:1rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.2);transition:border-color 0.2s,background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)';this.style.borderColor='rgba(255,255,255,0.4)'" onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.borderColor='rgba(255,255,255,0.2)'">What It Means ↓</a>
        </div>
      </div>
      <div style="flex-shrink:0;width:clamp(200px,28vw,300px);filter:drop-shadow(0 8px 40px rgba(196,162,78,0.25)) drop-shadow(0 2px 12px rgba(0,0,0,0.6));">
        <img
          src={`/images/learn/karmic-debt-numbers/Karmic Debt Number - ${kd.title}.webp`}
          alt={`Karmic Debt Number ${kd.n} — ${kd.title}`}
          fetchpriority="high"
          style="width:100%;border-radius:6px;display:block;"
        />
      </div>
    </div>
  </section>

  <!-- Author byline -->
  <div style="background:var(--color-light-bg);padding:1.25rem 1.5rem;">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:1rem;">
      <img src="/images/author-maddi-green.webp" alt="Maddie Greene" style="width:2.75rem;height:2.75rem;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid rgba(124,92,191,0.2);" />
      <div>
        <p style="color:var(--color-body-text);font-size:0.875rem;font-weight:600;margin:0 0 0.1rem;">Written by <strong>Maddie Greene</strong></p>
        <p style="color:var(--color-muted-text);font-size:0.78rem;margin:0;">Numerology writer &amp; researcher</p>
      </div>
    </div>
  </div>

  <!-- Content + Sticky sidebar wrapper -->
  <div class="xl:flex xl:gap-6 xl:max-w-[1200px] xl:mx-auto xl:px-4">
    <!-- Main content column -->
    <div class="xl:flex-1 xl:min-w-0">

  <!-- Main content -->
  <article style="padding:2.5rem 1.5rem 3rem;background:white;">
    <div style="max-width:48rem;margin:0 auto;">

      <!-- What it means -->
      <section id="meaning" style="margin-bottom:3rem;">
        <h2 class="section-h2">What karmic debt {kd.n} means</h2>
        <div style="display:flex;flex-direction:column;gap:1rem;">
          {kd.whatItMeans.map(para => <p style="color:var(--color-body-text);line-height:1.8;">{para}</p>)}
        </div>
      </section>

      <!-- How to know if you have it -->
      <section id="how-to-know" style="margin-bottom:3rem;padding-top:2rem;border-top:1px solid var(--color-border);">
        <h2 class="section-h2">How to know if you have it</h2>
        <div style="display:flex;flex-direction:column;gap:1rem;">
          {kd.howToKnow.map(para => <p style="color:var(--color-body-text);line-height:1.8;">{para}</p>)}
        </div>
      </section>

      <!-- Life lessons -->
      <section id="lessons" style="margin-bottom:3rem;padding-top:2rem;border-top:1px solid var(--color-border);">
        <h2 class="section-h2">The life lessons of {kd.n}</h2>
        <div style="display:flex;flex-direction:column;gap:1rem;">
          {kd.lifeLessons.map(para => <p style="color:var(--color-body-text);line-height:1.8;">{para}</p>)}
        </div>
      </section>

      <!-- Strengths & challenges -->
      <section id="strengths" style="margin-bottom:3rem;padding-top:2rem;border-top:1px solid var(--color-border);">
        <h2 class="section-h2">Strengths &amp; challenges</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.5rem;">
          <div>
            <h3 style="font-family:var(--font-family-heading);font-size:1.1rem;font-weight:700;color:var(--color-body-text);margin:0 0 1rem;display:flex;align-items:center;gap:0.5rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" style="color:#6abf69;" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              What works for you
            </h3>
            <div style="display:flex;flex-direction:column;gap:1rem;">
              {kd.strengths.map(s => (
                <div class="card-light p-5">
                  <div style="font-weight:600;color:var(--color-body-text);margin-bottom:0.3rem;">{s.title}</div>
                  <p style="font-size:0.875rem;color:var(--color-muted-text);line-height:1.7;margin:0;">{s.desc}</p>
                </div>
              ))}
            </div>
          </div>
          <div>
            <h3 style="font-family:var(--font-family-heading);font-size:1.1rem;font-weight:700;color:var(--color-body-text);margin:0 0 1rem;display:flex;align-items:center;gap:0.5rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#f87171;" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              What to watch
            </h3>
            <div style="display:flex;flex-direction:column;gap:1rem;">
              {kd.challenges.map(c => (
                <div class="card-light p-5">
                  <div style="font-weight:600;color:var(--color-body-text);margin-bottom:0.3rem;">{c.title}</div>
                  <p style="font-size:0.875rem;color:var(--color-muted-text);line-height:1.7;margin:0;">{c.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Practical guidance -->
      <section id="guidance" style="margin-bottom:3rem;padding-top:2rem;border-top:1px solid var(--color-border);">
        <h2 class="section-h2">Practical guidance</h2>
        <div style="display:flex;flex-direction:column;gap:1rem;">
          {kd.practicalGuidance.map(para => <p style="color:var(--color-body-text);line-height:1.8;">{para}</p>)}
        </div>
      </section>

      <!-- FAQ -->
      <section id="faq" style="margin-bottom:3rem;padding-top:2rem;border-top:1px solid var(--color-border);">
        <h2 class="section-h2" style="text-align:center;">Common questions</h2>
        <div class="faq-list">
          {kd.faq.map(item => (
            <details>
              <summary>
                {item.q}
                <svg class="faq-chevron" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <p class="faq-answer">{item.a}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- All karmic debt numbers -->
      <section id="all" style="margin-bottom:1rem;padding-top:2rem;border-top:1px solid var(--color-border);">
        <h2 class="section-h2">All karmic debt numbers</h2>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem;">
          {allNumbers.map(num => (
            <a
              href={`/learn/karmic-debt-numbers/${num.n}/`}
              style={num.n === kd.n
                ? "display:block;padding:1rem;text-align:center;border-radius:8px;border:2px solid var(--color-soft-gold);background:rgba(196,162,78,0.08);text-decoration:none;"
                : "display:block;padding:1rem;text-align:center;border-radius:8px;border:1px solid var(--color-border);background:var(--color-card-bg);text-decoration:none;transition:border-color 0.2s;"
              }
              onmouseover={num.n !== kd.n ? "this.style.borderColor='var(--color-violet)'" : ""}
              onmouseout={num.n !== kd.n ? "this.style.borderColor='var(--color-border)'" : ""}
            >
              <div style={num.n === kd.n
                ? "font-family:var(--font-family-heading);font-size:1.75rem;font-weight:700;color:var(--color-soft-gold);line-height:1;"
                : "font-family:var(--font-family-heading);font-size:1.75rem;font-weight:700;color:var(--color-body-text);line-height:1;"
              }>{num.n}</div>
              <div style="font-size:0.7rem;margin-top:0.25rem;color:var(--color-muted-text);">{num.title.replace('The Debt of ', '')}</div>
            </a>
          ))}
        </div>
      </section>

    </div>
  </article>

  <!-- Related guides -->
  <section style="padding:2.5rem 1.5rem;background:var(--color-card-bg);border-top:1px solid var(--color-border);">
    <div style="max-width:48rem;margin:0 auto;">
      <h2 class="section-h2">Related guides</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1.25rem;">
        <a href="/learn/karmic-debt-numbers/" class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block">
          <img src="/images/learn/Karmic Debt Numbers - Tile.webp" alt="Karmic Debt Numbers" class="w-full aspect-[2/3] object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          <div class="p-4">
            <h3 class="font-semibold text-body-text group-hover:text-violet transition-colors mb-1">Karmic Debt Numbers</h3>
            <p class="text-xs text-muted-text">Overview of all four karmic debts</p>
          </div>
        </a>
        <a href={`/learn/life-path-number-${reducesTo[kd.n]}/`} class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block">
          <img src={`/images/learn/Life Path Number ${reducesTo[kd.n]} - ${lpTitle[reducesTo[kd.n]]}.webp`} alt={`Life Path ${reducesTo[kd.n]}`} class="w-full aspect-[2/3] object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          <div class="p-4">
            <h3 class="font-semibold text-body-text group-hover:text-violet transition-colors mb-1">Life Path {reducesTo[kd.n]}</h3>
            <p class="text-xs text-muted-text">The base number that {kd.n} reduces to</p>
          </div>
        </a>
        <a href="/learn/master-numbers/" class="card-light overflow-hidden hover:border-violet/60 hover:-translate-y-0.5 transition-all duration-200 group block">
          <img src="/images/learn/Master Numbers - Tile.webp" alt="Master Numbers" class="w-full aspect-[2/3] object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          <div class="p-4">
            <h3 class="font-semibold text-body-text group-hover:text-violet transition-colors mb-1">Master Numbers</h3>
            <p class="text-xs text-muted-text">11, 22, 33 — the other special numbers</p>
          </div>
        </a>
      </div>
    </div>
  </section>

    </div><!-- end main content column -->
    <SidebarCTA />
  </div><!-- end flex wrapper -->

  <!-- Bottom CTA -->
  <section style="background:var(--color-midnight);padding:5rem 1.5rem;text-align:center;">
    <div style="max-width:36rem;margin:0 auto;">
      <p class="p-label" style="color:rgba(196,162,78,0.7);margin-bottom:0.75rem;">Go Deeper</p>
      <h2 style="font-family:var(--font-family-heading);font-size:clamp(1.75rem,4vw,2.5rem);font-weight:700;color:var(--color-starlight);margin:0 0 1rem;">See how your numbers interact</h2>
      <p style="color:rgba(255,255,255,0.65);font-size:1rem;line-height:1.75;margin-bottom:2rem;">Karmic debt is one layer of your chart. A full reading shows how it connects to your life path, expression number, soul urge, and personality number — so you can see the whole picture, not just one piece.</p>
      <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" rel="noopener sponsored" style="display:inline-block;background:var(--color-soft-gold);color:var(--color-midnight);font-weight:700;font-size:1rem;padding:0.9rem 2.25rem;border-radius:6px;text-decoration:none;letter-spacing:0.02em;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.88'" onmouseout="this.style.opacity='1'">Get Your Free Numerology Reading</a>
    </div>
  </section>

</Layout>

---
import Layout from '../../../layouts/Layout.astro';
import SidebarCTA from '../../../components/SidebarCTA.astro';

const compatData = [
 { number: 1, title: "The Leader", match: "strong", note: "Classic pairing. 1's direction and 2's emotional depth balance each other well." },
 { number: 2, title: "The Peacemaker", match: "good", note: "Two 2s understand each other, but both avoid conflict - decisions can stall." },
 { number: 3, title: "The Communicator", match: "strong", note: "3's warmth and expressiveness fits naturally with 2's need for connection." },
 { number: 4, title: "The Builder", match: "good", note: "4's stability gives 2 the security they need. Both are loyal." },
 { number: 5, title: "The Adventurer", match: "challenging", note: "5 needs freedom; 2 needs closeness. The gap can be hard to bridge." },
 { number: 6, title: "The Nurturer", match: "strong", note: "One of the best matches. Both value harmony, home, and deep connection." },
 { number: 7, title: "The Seeker", match: "good", note: "7 needs space; 2 needs reassurance. Works if both communicate openly." },
 { number: 8, title: "The Powerhouse", match: "good", note: "8's ambition can leave 2 feeling unseen, but mutual respect makes it work." },
 { number: 9, title: "The Humanitarian", match: "strong", note: "9's compassion and 2's empathy create a naturally caring partnership." },
];

const matchColor: Record<string, string> = {
 strong: "text-rpg-green",
 good: "text-soft-gold",
 challenging: "text-red-400",
};

const careers = [
 { role: "Counsellor / Therapist", why: "Natural emotional attunement makes them exceptional at holding space for others." },
 { role: "Mediator / Diplomat", why: "The ability to find common ground and keep the peace is almost instinctive." },
 { role: "Nurse / Social Worker", why: "The desire to nurture others is well-suited to caring professions." },
 { role: "HR / People Ops", why: "Skilled at understanding needs and desires of others in workplace dynamics." },
 { role: "Teacher / Life Coach", why: "Patient, empathetic, and invested in others' growth." },
 { role: "Artist / Musician", why: "Emotional depth and intuition often translate into meaningful creative work." },
];

const famous = [
 "Barack Obama",
 "Jennifer Aniston",
 "Diana, Princess of Wales",
 "Tony Blair",
 "Kim Kardashian",
 "Bill Clinton",
 "Wolfgang Amadeus Mozart",
 "Emma Watson",
];

const faqSchema = {
 "@context": "https://schema.org",
 "@type": "FAQPage",
 "mainEntity": [
 { "@type": "Question", "name": "What does it mean to have a life path of 2?", "acceptedAnswer": { "@type": "Answer", "text": "Having life path number 2 means your core personality is oriented toward cooperation, empathy, and relationship. You're probably a natural mediator - someone who instinctively reads the room, avoids confrontation, and works to create peace and harmony rather than conflict. The meaning of life path number 2 in your numerology chart is that your life purpose involves connection, partnership, and learning to balance your own needs with your instinct to put others first. People with a life path number 2 often find that their most meaningful growth comes through close relationships rather than individual achievement." } },
 { "@type": "Question", "name": "Why is life path 2 rare?", "acceptedAnswer": { "@type": "Answer", "text": "Life path 2 is considered rare because the arithmetic of birth dates makes it statistically less common than some other numbers. To get a 2, your full birth date needs to reduce to exactly 2 - and given the distribution of calendar dates, certain life path numbers come up more frequently than others. Life path 11 also doesn't reduce to a 2 (it stays as 11), which removes some dates from the pool. The traits themselves - deep empathy, patience, and a genuine preference for cooperation over competition - do feel less common in everyday life, which reinforces the perception." } },
 { "@type": "Question", "name": "Who should life path number 2 marry?", "acceptedAnswer": { "@type": "Answer", "text": "The best life path matches for a 2 are typically 1, 6, and 9. Life path 1 provides the decisiveness and direction that 2 sometimes lacks, while the 2's emotional depth balances the 1's tendency to focus outward. Life path 6 is another natural match - both value home, harmony, and deep loyalty. Life path 9's broad compassion pairs well with the 2's personal warmth. Two life path 2s together can work beautifully, but both partners' tendency to avoid confrontation can mean important things go unsaid. Life path 5 is typically the most challenging match for the 2: the 5 needs freedom and movement, while the 2 needs closeness and consistency." } },
 { "@type": "Question", "name": "Does life path number 2 attract money?", "acceptedAnswer": { "@type": "Answer", "text": "Not directly. Of all the life paths, the 2 is not the most financially driven. That's more the territory of life path 8. But life path 2 individuals often do well professionally over time because people trust them, want to work with them, and advocate for them. They build strong networks through genuine care rather than strategy. In careers in counseling, mediation, healthcare, and people-oriented fields, they often rise steadily. The financial story for a 2 is usually tied to doing work that aligns with their life purpose - when that alignment is there, the resources tend to follow." } },
 { "@type": "Question", "name": "What is the spiritual meaning of life path 2?", "acceptedAnswer": { "@type": "Answer", "text": "The spiritual meaning of life path 2 is about learning to balance giving and receiving. The 2 comes into this life with a strong capacity for love, compassion, and connection - their role as a bridge between people is genuine. The spiritual path for the 2 involves developing a stronger relationship with the self: learning that their own needs matter as much as anyone else's, that saying no isn't selfish, and that authentic self-expression is part of the work, not a distraction from it. Practices like meditation and yoga tend to resonate strongly with this number." } },
 { "@type": "Question", "name": "What is life path 11's connection to life path 2?", "acceptedAnswer": { "@type": "Answer", "text": "Life path 11 is a master number that, when reduced, becomes a 2. People with life path 11 share many of the 2's qualities : sensitivity, intuition, and a strong relational intelligence : but carry them at a higher level of intensity. Where the 2 supports, the 11 inspires. Not everyone with an 11 in their birth date qualifies as a master number - it depends on how the full date reduces. Those who do tend to experience the 2's challenges (emotional overwhelm, self-doubt, people-pleasing) in amplified form." } }
 ]
};

const breadcrumbSchema = {
 "@context": "https://schema.org",
 "@type": "BreadcrumbList",
 "itemListElement": [
 { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://numerologyguides.blog/" },
 { "@type": "ListItem", "position": 2, "name": "Learn", "item": "https://numerologyguides.blog/learn/" },
 { "@type": "ListItem", "position": 3, "name": "Life Path Numbers", "item": "https://numerologyguides.blog/learn/life-path-number/" },
 { "@type": "ListItem", "position": 4, "name": "Life Path 2" }
 ]
};
---

<Layout
 schema={[faqSchema, breadcrumbSchema]}
 title="Life Path Number 2: The Peacemaker - Traits, Careers & Compatibility | Numerology Guides"
 description="Life path number 2 is the most empathetic and relationship-oriented of all the life paths - built for connection, cooperation, and creating harmony. Full trait, career and compatibility guide."
>

 <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" />

 <style>
   :root { --font-family-heading: 'Cormorant Garamond', Georgia, serif; }
   .p-label { font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-soft-gold); font-weight:600; }
   .p-divider { width:48px; height:2px; background:var(--color-soft-gold); margin:0 auto; }
   .section-h2 { font-family:var(--font-family-heading); font-size:clamp(1.6rem,3.5vw,2.25rem); font-weight:700; color:var(--color-body-text); margin:0 0 1.25rem; }
   .faq-list details { border-top:1px solid var(--color-border); }
   .faq-list details:last-child { border-bottom:1px solid var(--color-border); }
   .faq-list summary { padding:1.3rem 0; cursor:pointer; display:flex; align-items:center; justify-content:space-between; gap:1rem; font-weight:600; font-size:1rem; color:var(--color-body-text); list-style:none; transition:color 0.2s; }
   .faq-list summary::-webkit-details-marker { display:none; }
   .faq-list details[open] summary { color:var(--color-violet); }
   .faq-chevron { flex-shrink:0; transition:transform 0.25s; }
   .faq-list details[open] .faq-chevron { transform:rotate(180deg); }
   .faq-answer { padding-bottom:1.3rem; font-size:0.9rem; color:var(--color-muted-text); line-height:1.8; }
   .lp-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:0.75rem; }
   @media (max-width:640px) { .lp-grid { grid-template-columns:repeat(3,1fr); } }
   .feat-card { display:block; background:white; border:1px solid var(--color-border); border-radius:8px; overflow:hidden; text-decoration:none; transition:box-shadow 0.25s, transform 0.25s; }
   .feat-card:hover { box-shadow:0 12px 40px rgba(26,21,40,0.1); transform:translateY(-3px); }
   .feat-img-wrap { overflow:hidden; }
   .feat-card img { width:100%; aspect-ratio:2/3; object-fit:cover; transition:transform 0.5s; }
   .feat-card:hover img { transform:scale(1.05); }
 </style>

 <!-- Breadcrumb -->
 <nav style="background:var(--color-card-bg);border-bottom:1px solid var(--color-border);padding:0.75rem 1.5rem;" aria-label="Breadcrumb">
   <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:0.5rem;font-size:0.75rem;color:var(--color-muted-text);">
     <a href="/" style="color:var(--color-muted-text);text-decoration:none;">Home</a>
     <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
     <a href="/learn/" style="color:var(--color-muted-text);text-decoration:none;">Learn</a>
     <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
     <a href="/learn/life-path-number/" style="color:var(--color-muted-text);text-decoration:none;">Life Path Numbers</a>
     <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
     <span style="color:var(--color-body-text);font-weight:600;">Life Path Number 2</span>
   </div>
 </nav>

 <!-- Hero -->
 <section style="position:relative;overflow:hidden;background:var(--color-midnight,#0e0a1a);">
   <div aria-hidden="true" style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(196,162,78,0.07) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>
   <div aria-hidden="true" style="position:absolute;top:-10%;left:-5%;width:55%;height:120%;background:radial-gradient(ellipse at center,rgba(124,92,191,0.18) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>
   <div style="position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:4rem 1.5rem;display:flex;align-items:center;gap:3rem;flex-wrap:wrap;">
     <div style="flex:1;min-width:280px;">
       <p class="p-label" style="margin-bottom:1.1rem;color:var(--color-soft-gold);opacity:0.9;">Life Path Number 2</p>
       <div class="p-divider" style="margin:0 0 1.6rem;"></div>
       <h1 style="font-family:var(--font-family-heading);font-size:clamp(2.8rem,6vw,5rem);font-weight:700;line-height:1.06;color:#f5f0e8;letter-spacing:-0.02em;margin:0 0 1.25rem;">
         The <em style="color:#c8a8f0;font-style:italic;">Peacemaker</em>
       </h1>
       <p style="font-size:1.05rem;line-height:1.8;color:rgba(240,234,255,0.78);max-width:460px;margin:0 0 2rem;">The 2 is numerology's most attuned to other people. No number reads a room like the 2. Not the loudest. Not the most ambitious. But the one holding it all together.</p>
       <div style="display:flex;flex-wrap:wrap;gap:0.875rem;">
         <a href="https://8904b5z1168aar3k8annz7y61n.hop.clickbank.net" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--color-violet);color:white;font-weight:700;font-size:1rem;padding:0.875rem 2rem;border-radius:6px;text-decoration:none;transition:background 0.2s,transform 0.15s;box-shadow:0 4px 20px rgba(124,92,191,0.45);" onmouseover="this.style.background='#6a4eab';this.style.transform='translateY(-1px)'" onmouseout="this.style.background='var(--color-violet)';this.style.transform='none'">Get My Free Reading →</a>
         <a href="#compatibility" style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.08);backdrop-filter:blur(6px);color:#f5f0e8;font-weight:600;font-size:1rem;padding:0.875rem 1.75rem;border-radius:6px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.2);transition:border-color 0.2s,background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)';this.style.borderColor='rgba(255,255,255,0.4)'" onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.borderColor='rgba(255,255,255,0.2)'">Find Your Best Match ↓</a>
       </div>
     </div>
     <div style="flex-shrink:0;width:clamp(200px,28vw,300px);filter:drop-shadow(0 8px 40px rgba(196,162,78,0.25)) drop-shadow(0 2px 12px rgba(0,0,0,0.6));">
       <img src="/images/learn/Life Path Number 2 - The Peacemaker.webp" alt="Life Path 2 — The Peacemaker tarot card" fetchpriority="high" style="width:100%;border-radius:6px;display:block;" />
     </div>
   </div>
 </section>

 <!-- Author byline -->
 <div style="background:var(--color-light-bg);padding:1.25rem 1.5rem;">
   <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:1rem;">
     <img src="/images/author-maddi-green.webp" alt="Maddie Greene" style="width:2.75rem;height:2.75rem;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid rgba(124,92,191,0.2);" />
     <div>
       <p style="color:var(--color-body-text);font-size:0.875rem;font-weight:600;margin:0 0 0.1rem;">Written by <strong>Maddie Greene</strong></p>
       <p style="color:var(--color-muted-text);font-size:0.78rem;margin:0;">Numerology writer &amp; researcher</p>
     </div>
   </div>
 </div>

 <!-- Content + Sticky sidebar wrapper -->
 <div class="xl:flex xl:gap-6 xl:max-w-[1200px] xl:mx-auto xl:px-4">
   <!-- Main content column -->
   <div class="xl:flex-1 xl:min-w-0">

 <!-- Main content -->
 <article style="padding:2rem 1.5rem 3rem;background:var(--color-card-bg);">
 <div class="max-w-3xl mx-auto xl:mx-0 xl:max-w-none">

 <!-- What it means -->
 <section id="meaning" style="margin-bottom:3rem;">
 <h2 class="section-h2">What life path number 2 means</h2>

 <p class="text-body-text leading-relaxed mb-4">
 Your life path number comes from your full birth date, reduced to a single digit. The 2 sits right after the 1, and that matters. Where 1 leads, 2 connects. Where other numbers move by force or ambition, 2 moves through relationship. The 2 reads people with an almost uncanny accuracy.
 </p>
 <p class="text-body-text leading-relaxed mb-4">
 2s are natural peacemakers. They don't seek the spotlight. They want everyone in the room to feel heard. Finding common ground, smoothing tension, keeping peace - it's not an act. It's how their mind works.
 </p>
 <p class="text-body-text leading-relaxed mb-4">
 But 2 gets misread as weak. It isn't. The 2's diplomacy is a skill. Reading a room, knowing what someone needs before they say it, navigating conflict without escalating it - that's rare.
 </p>
 <p class="text-body-text leading-relaxed">
 The challenge for life path 2 isn't stepping up. It's speaking up. Among the nine life paths, the 2 is most likely to defer, to avoid confrontation, to absorb others' emotions rather than voice their own. The work for this number is learning to advocate for their own needs without guilt. In feeling, the 2 usually knows exactly what's true - the difficulty is saying it out loud.
 </p>
 </section>

 <!-- Image -->
 <div class="mb-10 rounded-lg overflow-hidden border border-border/60 shadow-lg">
 <img
 src="/images/learn/Life Path Number 2 - Traits.webp"
 alt="Two glowing figures reaching toward each other representing Life Path 2 connection and harmony"
 class="w-full object-cover max-h-72"
 loading="lazy"
 />
 </div>

 <!-- Personality traits -->
 <section id="traits" style="margin-bottom:3rem;">
 <h2 class="section-h2">Personality traits</h2>

 <p class="text-body-text leading-relaxed mb-6">
 Anyone who knows a 2 will see themselves here. These traits show up across 2s in all kinds of lives: sensitivity, cooperation, connection.
 </p>

 <div class="grid md:grid-cols-2 gap-6 mb-8">
 <div class="card-light p-6">
 <h3 style="font-family:var(--font-family-heading);font-weight:700;color:var(--color-body-text);margin:0 0 1rem;display:flex;align-items:center;gap:0.5rem;font-size:1.1rem;">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" style="color:#4a9e5c;" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
 Strengths
 </h3>
 <ul class="space-y-3">
 {[
 ["Empathy", "The 2's ability to feel what others feel, and to respond to it without making it about themselves, is the defining quality of this number."],
 ["Diplomacy", "Conflict resolution comes naturally. 2 life path individuals find the language that creates mutual respect, even in tense situations."],
 ["Cooperation", "Unlike most life paths, the 2 prefers working with others over working alone. They're built for partnership."],
 ["Intuition", "There's a strong intuitive thread in the 2. They often know things without knowing how they know them, and they're usually right."],
 ["Patience", "2s are careful, deliberate, and willing to wait. They understand that creating harmony doesn't happen quickly."],
 ].map(([title, desc]) => (
 <li class="flex items-start gap-2 text-sm">
 <span class="text-rpg-green font-bold mt-0.5 shrink-0">+</span>
 <span><span class="font-semibold text-body-text">{title}:</span> <span class="text-muted-text">{desc}</span></span>
 </li>
 ))}
 </ul>
 </div>

 <div class="card-light p-6">
 <h3 style="font-family:var(--font-family-heading);font-weight:700;color:var(--color-body-text);margin:0 0 1rem;display:flex;align-items:center;gap:0.5rem;font-size:1.1rem;">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#c0444a;" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
 Challenges of life path 2
 </h3>
 <ul class="space-y-3">
 {[
 ["Avoiding confrontation", "The 2's instinct to avoid conflict can become avoidance - swallowing things that should be said, building quiet resentment over time."],
 ["People-pleasing", "Because the 2 is so attuned to others' needs and desires, their own needs can get buried. They say yes when they mean no, and feel it later."],
 ["Over-dependence", "2s connect deeply, which is a strength, but they can become over-reliant on relationships for their sense of self and wellbeing."],
 ["Indecision", "The same quality that makes 2s great mediators (seeing all sides) makes independent decisions hard. Two equally valid options can feel paralysing."],
 ["Absorbing others' emotions", "2s are so empathetic they can take on others' anger, fear, or sadness as their own. Without boundaries, this is draining."],
 ].map(([title, desc]) => (
 <li class="flex items-start gap-2 text-sm">
 <span style="color:#c0444a;font-weight:700;margin-top:0.1rem;flex-shrink:0;">-</span>
 <span><span class="font-semibold text-body-text">{title}:</span> <span class="text-muted-text">{desc}</span></span>
 </li>
 ))}
 </ul>
 </div>
 </div>

 <div class="card-light" style="padding:1.25rem;border-left:4px solid var(--color-violet);">
 <p class="text-sm text-muted-text leading-relaxed">
 <span class="font-semibold text-body-text">Why life path 2 is sometimes called rare:</span> The math of birthdays makes 2 statistically less common than some other numbers. But rarity isn't the real point. What's distinctive is how 2s navigate conflict. They find common ground where others see only friction. Diplomatic. That's the 2.
 </p>
 </div>
 </section>

 <!-- Love & relationships -->
 <section id="relationships" style="margin-bottom:3rem;">
 <h2 class="section-h2">Love & relationships</h2>

 <p class="text-body-text leading-relaxed mb-4">
 Relationships are where 2s shine. And where they're most vulnerable. The 2 doesn't just want a partner - they need one. It's not a flaw. It's how they're wired. Connection isn't optional for this number.
 </p>
 <p class="text-body-text leading-relaxed mb-4">
 In a good relationship, the 2 is warm, attentive, deeply loyal, and extraordinary at making their partner feel seen. They remember things. They notice changes. They're the person who knows what you need before you've said it. That kind of presence isn't something other life paths replicate easily.
 </p>
 <p class="text-body-text leading-relaxed mb-4">
 The risk is giving too much and receiving too little. The 2's instinct to nurture can lead to unbalanced dynamics where they're always the one adjusting, accommodating, and smoothing things over. Over time, unspoken needs create distance. The 2 that learns to voice what they need, calmly, directly, ends up in far more honest and durable partnerships.
 </p>
 <p class="text-body-text leading-relaxed">
 Among the best matches for life path 2 are the 1, 6, and 9. Life path 1 provides direction and decisiveness that balances 2's tendency toward indecision. Life path 6 shares the 2's commitment to home and connection; life path 9 brings a wide compassion that pairs naturally with 2's emotional depth. Other numbers in your chart affect compatibility too - which is where a full reading from Numerologist.com adds real detail beyond the life path number alone.
 </p>

 <!-- Compatibility grid -->
 <h3 class="text-lg font-bold font-[family-name:var(--font-family-heading)] text-body-text mt-8 mb-4">LP2 compatibility across all life paths</h3>
 <div style="overflow-x:auto;">
 <table style="width:100%;font-size:0.875rem;border-collapse:collapse;border:1px solid var(--color-border);border-radius:8px;overflow:hidden;box-shadow:0 2px 12px rgba(26,21,40,0.07);">
 <thead>
 <tr style="background:var(--color-light-bg);border-bottom:2px solid var(--color-border);">
 <th style="text-align:left;padding:0.875rem 1rem;font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-soft-gold);">Life path</th>
 <th style="text-align:left;padding:0.875rem 1rem;font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-soft-gold);">Match</th>
 <th style="text-align:left;padding:0.875rem 1rem;font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-soft-gold);" class="hidden md:table-cell">Notes on 2 compatibility</th>
 </tr>
 </thead>
 <tbody>
 {compatData.map(row => (
 <tr style="border-bottom:1px solid var(--color-border);">
 <td style="padding:0.75rem 1rem;">
 <span style="font-weight:600;color:var(--color-body-text);">LP {row.number}</span>
 <span style="color:var(--color-muted-text);margin-left:0.35rem;font-size:0.78rem;">— {row.title}</span>
 </td>
 <td style="padding:0.75rem 1rem;">
 <span style={`font-weight:600;text-transform:capitalize;color:${row.match === 'strong' ? '#4a9e5c' : row.match === 'good' ? 'var(--color-soft-gold)' : '#c0444a'};`}>{row.match}</span>
 </td>
 <td style="padding:0.75rem 1rem;color:var(--color-muted-text);font-size:0.82rem;" class="hidden md:table-cell">{row.note}</td>
 </tr>
 ))}
 </tbody>
 </table>
 </div>
 </section>

 <!-- Career -->
 <section id="career" style="margin-bottom:3rem;">
 <h2 class="section-h2">Career paths for life path 2</h2>

 <p class="text-body-text leading-relaxed mb-6">
 2s gravitate to careers in helping, connecting, creating conditions for others. Counseling, mediation, education, healthcare, the arts - they cluster there because 2s are actually good at those things.
 </p>
 <p class="text-body-text leading-relaxed mb-6">
 2s struggle in competitive, win-at-any-cost environments. Not because they can't handle pressure. It's the culture itself. They thrive where work involves real connection and their relational skill is valued, not exploited.
 </p>

 <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
 {careers.map(c => (
 <div class="card-light p-4">
 <div class="font-semibold text-body-text font-[family-name:var(--font-family-heading)] mb-1">{c.role}</div>
 <div class="text-xs text-muted-text leading-relaxed">{c.why}</div>
 </div>
 ))}
 </div>

 <p class="text-body-text leading-relaxed">
 Yoga, counseling, mental health work also suit 2s. Their intuition and ability to hold space are real strengths. The trap: environments that look harmonious but punish honesty underneath. That burns 2s out fast.
 </p>
 </section>


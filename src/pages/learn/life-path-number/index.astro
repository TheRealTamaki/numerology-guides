<script>
  const LP_LABELS: Record<string, string> = {
    "1": "The Leader", "2": "The Peacemaker", "3": "The Communicator",
    "4": "The Builder", "5": "The Adventurer", "6": "The Nurturer",
    "7": "The Seeker", "8": "The Powerhouse", "9": "The Humanitarian",
    "11": "The Intuitive - Master Number",
    "22": "The Master Builder - Master Number",
    "33": "The Master Teacher - Master Number",
  };

  const LP_BLURBS: Record<string, string> = {
    "1": "Independent, driven, and built to lead. The 1 is here to forge their own path - and they usually do.",
    "2": "Empathetic, diplomatic, and most alive in partnership. The most relationship-oriented number in the chart.",
    "3": "Creative, expressive, and magnetic. The 3 is driven by a deep need to connect and communicate.",
    "4": "Practical, disciplined, and reliable. The 4 builds things that last - systems, structures, foundations.",
    "5": "Freedom-seeking, curious, and adaptable. For the 5, change isn't a challenge - it's oxygen.",
    "6": "Caring, responsible, and community-minded. The 6's purpose centres on family, service, and creating beauty.",
    "7": "Analytical, introspective, and relentlessly curious. The 7 needs to understand what's beneath the surface.",
    "8": "Ambitious, authoritative, and materially focused. The 8 understands how power and resources work.",
    "9": "Compassionate, wise, and big-picture minded. The 9 is here to serve - the most selfless number.",
    "11": "Visionary and spiritually sensitive. The 11 carries intense intuition and a demanding inner life.",
    "22": "Visionary and pragmatic in equal measure. The 22 is built to construct something that outlasts them.",
    "33": "The rarest life path. Extraordinary compassion, healing instinct, and spiritual depth.",
  };

  function lpDigitSum(n: number): number {
    return String(n).split('').reduce((a, d) => a + parseInt(d), 0);
  }

  function lpReduceWithSteps(n: number): { value: number; steps: string } {
    if (n <= 9) return { value: n, steps: String(n) };
    const digits = String(n).split('').join('+');
    let sum = lpDigitSum(n);
    if (sum === 11 || sum === 22 || sum === 33) return { value: sum, steps: `${n} → ${digits} = ${sum}` };
    if (sum <= 9) return { value: sum, steps: `${n} → ${digits} = ${sum}` };
    const digits2 = String(sum).split('').join('+');
    const final = lpDigitSum(sum);
    return { value: final, steps: `${n} → ${digits} = ${sum} → ${digits2} = ${final}` };
  }

  function lpReduceYear(year: number): { value: number; steps: string } {
    const digits = String(year).split('').join('+');
    let sum = lpDigitSum(year);
    if (sum === 11 || sum === 22 || sum === 33) return { value: sum, steps: `${year} → ${digits} = ${sum}` };
    if (sum <= 9) return { value: sum, steps: `${year} → ${digits} = ${sum}` };
    const digits2 = String(sum).split('').join('+');
    let sum2 = lpDigitSum(sum);
    if (sum2 === 11 || sum2 === 22 || sum2 === 33) return { value: sum2, steps: `${year} → ${digits} = ${sum} → ${digits2} = ${sum2}` };
    if (sum2 <= 9) return { value: sum2, steps: `${year} → ${digits} = ${sum} → ${digits2} = ${sum2}` };
    const digits3 = String(sum2).split('').join('+');
    const sum3 = lpDigitSum(sum2);
    return { value: sum3, steps: `${year} → ${digits} = ${sum} → ${digits2} = ${sum2} → ${digits3} = ${sum3}` };
  }

  function lpToAddend(n: number): number {
    if (n === 11) return 2; if (n === 22) return 4; if (n === 33) return 6; return n;
  }

  function lpReduceFinal(n: number): { value: number; steps: string } {
    if (n === 11 || n === 22 || n === 33) return { value: n, steps: String(n) };
    if (n <= 9) return { value: n, steps: String(n) };
    const digits = String(n).split('').join('+');
    const sum = lpDigitSum(n);
    if (sum === 11 || sum === 22 || sum === 33) return { value: sum, steps: `${n} → ${digits} = ${sum}` };
    if (sum <= 9) return { value: sum, steps: `${n} → ${digits} = ${sum}` };
    const digits2 = String(sum).split('').join('+');
    const sum2 = lpDigitSum(sum);
    return { value: sum2, steps: `${n} → ${digits} = ${sum} → ${digits2} = ${sum2}` };
  }

  function lpCalculate() {
    const monthEl = document.getElementById('lp-calc-month') as HTMLSelectElement;
    const dayEl = document.getElementById('lp-calc-day') as HTMLInputElement;
    const yearEl = document.getElementById('lp-calc-year') as HTMLInputElement;
    const errorEl = document.getElementById('lp-calc-error')!;
    const resultEl = document.getElementById('lp-calc-result')!;

    const month = parseInt(monthEl.value);
    const day = parseInt(dayEl.value);
    const year = parseInt(yearEl.value);

    errorEl.classList.add('hidden');
    resultEl.classList.add('hidden');

    if (!month || !day || !year || day < 1 || day > 31 || year < 1900 || year > 2025) {
      errorEl.textContent = 'Please enter a valid date of birth to calculate.';
      errorEl.classList.remove('hidden');
      return;
    }

    const monthNames = ['','January','February','March','April','May','June','July','August','September','October','November','December'];

    const mResult = lpReduceWithSteps(month);
    const dResult = lpReduceWithSteps(day);
    const yResult = lpReduceYear(year);

    const mAdd = lpToAddend(mResult.value);
    const dAdd = lpToAddend(dResult.value);
    const yAdd = lpToAddend(yResult.value);
    const total = mAdd + dAdd + yAdd;
    const finalResult = lpReduceFinal(total);

    const mMasterNote = (mResult.value === 11 || mResult.value === 22 || mResult.value === 33) ? ` <span style="color:var(--color-gold)">(master - used as ${mAdd})</span>` : '';
    const dMasterNote = (dResult.value === 11 || dResult.value === 22 || dResult.value === 33) ? ` <span style="color:var(--color-gold)">(master - used as ${dAdd})</span>` : '';
    const yMasterNote = (yResult.value === 11 || yResult.value === 22 || yResult.value === 33) ? ` <span style="color:var(--color-gold)">(master - used as ${yAdd})</span>` : '';
    const isMasterFinal = finalResult.value === 11 || finalResult.value === 22 || finalResult.value === 33;

    document.getElementById('lp-working-steps')!.innerHTML = `
      <div class="flex items-baseline gap-2 flex-wrap">
        <span style="color:var(--color-violet);font-weight:700;min-width:4.5rem">Month:</span>
        <span>${monthNames[month]} (${month})</span>
        ${mResult.steps !== String(month) ? `<span style="color:var(--color-muted-text)">→ ${mResult.steps}</span>` : ''}
        ${mMasterNote}
        <span style="color:var(--color-body-text);font-weight:700">= ${mResult.value}</span>
      </div>
      <div class="flex items-baseline gap-2 flex-wrap">
        <span style="color:var(--color-violet);font-weight:700;min-width:4.5rem">Day:</span>
        <span>${day}</span>
        ${dResult.steps !== String(day) ? `<span style="color:var(--color-muted-text)">→ ${dResult.steps}</span>` : ''}
        ${dMasterNote}
        <span style="color:var(--color-body-text);font-weight:700">= ${dResult.value}</span>
      </div>
      <div class="flex items-baseline gap-2 flex-wrap">
        <span style="color:var(--color-violet);font-weight:700;min-width:4.5rem">Year:</span>
        <span>${yResult.steps}</span>
        ${yMasterNote}
        <span style="color:var(--color-body-text);font-weight:700">= ${yResult.value}</span>
      </div>
      <div style="border-top:1px solid var(--color-border);margin-top:0.5rem;padding-top:0.75rem" class="flex items-baseline gap-2 flex-wrap">
        <span style="color:var(--color-violet);font-weight:700;min-width:4.5rem">Total:</span>
        <span>${mAdd} + ${dAdd} + ${yAdd} = ${total}</span>
        ${finalResult.steps !== String(total) ? `<span style="color:var(--color-muted-text)">→ ${finalResult.steps.replace(/^\d+ → /,'')}</span>` : ''}
        <span style="color:var(--color-gold);font-weight:800;font-size:1.1em">= ${finalResult.value}${isMasterFinal ? ' ✦' : ''}</span>
      </div>
    `;

    const key = String(finalResult.value);
    document.getElementById('lp-result-number')!.textContent = key;
    document.getElementById('lp-result-label')!.textContent = LP_LABELS[key] || '';
    document.getElementById('lp-result-blurb')!.textContent = LP_BLURBS[key] || '';
    (document.getElementById('lp-result-guide-link') as HTMLAnchorElement).href = `/learn/life-path-number-${key}/`;

    resultEl.classList.remove('hidden');
    resultEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  document.getElementById('lp-calc-btn')?.addEventListener('click', lpCalculate);
  ['lp-calc-day','lp-calc-year'].forEach(id => {
    document.getElementById(id)?.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter') lpCalculate();
    });
  });
</script>
